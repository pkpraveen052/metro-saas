<odoo>
    <data noupdate="0">

        <!-- Sample Invoice File -->
        <record id="sample_product_file" model="ir.attachment">
            <field name="name">Product Import</field>
            <field name="type">binary</field>
            <field name="datas"
                   type="base64"
                   file="metro_genie/sample_files/Product_Import.xlsx"/>
<!--            <field name="res_model">metro.sample.file.wizard</field>-->
<!--            <field name="public">True</field>-->
            <field name="is_export">True</field>
            <field name="public">True</field>
            <field name="group_ids"
                   eval="[(6, 0, [
                   ref('stock.group_stock_manager'),
                   ref('stock.group_stock_user')
                   ])]"/>
            <field name="mimetype">application/vnd.openxmlformats-officedocument.spreadsheetml.sheet</field>
        </record>

