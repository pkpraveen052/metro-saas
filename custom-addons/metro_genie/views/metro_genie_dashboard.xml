<odoo>
    <record id="view_metro_genie_dashboard" model="ir.ui.view">
        <field name="name">metro.genie.dashboard</field>
        <field name="model">metro.genie.dashboard</field>
        <field name="arch" type="xml">
            <form string="MetroGenie Dashboard" create="true" edit="true" js_class="genie_dashboard_form">
                <sheet>
<!--                    <div class="container">-->
                        <div class="oe_title">
                            <h1 class="mb-2" style="display: flex; align-items: center;">
                                <span>Welcome back,</span>
                                <field class="ml-2" name="current_user_name" nolabel="1" readonly="1" style="margin: 0; padding: 0;"/>
                            </h1>
                            <p class="text-muted">Need help? Ask me anything below.</p>
                        </div>
                        <div class="search-box" style="display: flex; align-items: center; gap: 12px; background: white; padding: 12px 16px; border-radius: 16px; box-shadow: 0 2px 6px rgba(0,0,0,0.05); margin-bottom: 24px; border: 1px solid #ddd;">
<!--                              <i class="fa fa-microphone" style="color: #666; cursor: pointer;"></i>-->
                                <field name="action_input" context="{'metro_genie': 1}" widget="genie_action_autocomplete_text" placeholder="Search....." style="flex-grow: 1; border: none; outline: none; background: transparent; font-size: 16px; min-height: 48px; max-height: 300px; overflow-y: auto;"/>
<!--                              <i class="fa fa-paper-plane send-icon" id="genie-send-button" style="color: #666; cursor: pointer;"></i>-->
                          </div>
                        <div class="button-row">
                            <button name="action_cre_contact" type="button" class="quick-button orange genie-nav-btn" data-suggestion="Create Contacts" groups="base.group_user,base.group_partner_manager"><i class="fa fa-users"></i> Create Contacts</button>
                            <button name="action_cre_invoice" type="button" class="quick-button blue genie-nav-btn" data-suggestion="Create Invoice" groups="account.group_account_invoice,account.group_account_readonly,metro_invoice_user.group_account_invoice_user"><i class="fa fa-file-text-o"></i> Create Invoice</button>
                            <button name="action_cre_bill" type="button" class="quick-button purple genie-nav-btn" data-suggestion="Create Bill" groups="account.group_account_invoice,account.group_account_readonly,metro_invoice_user.group_account_invoice_user"><i class="fa fa-file-text-o"></i> Create Bills</button>
                            <button name="action_cre_product" type="button" class="quick-button pink genie-nav-btn" data-suggestion="Create Product" groups="stock.group_stock_manager,stock.group_stock_user"><i class="fa fa-cube"></i> Create Product</button>
                            <button name="action_cre_ticket" type="button" class="quick-button orange genie-nav-btn" data-suggestion="Raise Issue/Ticket"><i class="fa fa-ticket"></i> Raise Issue/Ticket</button>

                            <button name="action_view_invoice" type="button" class="quick-button orange genie-nav-btn" data-suggestion="View Invoice" groups="account.group_account_invoice,account.group_account_readonly,metro_invoice_user.group_account_invoice_user" style="padding: -0.25rem 2.8rem;"><i class="fa fa-file-text-o"></i>View Invoice</button>
                            <button name="action_view_bill" type="button" class="quick-button yellow genie-nav-btn" data-suggestion="View Bill" groups="account.group_account_invoice,account.group_account_readonly,metro_invoice_user.group_account_invoice_user" style="padding: -0.25rem 2.8rem;"><i class="fa fa-file-text-o"></i>View Bill</button>
                            <button name="action_view_product" type="button" class="quick-button indigo genie-nav-btn" data-suggestion="View Product" groups="stock.group_stock_manager,stock.group_stock_user" style="padding: -0.25rem 2.8rem;"><i class="fa fa-cube"></i>View Product</button>
                            <div class="dropdown accounting-dropdown" style="position: relative;" groups="account.group_account_invoice,account.group_account_readonly,metro_invoice_user.group_account_invoice_user">
                                <button name="action_view_account_report" type="button" class="dropdown-toggle quick-button red accounting-reports-btn">
                                    <i class="fa fa-file-text-o"></i> Accounting Reports
                                </button>
                            </div>
                            <div class="sample-files-wrapper" style="position: relative;display: inline-block;">
                                <button name="action_open_sample_files" type="button"
                                        class="quick-button indigo sample-files-btn"
                                        style="min-width: 164px"
                                        title="Sample Files">
                                    <i class="fa fa-download mr-1"/>
                                    Sample Files
                                </button>
                            </div>
                            <!--<button name="action_view_pl" type="button" class="quick-button green genie-nav-btn" data-suggestion="View PL" groups="account.group_account_readonly,account.group_account_invoice"><i class="fa fa-bar-chart"></i> View PL</button>-->
                            <!--<button name="action_view_bs" type="button" class="quick-button teal genie-nav-btn" data-suggestion="View BS" groups="account.group_account_readonly,account.group_account_invoice"><i class="fa fa-line-chart"></i> View BS</button>-->
                        </div>
<!--                        <div class="button-row second">-->
<!--                            <button name="action_view_invoice" type="button" class="quick-button orange genie-nav-btn" data-suggestion="View Invoice" groups="account.group_account_invoice,account.group_account_readonly,metro_invoice_user.group_account_invoice_user" style="padding: 0.75rem 2.8rem;"><i class="fa fa-file-text-o"></i>View Invoice</button>-->
<!--                            <button name="action_view_bill" type="button" class="quick-button yellow genie-nav-btn" data-suggestion="View Bill" groups="account.group_account_invoice,account.group_account_readonly,metro_invoice_user.group_account_invoice_user" style="padding: 0.75rem 2.8rem;"><i class="fa fa-file-text-o"></i>View Bill</button>-->
<!--                            <button name="action_view_product" type="button" class="quick-button indigo genie-nav-btn" data-suggestion="View Product" groups="stock.group_stock_manager,stock.group_stock_user" style="padding: 0.75rem 2.8rem;"><i class="fa fa-cube"></i>View Product</button>-->
<!--                            <div class="dropdown accounting-dropdown" style="position: relative;" groups="account.group_account_invoice,account.group_account_readonly,metro_invoice_user.group_account_invoice_user">-->
<!--                                <button name="action_view_account_report" type="button" class="dropdown-toggle quick-button red accounting-reports-btn">-->
<!--                                    <i class="fa fa-file-text-o"></i> Accounting Reports-->
<!--                                </button>-->
<!--                            </div>-->
<!--                        </div>-->
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_metro_genie_dashboard" model="ir.actions.act_window">
        <field name="name">MetroGenie Dashboard</field>
        <field name="res_model">metro.genie.dashboard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_metro_genie_dashboard"/>
    </record>
</odoo>
