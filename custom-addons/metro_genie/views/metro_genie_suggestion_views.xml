<odoo>
    <record id="view_metro_genie_suggestion_tree" model="ir.ui.view">
        <field name="name">metro.genie.suggestion.tree</field>
        <field name="model">metro.genie.suggestion</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence" invisible="1"/>
                <field name="name"/>
<!--                <field name="action_xml_id"/>-->
                <field name="description"/>
                <field name="window_action_id" optional="hide"/>
                <field name="client_actions_id" optional="hide"/>
                <field name="view_types" optional="hide"/>
                <field name="menu_id" optional="hide"/>
                <field name="model" invisible="1"/>
                <field name="is_button"/>
                <field name="is_accounting_report"/>
            </tree>
        </field>
    </record>
    <record id="view_metro_genie_suggestion_form" model="ir.ui.view">
        <field name="name">metro.genie.suggestion.form</field>
        <field name="model">metro.genie.suggestion</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="sequence" invisible="1"/>
                            <field name="name"/>
                            <field name="window_action_id"/>
                            <field name="client_actions_id"/>
                        </group>
                        <group>
                            <field name="view_types"/>
                            <field name="model" invisible="1"/>
                            <field name="menu_id"/>
                            <field name="group_ids" invisible="1"/>
                            <field name="is_button"/>
                            <field name="is_accounting_report"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="description"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_metro_genie_suggestion" model="ir.actions.act_window">
        <field name="name">Suggestions</field>
        <field name="res_model">metro.genie.suggestion</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{}</field>
    </record>
</odoo>