<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
		<template id="report_supplier_statement">
			<t t-call="account_statement.custom_external_account_layout">
				<t t-set="doc" t-value="doc.with_context({'lang':doc.lang})" />
				<div class="page" style="font-family: 'Open Sans', Arial, sans-serif; font-size:10.0pt;">
				<t t-set="company" t-value="res_company"/>
				<div class="oe_structure" />
				<h5 style="margin:20px;text-align:center;font-weight:bold;">STATEMENT OF ACCOUNT</h5>
				<br/><br/>
				<div class="row" style="margin-top: 0px !important;">
					<div class="col-6">
						<strong>Name: </strong><span t-esc="doc.name" /><br/>
						<div>
                            <strong>Address:</strong>
                            <t t-if="doc.street">
                                <span t-field="doc.street"/>,
                            </t>
                            <t t-if="doc.street2">
                                <span t-field="doc.street2"/>,
                            </t>
                            <t t-if="doc.street or doc.street2">
                                <br/>
                            </t>
                            <t t-if="doc.city">
                                <span t-field="doc.city"/>,
                            </t>
                            <t t-if="doc.state_id">
                                <span t-field="doc.state_id.name"/>,
                            </t>
                            <t t-if="doc.zip">
                                <span t-field="doc.zip"/>,
                            </t>
                            <t t-if="doc.country_id">
                                <span t-field="doc.country_id.name"/>
                            </t>
                        </div>
                        <div t-if="doc.phone">
                            <strong>Phone: </strong><span t-field="doc.phone"/>
                        </div>
                        <div t-if="doc.email">
                            <strong>Email: </strong><span t-field="doc.email"/>
                        </div>
					</div>
					<div class="col-3"></div>
					<div class="col-3">
						 <strong>Print Date </strong><span t-esc="context_timestamp(datetime.datetime.now())" t-options="{'widget': 'date'}"/>
					</div>
				</div>
				<br/>
				<div class="page">
					<style>
						.border-black {
							border: 1px solid black;
						}
						.table-bordered {
							border-collapse: collapse;
						}
						.table-bordered th, .table-bordered td {
							border: 1px solid black;
						}
						.table-sm th, .table-sm td {
							padding: 0.3rem;
						}
						.text-right {
							text-align: right;
						}						
					</style>
					<t t-set="bal" t-value="doc.get_cryfwd_supplier_initial_balance()"/>
					<!-- <t t-set="i" t-value="0.0" />
					<t t-set="j" t-value="0.0" />
					<t t-set="k" t-value="0.0" /> -->					
					<!-- <t t-foreach="doc.supplier_invoice_ids" t-as="line">
						<t t-set="i" t-value="i+ line.amount_total_signed" />
						<t t-set="j" t-value="j+line.credit_amount" />
						<t t-set="k" t-value="k+line.result" />
					</t> -->			
					<t t-set="i" t-value="bal" />
					<t t-set="j" t-value="0.0" />
					<t t-set="sub_total" t-value="0.0" />		
					
					<table class="table table-sm table-bordered border-black">
						<thead>
							<tr class="text-center">
								<th>Date</th>
								<th>Invoice Number</th>
								<th>Account</th>
								<th>Ref</th>
								<th>Invoices/Debit</th>
								<th>Payments/Credit</th>
								<th>Balance</th>
							</tr>
						</thead>
						<tbody>
							<tr>
								<td></td>
								<td><b>Initial Balance</b></td>
								<td></td>
								<td></td>
								<td class="text-right"><span t-esc="bal" t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/></td>
								<td class="text-right"><span t-esc="0.0" t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/></td>
								<td class="text-right" style="background-color: transparent;">
									<b><span t-esc="bal" t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/></b>
								</td>
							</tr>
							<tr t-foreach="doc.supplier_invoice_ids.sorted(key=lambda r: (r.invoice_date, r.name))" t-as="line">
								<t t-set="debit" t-value="-1 * line.amount_total"/>
								<t t-set="credit" t-value="line.credit_amount"/>

								<t t-if="line.adjust_in_carry_fwd_bal">
									<t t-set="debit" t-value="0.00"/>
									<t t-set="credit" t-value="-1 * line.credit_amount"/>
								</t>

								<t t-if="line.move_type == 'in_refund'">
									<t t-set="debit" t-value="line.amount_total"/>
								</t>

								<td><span t-esc="line.invoice_date" t-options="{'widget': 'date'}"/></td>
								<td><span t-esc="line.name" /></td>
								<td>
									<span t-esc="line.partner_id.property_account_payable_id.code" />
								</td>
								<td><span t-esc="line.ref"/></td>
								<td class="text-right">
									<span t-esc="debit" t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/>
								</td>
								<td class="text-right">
									<span t-esc="credit" t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}" />
								</td>
								<td class="text-right" style="background-color: transparent;">
									<t t-set="sub_total" t-value="bal - credit + debit" />
									<span t-esc="sub_total" t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}" />
									<t t-set="bal" t-value="sub_total"/>
								</td>

								<t t-set="i" t-value="i+debit" />
								<t t-set="j" t-value="j+credit" />
							</tr>
							<tr>
								<td class="text-right"></td>
								<td></td>
								<td></td>
								<td><b>Total</b></td>
								<td class="text-right" style="background-color: transparent;"><b><span t-esc="i" t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/></b></td>
								<td class="text-right" style="background-color: transparent;"><b><span t-esc="j" t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/></b></td>
								<td class="text-right" style="background-color: transparent;"><b><span t-esc="sub_total" t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/></b></td>
							</tr>
						</tbody>
					</table>
					<div>
						<table class="table table-sm" style="border: none;table-layout:fixed;margin-right: 0;margin-left: auto;width: 35%;">
							<tr>
								<td style="border: none;">
									<strong>Balance Due :</strong>
								</td >
								<td class="text-right" style="border: none;">
									<strong>
									<span t-field="doc.payment_amount_due_amt_supplier"
										t-options='{"widget": "monetary", "display_currency": res_company.currency_id}' />
									</strong>
								</td>
							</tr>
						</table>
					</div>
					<t t-if="doc.company_id.show_supplier_summary_statement">
						<div>
		  					<t t-set="inv_data" t-value="doc.compute_dayswise_supplier_balance_summary()"/>
		            		<span style="font-weight: bold;font-size: 1rem;">Summary (As of <span t-esc="inv_data[5]" t-options="{'widget': 'date'}"/>)</span>
	  						<table t-attf-class="table table-sm" name="days_table">
		  						<thead>
		  							<tr>
		  								<th>0-30</th>
		  								<th>30-60</th>
		  								<th>60-90</th>
		  								<th>90+</th>
		  								<th>Total</th>
		  							</tr>
		  						</thead>
		  						<tr>
		  							<td><span t-esc="inv_data[0]" t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/></td>
		  							<td><span t-esc="inv_data[1]" t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/></td>
		  							<td><span t-esc="inv_data[2]" t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/></td>
		  							<td><span t-esc="inv_data[3]" t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/></td>
		  							<td style="background-color: transparent;"><span t-esc="inv_data[4]" t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/></td>
		  						</tr>
		  					</table>
						</div>
					</t>
				</div>
			</div>
			</t>
		</template>

		<template id="report_supplier">
			<t t-call="web.html_container">
				<t t-foreach="docs" t-as="doc">
					<t t-call="account_statement.report_supplier_statement" t-lang="doc.lang" />
				</t>
			</t>
		</template>

		<record id="report_supplier_print" model="ir.actions.report">
			<field name="name">Supplier Statement</field>
			<field name="model">res.partner</field>
			<field name="report_type">qweb-pdf</field>
			<field name="report_name">account_statement.report_supplier</field>
			<field name="report_file">account_statement.report_supplier</field>
			<field name="print_report_name">'%s_Supplier_Statement.pdf' % (object.name)</field>
			<field name="binding_model_id" eval="False"/>
			<field name="binding_type">report</field>
			<field name="paperformat_id" ref="account_statement.paperformat_customer_statement"/>
			<field name="attachment">'%s_Supplier_Statement.pdf' % (object.name)</field>
		</record>
	</data>
</odoo>
