<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_customer_monthly_statement_wizard" model="ir.ui.view">
        <field name="name">customer.monthly.statement.wizard.form</field>
        <field name="model">customer.monthly.statement.wizard</field>
        <field name="arch" type="xml">
            <form string="Customer Monthly Statement Wizard">
                <group>
                    <group>
                        <field name="date_from"/>
                        <field name="date_to" readonly="1" force_save="1"/>
                        <field name="partner_id" invisible="1"/>
                    </group>
                </group>
                <footer>
                    <button string="Print" type="object" name="generate_report" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_customer_monthly_statement_wizard" model="ir.actions.act_window">
        <field name="name">Customer Monthly Statement Wizard</field>
        <field name="res_model">customer.monthly.statement.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
