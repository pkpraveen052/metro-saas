<odoo>

    <template id="report_payment_voucher_payee">
        <t t-set="o" t-value="docs"/>
        <t t-call="metroerp_accounting_enhancement.custom_external_partner_layout">
            <div class="page" style="font-family: 'Open Sans', Arial, sans-serif; font-size:10.0pt;">
                <div class="oe_structure"/>
                <div class="row">
                    <div class="col-8 text-left">
                        <b>
                            <t>
                                <strong style="font-size: 13.0pt;color: #495057;">Payee:
                                    <span t-field="o.pay_to"/>
                                </strong>
                            </t>
                        </b>
                    </div>
                    <!--<div class="col-4 text-right"/>-->
                    <div class="col-4 text-right">
                        <div>
                            <strong>
                                <span style="font-size: 13.0pt;color: #495057;">Payment Voucher</span>
                            </strong>
                        </div>
                        <div>
                            <div>
                                <strong style="font-size: 10.0pt;color: #495057;">
                                    <span t-field="o.name"/>
                                </strong>
                            </div>
                            <div>
                                <strong style="font-size: 10.0pt;color: #495057;">Date:
                                    <span t-field="o.date" t-options="{&quot;widget&quot;: &quot;date&quot;}"/>
                                </strong>
                            </div>
                        </div>

                    </div>
                </div>
                <br/>
                <!-- Is there a discount on at least one line? -->
                <div class="col-12 text-left" style="margin-left:-17px;">
                    <b>
                        <strong style="color: #495057;">Being Payment For
                            <span t-field="o.ref"/>
                        </strong>
                    </b>
                </div>
                <br/>
                <table class="table table-sm o_main_table" name="invoice_line_table" style="table-layout:fixed">
                    <t>
                        <col width="12%"/>
                        <col width="24%"/>
                        <col width="37%"/>
                        <col width="15%"/>
                        <col width="12%"/>
                        <t t-set="total_style" t-value="'page-break-inside: avoid;table-layout:fixed;margin-right: 0;margin-left: auto;width:35%;'"/>
                    </t>
                    <thead>
                        <tr>
                            <th name="th_account_no" class="text-center" style="vertical-align: middle;">Account No</th>
                            <th name="th_account_name" class="text-center" style="vertical-align: middle;">
                                <span>Account Name</span>
                            </th>
                            <th name="th_description" class="text-center" style="vertical-align: middle;">
                                <span>Description</span>
                            </th>
                            <th name="th_taxes" class="text-center" style="vertical-align: middle;">
                                <span>Tax</span>
                            </th>
                            <th name="th_amount" class="text-center" style="vertical-align: middle;">
                                <span>Amount</span>
                            </th>
                        </tr>
                    </thead>
                    <t t-set="item_num" t-value="0"/>
                    <tbody class="invoice_tbody">
                        <t t-set="current_subtotal" t-value="0"/>
                        <t t-foreach="o.line_ids.filtered(lambda l: l.account_id.user_type_id.name != 'Bank and Cash' and l.move_id.move_type == 'entry')" t-as="line">
                            <!--                    <t t-set="current_subtotal" t-value="current_subtotal + line.price_subtotal"/>-->
                            <!--                    <t t-set="current_subtotal" t-value="current_subtotal + line.price_total"/>-->
                            <!--                    <t t-set="amount" t-value="line.compute_line_amount_credit_debit()"/>-->
                            <tr>
                                <t name="account_invoice_line_accountable">
                                    <td name="account_invoice_line_name" class="text-center">
                                        <span t-field="line.account_id.code"/>
                                    </td>
                                    <td name="td_description" class="text-left">
                                        <span t-field="line.account_id.name" t-options="{'widget': 'text'}"/>
                                    </td>
                                    <td name="td_description" class="text-left">
                                        <span t-field="line.name"/>
                                    </td>
                                    <td name="td_taxes" class="text-center">
                                        <span t-esc="', '.join(map(lambda x: (x.description or x.name), line.tax_ids))" id="line_tax_ids"/>
                                    </td>
                                    <td name="td_amount">
                                        <span t-esc="o.currency_id.symbol" style="float: left;text-align: left;"/>
                                        <t t-set="amount_round" t-value="line.debit - line.credit" />
                                        <span t-esc="'%.2f' % amount_round" style="float: right;text-align: right;"/>
                                    </td>
                                </t>
                            </tr>
                        </t>
                    </tbody>
                </table>


                <!--<div class="col-4 offset-8 position-relative" style="margin-top:20px;">-->
                <!--    <div style="margin-left:180px;">-->
                <!--        <tr style="font-size:15px;">-->
                <!--            <td class="text-left">-->
                <!--                <strong style="color: #000000;">Total:</strong>-->
                <!--            </td>-->
                <!--            <t t-set="total_amount" t-value="0"/>-->
                <!--            <t t-foreach="o.line_ids.filtered(lambda l: l.account_id.user_type_id.name != 'Bank and Cash' and l.move_id.move_type == 'entry')" t-as="line">-->
                <!--                <t t-set="total_amount" t-value="total_amount + (line.debit - line.credit)"/>-->
                <!--            </t>-->
                <!--            <td class="text-right" style="color: #000000;">-->
                <!--                <span t-esc="total_amount" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>-->
                <!--            </td>-->
                <!--        </tr>-->
                <!--    </div>-->
                <!--</div>-->

                <div name="so_total_summary">
                    <div id="total" name="total">
                        <table class="table table-sm" t-att-style="total_style">
                            <t t-foreach="o.line_ids.filtered(lambda l: l.account_id.user_type_id.name == 'Bank and Cash' and l.move_id.move_type == 'entry')" t-as="line">
                                <tr>
                                    <td style="border-right: none;background: white;">
                                        <span style="font-weight:bold;color: #000000" t-field="line.account_id.name"/>
                                    </td>
                                    <td class="text-right" style="background: white;">
                                        <span style="color: #000000" t-field="line.name"/>
                                    </td>
                                </tr>
                                <tr class="border-black o_subtotal">
                                    <td name="td_amount_untaxed_label" style="background: white;">
                                        <strong>Amount:</strong>
                                    </td>
                                    <td name="td_amount_untaxed" style="background: white;">
                                        <span t-esc="o.currency_id.symbol" style="margin-left: 50px;float: left;text-align: left;font-weight:bold;color: #000000"/>
                                        <t t-set="amount_round_summary" t-value="line.credit - line.debit" />
                                        <span t-esc="'%.2f' % amount_round_summary" style="float: right;text-align: right;font-weight:bold;color: #000000"/>
                                    </td>
                                </tr>
                            </t>
                        </table>
                    </div>
                </div>
            </div>
            <div name="signature" style="font-family: 'Open Sans', Arial, sans-serif; font-size:10.0pt;color:black;margin-top:100px;">
                <table calss="col-12" width="100%" style="font-family: 'Open Sans', Arial, sans-serif; font-size:10.0pt;">
                    <tr style="border:1px solid white;">
                        <td width="50%" class="float-left text-left" style="vertical-align: top;color:black;border:1px solid white;">
                            <div style="vertical-align: top;border-top:1px solid #000;text-align:center;width:80%;height:auto;margin-bottom:10px;"/>
                            <strong>Checked / Approved / Authorised By</strong>
                        </td>
                        <td width="50%" class="float-right text-left" style="vertical-align: top;background:white;color:black;border:1px solid white;padding-left:30px;">
                            <div style="vertical-align: top;border-top:1px solid #000;text-align:center;width:100%;height:auto;margin-bottom:10px;"/>
                            <strong>Received By</strong>
                        </td>
                    </tr>
                </table>
            </div>
        </t>
    </template>



    <template id="payment_voucher_report">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="metroerp_accounting_enhancement.report_payment_voucher_payee"/>
            </t>
        </t>
    </template>


    <record id="action_report_payment_voucher_report" model="ir.actions.report">
        <field name="name">Payment Voucher Payee</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">metroerp_accounting_enhancement.payment_voucher_report</field>
        <field name="report_file">metroerp_accounting_enhancement.payment_voucher_report</field>
        <field name="print_report_name">'%s_Payment_Voucher_Report_Payee.pdf' % (object.name)</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="metroerp_accounting_enhancement.paperformat_payment_voucher"/>
<!--        <field name="context">{'default_move_type': 'entry'}</field>-->
    </record>

</odoo>
