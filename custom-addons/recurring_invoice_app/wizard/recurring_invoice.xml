<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

    <record id="recurring_invoice_view_form" model="ir.ui.view">
        <field name="name">recurring.invoice.view.form</field>
        <field name="model">recurring.invoice</field>
        <field name="arch" type="xml">
            <form string="Recurring Order">
                <header>                    
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div attrs="{'invisible': [('display_note','=',False)]}">
                        <b>Note: </b><field name="display_note" nolabel="1" readonly="1"/>
                    </div>
                    <group>
                        <group>
                            <field name="name" required="1"/>
                            <field name="user_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="partner_id" required="1"
                                attrs="{'readonly': [('state', '=','running')]}"
                                domain="[('company_id', '=', company_id)]"/>
                            <field name="active" invisible="1"/>
                            <field name="company_id" invisible="1"/>
                        </group>                        
                    </group>
                    <notebook>
                        <page string="Recurring Data">
                            <group>
                                <group> 
                                    <field name="first_date" required="1" attrs="{'readonly': [('state', '=','running')]}"/>
                                    <field name="total" invisible="1"/>
                                    <field name="due_date" invisible="1"/>
                                    <field name="recurring_number" required="1" attrs="{'readonly': [('state', '=','running')]}"/>
                                </group>
                                <group>
                                    <field name="interval_type" required="1" attrs="{'readonly': [('state', '=','running')]}"/>
                                    <field name="recurring_interval" required="1" attrs="{'readonly': [('state', '=','running')]}"/>
                                </group>
                            </group>
                        </page>
                        <page string="Invoice Lines">
                            <field name="line_ids">
                                <tree string="Invoice Lines" create="0" editable="bottom">
                                    <field name="product_id" readonly="1" force_save="1"/>
                                    <field name="name" force_save="1" width="200px"/>
                                    <field name="account_id" readonly="1" invisible="1" force_save="1"/>
                                    <field name="quantity" readonly="1" force_save="1"/>
                                    <field name="product_uom_id" readonly="1" force_save="1" invisible="1"/>
                                    <field name="price_unit" readonly="1" force_save="1"/>
                                    <field name="tax_ids" readonly="1" force_save="1"/>
                                    <field name="currency_id" readonly="1" invisible="1" force_save="1"/>
                                    <field name="price_subtotal" readonly="1" force_save="1"/>
                                    <field name="price_total" readonly="1" force_save="1"/>
                                    <field name="wizard_id" invisible="1" force_save="1"/>
                                </tree>
                            </field>
                            <br/>
                            <group col="3" string="Legend (for Invoice Lines Label)">
                                <group>
                                    <span colspan="3">Fiscal Quarter: %%(fiscal_quarter)s</span>
                                    <span colspan="3">Fiscal Quarter Start Month: %%(fq_start_month)s</span>
                                    <span colspan="3">Fiscal Quarter End Month: %%(fq_end_month)s</span>
                                    <span colspan="3">Fiscal Start Year with Century: %%(fq_start_year)s</span>
                                    <span colspan="3">Fiscal End Year with Century: %%(fq_end_year)s</span>
                                    <span colspan="3">Fiscal Start Year without Century: %%(fq_start_y)s</span>
                                    <span colspan="3">Fiscal End Year without Century: %%(fq_end_y)s</span>
                                </group>
                                <group>
                                    <span colspan="2">Quarter: %%(quarter)s</span>
                                    <span colspan="2">Quarter Start Month: %%(quarter_start_month)s</span>
                                    <span colspan="2">Quarter End Month: %%(quarter_end_month)s</span>
                                    <span colspan="2">Current Year with Century: %%(year)s</span>
                                    <span colspan="2">Current Year without Century: %%(y)s</span>
                                </group>
                                <group>
                                    <span colspan="2">Current Year with Century: %%(year)s</span>
                                    <span colspan="2">Current Year without Century: %%(y)s</span>
                                    <span colspan="2">Month: %%(month)s</span>
                                    <span colspan="2">Day: %%(day)s</span>
                                </group>
<!--                                <group>-->
<!--                                    <span colspan="2">Month Full Name: %%(month_name)s</span>-->
<!--                                    <span colspan="2">Month Short Name: %%(month_short)s</span>-->
<!--                                    <span colspan="2">Day: %%(day)s</span>-->
<!--                                </group>-->
                            </group>

                        </page>
                        <page string="Scheduled Invoice" invisible="1"> 
                            <field name="scheduled_idss">
                                <tree string="Recurring Lines" editable="bottom">
                                    <field name="recurring_invoice_id" invisible="1"/>
                                    <field name="schedule_date"/>
                                    <field name="invoice"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button name="confirm_recurring" string="Confirm Recurring Process" class="btn-primary" type="object" attrs="{'invisible': [('state', '=','running')]}"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_recurring_invoice" model="ir.actions.act_window">
        <field name="name">Recurring invoice</field>
        <field name="res_model">recurring.invoice</field>
        <field name="view_mode">form</field>
    </record>

    </data>
</odoo>