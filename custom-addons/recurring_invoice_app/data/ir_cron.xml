<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">

        <record model="ir.cron" id="recurring_invoice_reminder">
            <field name="name">Reminder Mail: Send by email</field>
            <field name="model_id" ref="recurring_invoice_app.model_recurring_invoice"/>
            <field name="state">code</field>
            <field name="code">model._cron_recurring_invoice_alerts()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="active">False</field>
            <field name="user_id" ref="base.user_admin" />
        </record>
    </data>

    <data noupdate="0">
        <record model="ir.cron" id="recurring_invoice_details">
                <field name="name">Create recurring Invoice</field>
                <field name="model_id" ref="recurring_invoice_app.model_scheduled_invoices"/>
                <field name="state">code</field>
                <field name="code">model._cron_recurring_invoice_detail_create()</field>
                <field name="interval_number">1</field>
                <field name="interval_type">days</field>
                <field name="numbercall">-1</field>
                <field name="doall" eval="False"/>
                <field name="user_id" ref="base.user_admin"/>
        </record>
    </data>
</odoo>