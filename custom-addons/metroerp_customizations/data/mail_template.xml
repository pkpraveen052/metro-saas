<odoo>
    <data noupdate="1">
        <record id="mail_template_delivery_order_confirmation" model="mail.template">
            <field name="name">Delivery Order: Confirmation Email</field>
            <field name="model_id" ref="stock.model_stock_picking"/>
            <field name="subject">${object.company_id.name} ${'Order'} (Ref ${object.name or 'n/a' })</field>
            <field name="email_from">${(object.user_id.email_formatted or user.email_formatted) | safe}</field>
            <field name="email_to">${object.partner_id.email}</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p style="margin: 0px; padding: 0px; font-size: 13px;">
                        Dear ${object.partner_id.name},<br/><br/>
                        We are glad to inform you that your delivery order <strong>${object.name}</strong> has been confirmed.
                        <br/><br/>
                        Please find your delivery order attached for more details.<br/><br/>
                        Thank you,
                    </p>
                </div>
            </field>
            <field name="report_template" ref="stock.action_report_delivery"/>
            <field name="report_name">${(object.name or '').replace('/','_')}</field>
            <field name="lang">${object.partner_id.lang}</field>
            <field name="auto_delete" eval="True"/>
        </record>
    </data>
</odoo>
