<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="inherited_email_compose_message_wizard_form" model="ir.ui.view">
            <field name="name">mail.compose.message.form.view</field>
            <field name="model">mail.compose.message</field>
            <field name="groups_id" eval="[(4, ref('metroerp_customizations.sub_admin_group')),(4, ref('base.group_user'))]"/>
            <field name="inherit_id" ref="mail.email_compose_message_wizard_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form/group[2]/field[@name='template_id']" position="replace">
                     <field name="template_id"
                            options="{'no_create': True, 'no_open': True}"
                            domain="[('company_id', 'in', [False, company_id]),('model','=',model)]"
                            context="{'default_model': model, 'default_body_html': body, 'default_subject': subject}"/>
                </xpath>
                <xpath expr="//form/group[1]/field[@name='model']" position="after">
                    <field name="company_id" invisible="1"/>
               </xpath>
            </field>
        </record>

        <record id="inherited_invoice_send_wizard_form" model="ir.ui.view">
            <field name="name">account.invoice.send.form.view</field>
            <field name="model">account.invoice.send</field>
            <field name="groups_id" eval="[(4, ref('metroerp_customizations.sub_admin_group')),(4, ref('base.group_user'))]"/>
            <field name="inherit_id" ref="account.account_invoice_send_wizard_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='composition_mode']" position="after">
                    <field name="company_id" invisible="1"/>
                    <field name="model" invisible="1"/>
                </xpath>
                <xpath expr="//field[@name='template_id']" position="attributes">
                    <attribute name="domain">[('model', '=', model),('company_id', 'in', [False, company_id])]</attribute>
                    <attribute name="options">{'no_open': True,'no_create': True}</attribute>
                </xpath>
            </field>
        </record>
    </data>
</odoo>