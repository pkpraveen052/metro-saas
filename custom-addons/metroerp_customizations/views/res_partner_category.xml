<?xml version="1.0" encoding="utf-8"?>

<odoo>
	<data>

        <record id="inherited_res_partner_category_list_view" model="ir.ui.view">
            <field name="name">res.partner.category.inherited.list.view</field>
            <field name="model">res.partner.category</field>
            <field name="inherit_id" ref="base.view_partner_category_list"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='display_name']" position="after">
                    <field name="company_id" string="Company" required="1"/>
                </xpath>
            </field>
        </record>

<!--        res partner category form view inherit-->
        <record id="inherited_res_partner_category_form_view" model="ir.ui.view">
            <field name="name">res.partner.category.inherited.form.view</field>
            <field name="model">res.partner.category</field>
            <field name="inherit_id" ref="base.view_partner_category_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='parent_id']" position="after">
                    <field name="company_id" string="Company" required="1"/>
                </xpath>
            </field>
        </record>

	</data>
</odoo>