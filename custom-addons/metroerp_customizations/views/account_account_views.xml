<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <!-- Inherit account.account form view -->
        <record id="view_account_form_inherit_journal_items" model="ir.ui.view">
            <field name="name">account.account.form.inherit.journal.items</field>
            <field name="model">account.account</field>
            <field name="inherit_id" ref="account.view_account_form"/>
            <field name="arch" type="xml">

                <xpath expr="//div[@name='button_box']/button[@name='account.action_move_line_select']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>

                <xpath expr="//div[@name='button_box']" position="inside">
                    <button class="oe_stat_button" 
                            name="action_open_journal_items"
                            string="Journal Items" 
                            type="object" 
                            icon="fa-bars"/>
                </xpath>

            </field>
        </record>

        <record id="account.action_move_line_select" model="ir.actions.act_window">
            <field name="name">Journal Items</field>
            <field name="res_model">account.move.line</field>
            <field name="context">{'search_default_posted': 1}</field>
        </record>

    </data>
</odoo>
