<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>

		<!-- Product Tags Tree View -->
		<record id="view_product_tags_tree" model="ir.ui.view">
			<field name="name">product.tags.tree</field>
			<field name="model">product.tags</field>
			<field name="arch" type="xml">
				<tree string="Product Tags" sample="1">
					<field name="name"/>
					<field name="color" widget="color_picker"/>
					<field name="product_ids"/>
				</tree>
			</field>
		</record>

		<!-- Product Tags Form View -->
		<record id="view_product_tags_form" model="ir.ui.view">
			<field name="name">product.tags.form</field>
			<field name="model">product.tags</field>
			<field name="arch" type="xml">
				<form string="Product Tags">
					<sheet>
						<div class="oe_title">
                            <h1>
                                <field name="name" placeholder="Tag Name"/>
                            </h1>
                        </div>
                        <br/><br/>
			<group>
				<group>
							<field name="color" widget="color_picker" required="True"/>
						</group><group/>
						</group>
						<group>
							<group>
								<field name="sequence"/>
							</group>
							<group>
								<field name="company_id"/>
							</group>
						</group>
						<field name='product_ids' options="{'no_create_edit': True}" domain="[('company_id','=',company_id)]"/>
					</sheet>
				</form>
			</field>
		</record>

		<!-- Product Tags Action -->
		<record id="product_tags_tree_action" model="ir.actions.act_window">
			<field name="name">Product Tags</field>
			<field name="res_model">product.tags</field>
			<field name="view_mode">tree,form</field>
			<field name="view_id" ref="view_product_tags_tree"/>
			<field name="help" type="html">
				<p class="o_view_nocontent_smiling_face">
					Create a new tags for your Products.
				</p>
			</field>
		</record>

		<!-- Product Tags Menu -->
		<menuitem action="product_tags_tree_action" id="menu_product_tags"
			parent="sale.product_menu_catalog"/>



	</data>
</odoo>
