<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="inherited_account_bank_statement_form_view" model="ir.ui.view">
            <field name="name">account.bank.statement.inherit</field>
            <field name="model">account.bank.statement</field>
            <field name="inherit_id" ref="account.view_bank_statement_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='line_ids']//tree//field[@name='partner_id']" position="replace">
                    <field name="partner_id" attrs="{'readonly': [('parent.state', '!=', 'open')]}"
                           domain="[('company_id', '=', parent.company_id)]"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
