        <menuitem action="stock_landed_costs.action_stock_landed_cost"
                  name="Landed Costs" parent="stock.menu_stock_warehouse_mgmt"
                  id="stock_landed_costs.menu_stock_landed_cost" sequence="115"
                  groups="metroerp_customizations.group_module_stock_landed_costs"/>
    </data>
</odoo>
