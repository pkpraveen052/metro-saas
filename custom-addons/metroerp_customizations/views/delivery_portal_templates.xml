<odoo>
    <template id="portal_my_home_menu_delivery" name="Portal layout : delivery menu entries" inherit_id="portal.portal_breadcrumbs" priority="40">
        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
            <li t-if="page_name == 'delivery'" t-attf-class="breadcrumb-item #{'active ' if not delivery else ''}">
                <a t-if="delivery_order" t-attf-href="/my/deliveries?{{ keep_query() }}">Delivery Orders</a>
                <t t-else="">Delivery Orders</t>
            </li>
            <li t-if="delivery_order" class="breadcrumb-item active">
                <t t-esc="delivery_order.name" t-if="delivery_order.name != '/'"/>
                <t t-else=""><em>Draft Delivery Order </em></t>
            </li>
        </xpath>
    </template>

    <template id="portal_my_home_delivery" name="Show Delivery Order" inherit_id="portal.portal_my_home" customize_show="True" priority="40">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="title">Delivery Orders</t>
                <t t-set="url" t-value="'/my/deliveries'"/>
                <t t-set="placeholder_count" t-value="'delivery_count'"/>
            </t>
        </xpath>
    </template>

    <template id="portal_my_delivery" name="My Delivery Order">
      <t t-call="portal.portal_layout">
        <t t-set="breadcrumbs_searchbar" t-value="True"/>

        <t t-call="portal.portal_searchbar">
            <t t-set="title">Delivery Orders</t>
        </t>
        <t t-if="not deliveries">
            <p>There are currently no delivery order for your account.</p>
        </t>
        <t t-if="deliveries" t-call="portal.portal_table">
            <thead>
                <tr class="active">
                    <th>Delivery Orders#</th>
                    <th>Shipping Date</th>
                    <th class='d-none d-md-table-cell'>Deadline</th>
                    <th>Source Document</th>
                </tr>
            </thead>
            <tbody>
                <t t-foreach="deliveries" t-as="delivery">
                    <tr>
                        <td><a t-att-href="delivery.get_portal_url()" t-att-title="delivery.name"><t t-esc="delivery.name"/></a></td>
                        <td><span t-field="delivery.scheduled_date"/></td>
                        <td class='d-none d-md-table-cell'><span t-field="delivery.date_deadline"/></td>
                        <td><span t-field="delivery.origin"/></td>
                    </tr>
                </t>
            </tbody>
        </t>
      </t>
    </template>

    <template id="portal_delivery_page" name="Delivery Portal Template" inherit_id="portal.portal_sidebar" primary="True">
        <xpath expr="//div[hasclass('o_portal_sidebar')]" position="inside">
            <t t-set="o_portal_fullwidth_alert" groups="stock.group_stock_manager">
                <t t-call="portal.portal_back_in_edit_mode">
                    <t t-set="backend_url" t-value="'/web#model=%s&amp;id=%s&amp;action=%s&amp;view_type=form' % (delivery_order._name, delivery_order.id, delivery_order.env.ref('stock.action_picking_tree_all').id)"/>
                </t>
            </t>

            <div class="row mt16 o_portal_delivery_sidebar">
                <!-- Sidebar -->
                <t t-call="portal.portal_record_sidebar">
                    <t t-set="classes" t-value="'col-lg-auto d-print-none'"/>
                    <t t-set="title">
                        <h2 class="mb-0">
                            <b>Delivery Order</b>
                        </h2>
                    </t>
                    <t t-set="entries">
                        <ul class="list-group list-group-flush flex-wrap flex-row flex-lg-column">
                            <li class="list-group-item flex-grow-1">
                                <a t-if="delivery_order.has_to_be_signed(True)" role="button" class="btn btn-primary btn-block mb8" data-toggle="modal" data-target="#modalaccept" href="#">
                                    <i class="fa fa-check"/><t> Accept &amp; Sign</t>
                                </a>
                                <div class="o_download_pdf btn-toolbar flex-sm-nowrap">
                                    <div class="btn-group  flex-grow-1 mr-1 mb-1">
                                        <a class="btn btn-secondary btn-block o_download_btn" t-att-href="delivery_order.get_portal_url(report_type='pdf', download=True)" title="Download"><i class="fa fa-download"/> Download</a>
                                    </div>
                                    <div class="btn-group flex-grow-1 mb-1">
                                        <a class="btn btn-secondary btn-block o_print_btn o_portal_invoice_print" t-att-href="delivery_order.get_portal_url(report_type='pdf')" id="print_invoice_report" title="Print" target="_blank"><i class="fa fa-print"/> Print</a>
                                    </div>
                                </div>
                            </li>
                            <li t-if="delivery_order.user_id" class="list-group-item flex-grow-1">
                                <div class="small mb-1"><strong class="text-muted">
                                    <t t-if="delivery_order.picking_type_code == 'outgoing'">
                                        Responsible
                                    </t>
                                </strong></div>
                                <div class="row flex-nowrap">
                                    <div class="col flex-grow-0 pr-2">
                                        <img class="rounded-circle mr4 float-left o_portal_contact_img" t-if="delivery_order.user_id.image_1024" t-att-src="image_data_uri(delivery_order.user_id.image_1024)" alt="Contact"/>
                                        <img class="rounded-circle mr4 float-left o_portal_contact_img" t-if="not delivery_order.user_id.image_1024" src="/web/static/src/img/placeholder.png" alt="Contact"/>
                                    </div>
                                    <div class="col pl-0" style="min-width: 150px">
                                        <span t-field="delivery_order.user_id" t-options='{"widget": "contact", "fields": ["name", "phone"], "no_marker": True}'/>
                                        <a href="#discussion" class="small"><i class="fa fa-comment"></i> Send message</a>
                                    </div>
                                </div>
                            </li>
                        </ul>
                    </t>
                </t>

                <!-- Page content -->
                 <div id="quote_content" class="col-12 col-lg justify-content-end">

                    <!-- modal relative to the actions sign and pay -->
                    <div role="dialog" class="modal fade" id="modalaccept">
                        <div class="modal-dialog" t-if="delivery_order.has_to_be_signed(True)">
                            <form id="accept" method="POST" t-att-data-order-id="delivery_order.id" t-att-data-token="delivery_order.access_token" class="js_accept_json modal-content js_website_submit_form">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <header class="modal-header">
                                    <h4 class="modal-title">Sign-On Delivery Order</h4>
                                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">×</button>
                                </header>
                                <main class="modal-body" id="sign-dialog">
                                    <!-- <p>
                                        <span>By signing this proposal, I agree to the following terms:</span>
                                        <ul>
                                            <li><span>Accepted on the behalf of:</span> <b t-field="sale_order.partner_id.commercial_partner_id"/></li>
                                            <li><span>For an amount of:</span> <b data-id="total_amount" t-field="sale_order.amount_total"/></li>
                                            <li t-if="sale_order.payment_term_id"><span>With payment terms:</span> <b t-field="sale_order.payment_term_id.note"/></li>
                                        </ul>
                                    </p> -->
                                    <t t-call="portal.signature_form">
                                        <t t-set="call_url" t-value="delivery_order.get_portal_url(suffix='/accept')"/>
                                        <t t-set="default_name" t-value="delivery_order.partner_id.name"/>
                                    </t>
                                </main>
                            </form>
                        </div>
                    </div>

                    <!-- status messages -->
                    <div t-if="message == 'sign_ok'" class="alert alert-success alert-dismissable d-print-none" role="status">
                        <button type="button" class="close" data-dismiss="alert" aria-label="Close">×</button>
                        <strong>Thank You!</strong><br/>
                        <t t-if="message == 'sign_ok' and delivery_order.state in ['assigned','done']">Your DO has been signed.</t>
                        <t t-else="">Your DO has been signed.</t>
                    </div>

                    <div t-if="delivery_order.state == 'cancel'" class="alert alert-danger alert-dismissable d-print-none" role="alert">
                        <button type="button" class="close" data-dismiss="alert" aria-label="close">×</button>
                        <strong>This DO has been canceled.</strong> <a role="button" href="#discussion"><i class="fa fa-comment"/> Contact us to get a new DO.</a>
                    </div>

                    <div t-if="delivery_order.is_expired" class="alert alert-warning alert-dismissable d-print-none" role="alert">
                        <button type="button" class="close" data-dismiss="alert" aria-label="close">×</button>
                        <strong>This Do expired!</strong> <a role="button" href="#discussion"><i class="fa fa-comment"/> Contact us to get a new DO.</a>
                    </div>

                    <!-- main content -->
                    <div t-attf-class="card #{'pb-5' if report_type == 'html' else ''}" id="portal_delivery_content">
                        <div t-call="metroerp_customizations.delivery_portal_content"/>
                    </div>

                    <!-- bottom actions -->
                    <div t-if="delivery_order.has_to_be_signed(True)" class="row justify-content-center text-center d-print-none pt-1 pb-4">

                        <t t-if="delivery_order.has_to_be_signed(True)">
                            <div class="col-sm-auto mt8">
                                <a role="button" class="btn btn-primary" data-toggle="modal" data-target="#modalaccept" href="#"><i class="fa fa-check"/><t t-if="delivery_order.has_to_be_signed(True)"> Accept &amp; Sign</t></a>
                            </div>
                            <div class="col-sm-auto mt8">
                                <a role="button" class="btn btn-secondary" href="#discussion"><i class="fa fa-comment"/> Feedback</a>
                            </div>
                            <!-- <div class="col-sm-auto mt8">
                                <a role="button" class="btn btn-danger" data-toggle="modal" data-target="#modaldecline" href="#"> <i class="fa fa-times"/> Reject</a>
                            </div> -->
                        </t>
                    </div>
                    <div class="text-center" style="font-size:15px; margin-top:5px; font-weight: bold; color: #555; display: flex; align-items: center; justify-content: center;">
                        <span>Powered by</span>
                        <a target="_blank" href="https://www.metrogroup.solutions/solutions/accounting-system" title="Metro Accounting System" style="color: #007bff; text-decoration: none; font-weight: bold; margin: 0 5px;">
                            Metro Accounting System
                        </a>
                    </div>
                    <!-- chatter -->
                    <div id="delivery_communication" class="mt-4">
                        <h2>History</h2>
                        <t t-call="portal.message_thread">
                            <t t-set="object" t-value="delivery_order"/>
                        </t>
                    </div>
                </div>
            </div>
        </xpath>
    </template>

    <template id="portal_delivery_error" name="Delivery error/warning display">
        <div class="row mr16">
            <div t-attf-class="'col-lg-12 mr16 ml16 alert alert-dismissable' #{'alert-danger' if error else 'alert-warning'}" role="alert">
                <a href="#" class="close" data-dismiss="alert" aria-label="close" title="close">×</a>
                <t t-if="error == 'generic'" name="generic">
                    There was an error processing this page.
                </t>
            </div>
        </div>
    </template>

    <template id="portal_delivery_success" name="Delivery success display">
        <div class="row mr16">
            <div class="col-lg-12 mr16 ml16 alert alert-dismissable alert-success" role="status">
                <a href="#" class="close" data-dismiss="alert" aria-label="close" title="close">×</a>
            </div>
        </div>
    </template>

    <template id="delivery_portal_content" name="Delivery Portal Content">
        <!-- Intro -->
        <div id="introduction" t-attf-class="pb-2 pt-3 #{'card-header bg-white' if report_type == 'html' else ''}">
            <h2 class="my-0">
                 Delivery Order
                <em t-esc="delivery_order.name"/>
            </h2>
        </div>
        <div t-attf-class="#{'card-body' if report_type == 'html' else ''}">
            <!-- Informations -->
            <div id="informations">
                <div class="row">
                    <div class="mb-3 col-12">
                        <t t-if="delivery_order.origin">
                            <strong>Order:</strong>
                            <span t-field="delivery_order.origin"/>
                        </t>
                    </div>
                </div>
                <div class="row" id="do_date">
                    <div class="mb-3 col-6">
                        <div t-if="delivery_order.state" name="div_scheduled_date">
                            <strong>Shipping Date:</strong>
                            <t t-if="delivery_order.state == 'done'">
                                <span t-field="delivery_order.date_done" t-options='{"widget": "date"}'/>
                            </t>
                            <t t-if="delivery_order.state != 'done'">
                                <span t-field="delivery_order.scheduled_date" t-options='{"widget": "date"}'/>
                           </t>
                        </div>
                    </div>
                    <div class="mb-3 col-6" t-if="delivery_order.date_deadline">
                        <strong>Expiration Date:</strong> <span t-field="delivery_order.date_deadline" t-options='{"widget": "date"}'/>
                    </div>
                </div>
                <div class="row">
                    <div class="col-lg-6">
                        <strong class="d-block mb-1">Shipping Address:</strong>
                        <address t-field="delivery_order.partner_id" t-options='{"widget": "contact", "fields": ["address", "name"], "no_marker": True}'/>
                    </div>
                </div>
            </div>
            <section id="order_details" style="page-break-inside: auto;" class="mt32">
                <h3 id="order">Order</h3>
                <div class="table-responsive">
                    <table t-att-data-order-id="delivery_order.id" t-att-data-token="delivery_order.access_token" class="table table-sm" id="delivery_order_table2" t-if="delivery_order.state!='done'">
                        <thead class="bg-100">
                            <tr>
                                <th class="text-left">Products</th>
                                <th class="text-center">Quantity</th>
                            </tr>
                        </thead>
                        <tbody class="delivery_tbody">
                            <t t-set="lines" t-value="delivery_order.move_lines.filtered(lambda x: x.product_uom_qty)"/>
                            <t t-foreach="lines" t-as="move">
                                <tr>
                                    <td class="text-left" id="product_name">
                                        <span t-field="move.product_id"/>
                                        <p t-if="move.description_picking != move.product_id.name">
                                            <span t-field="move.description_picking"/>
                                        </p>
                                    </td>
                                    <td class="text-center">
                                        <span t-field="move.product_uom_qty"/>
                                        <span t-field="move.product_uom"/>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>


                    <table t-att-data-order-id="delivery_order.id" t-att-data-token="delivery_order.access_token" class="table table-sm" id="delivery_order_table1" t-if="delivery_order.move_line_ids and delivery_order.state=='done'">
                        <t t-set="has_serial_number" t-value="False"/>
                        <t t-set="has_serial_number" t-value="delivery_order.move_line_ids.mapped('lot_id')" groups="stock.group_lot_on_delivery_slip"/>
                        <thead class="bg-100">
                            <tr>
                                <th>Products</th>
                                <t name="lot_serial" t-if="has_serial_number">
                                <th>
                                    Lot/Serial Number
                                </th>
                                </t>
                                <th class="text-center">Quantity</th>
                            </tr>
                        </thead>
                        <tbody class="delivery_tbody2">
                            <t t-if="delivery_order.has_packages" name="has_packages">
                                <t t-set="packages" t-value="delivery_order.move_line_ids.mapped('result_package_id')"/>
                                <t t-foreach="packages" t-as="package">
                                    <t t-call="metroerp_customizations.metro_stock_report_delivery_package_section_line"/>
                                    <t t-set="package_move_lines" t-value="delivery_order.move_line_ids.filtered(lambda l: l.result_package_id == package)"/>

                                    <!-- If printing lots/serial numbers => keep products in original lines -->
                                    <t t-if="has_serial_number">
                                        <tr t-foreach="package_move_lines" t-as="move_line">
                                            <t t-call="metroerp_customizations.metro_stock_report_delivery_has_serial_move_line"/>
                                        </tr>
                                    </t>

                                    <!-- If not printing lots/serial numbers => merge lines with same product+description+uom -->
                                    <t t-else="">
                                        <t t-set="aggregated_lines" t-value="package_move_lines._get_aggregated_product_quantities()"/>
                                        <t t-call="metroerp_customizations.metro_stock_report_delivery_aggregated_move_lines"/>
                                    </t>
                                </t>

                                <t t-set="move_lines" t-value="delivery_order.move_line_ids.filtered(lambda l: not l.result_package_id)"/>
                                    <t t-if="move_lines" name="no_package_move_lines">
                                        <t t-call="stock.stock_report_delivery_no_package_section_line" name="no_package_section"/>
                                        <t t-if="has_serial_number">
                                            <tr t-foreach="move_lines" t-as="move_line">
                                                <t t-call="metroerp_customizations.metro_stock_report_delivery_has_serial_move_line"/>
                                            </tr>
                                        </t>
                                        <t t-else="">
                                            <t t-set="aggregated_lines" t-value="move_lines._get_aggregated_product_quantities()"/>
                                            <t t-if="aggregated_lines">
                                            <t t-call="metroerp_customizations.metro_stock_report_delivery_aggregated_move_lines"/>
                                        </t>
                                    </t>
                                </t>
                            </t>

                            <!-- No destination packages -->
                            <t t-else="">
                                <!-- If printing lots/serial numbers => keep products in original lines -->
                                <t t-if="has_serial_number">
                                    <tr t-foreach="delivery_order.move_line_ids" t-as="move_line">
                                        <t t-call="metroerp_customizations.metro_stock_report_delivery_has_serial_move_line"/>
                                    </tr>
                                </t>
                                <!-- If not printing lots/serial numbers => merge lines with same product -->
                                <t t-else="" name="aggregated_move_lines">
                                    <t t-set="aggregated_lines" t-value="delivery_order.move_line_ids._get_aggregated_product_quantities()"/>
                                    <t t-call="metroerp_customizations.metro_stock_report_delivery_aggregated_move_lines"/>
                                </t>
                            </t>
                        </tbody>
                    </table>
                    <t t-set="backorders" t-value="delivery_order.backorder_ids.filtered(lambda x: x.state not in ('done', 'cancel'))"/>
                    <t t-if="delivery_order.backorder_ids and backorders">
                    <p>
                        <span>All items couldn't be shipped, the following items will be shipped as soon as they become available.</span>
                    </p>
                    <table class="table table-sm" name="stock_backorder_table">
                        <thead>
                            <tr>
                                <th name="th_sb_product">Product</th>
                                <th name="th_sb_quantity">Quantity</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="backorders" t-as="backorder">
                                <t t-set="bo_lines" t-value="backorder.move_lines.filtered(lambda x: x.product_uom_qty)"/>
                                <tr t-foreach="bo_lines" t-as="bo_line">
                                    <td>
                                        <span t-field="bo_line.product_id"/>
                                        <p t-if="bo_line.description_picking != bo_line.product_id.name">
                                            <span t-field="bo_line.description_picking"/>
                                        </p>
                                    </td>
                                    <td>
                                        <span t-field="bo_line.product_uom_qty"/>
                                        <span t-field="bo_line.product_uom"/>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                    </t>
                </div>
            </section>

            <section id="terms" class="mt-5" t-if="delivery_order.note">
                <h3 class="">Note</h3>
                <hr class="mt-0 mb-1"/>
                <em t-field="delivery_order.note"/>
            </section>

            <section t-if="delivery_order.signature" id="signature" name="Signature">
                <div class="row mt-4" name="signature">
                    <div t-attf-class="#{'col-3' if report_type != 'html' else 'col-sm-7 col-md-4'} ml-auto text-center">
                        <h5>Signature</h5>
                        <img t-att-src="image_data_uri(delivery_order.signature)" style="max-height: 6rem; max-width: 100%;"/>
                        <p t-field="delivery_order.partner_id.name"/>
                    </div>
                </div>
            </section>
            
        </div>
    </template>

    <template id="metro_stock_report_delivery_aggregated_move_lines">
        <tr t-foreach="aggregated_lines" t-as="line">
            <td>
                <span t-esc="aggregated_lines[line]['name']"/>
                <p t-if="aggregated_lines[line]['description']">
                    <span t-esc="aggregated_lines[line]['description']"/>
                </p>
            </td>
            <td class="text-center" name="move_line_aggregated_qty_done">
                <span t-esc="aggregated_lines[line]['qty_done']"
                    t-options="{'widget': 'float', 'decimal_precision': 'Product Unit of Measure'}"/>
                <span t-esc="aggregated_lines[line]['product_uom']"/>
            </td>
        </tr>
    </template>

     <!-- package related "section lines" -->
     <template id="metro_stock_report_delivery_package_section_line">
        <tr t-att-class="'bg-200 font-weight-bold o_line_section'">
            <td colspan="99" name="package_info">
                <span t-field="package.name"/>
            </td>
        </tr>
    </template>

    <template id="metro_stock_report_delivery_has_serial_move_line">
        <td>
            <span t-field="move_line.product_id"/>
            <!-- this is an annoying workaround for the multiple types of descriptions (often auto-filled) that we do not want to print -->
            <!-- this makes it so we can pre-filter the descriptions in inherited templates since we cannot extend the standard "if" condition -->
            <!-- let's agree that pre-filtered descriptions will be set to "" -->
            <t t-if="not description and description != ''">
                <t t-set="description" t-value="move_line.move_id.description_picking"/>
            </t>
            <p t-if="description !='' and description != move_line.product_id.name">
                <span t-esc="description"/>
            </p>
        </td>
        <t t-if="has_serial_number" name="move_line_lot">
            <td><span t-field="move_line.lot_id.name"/></td>
        </t>
        <td class="text-center" name="move_line_lot_qty_done">
            <span t-field="move_line.qty_done"/>
            <span t-field="move_line.product_uom_id"/>
        </td>
    </template>

</odoo>
