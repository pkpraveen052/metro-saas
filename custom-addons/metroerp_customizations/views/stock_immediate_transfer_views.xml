<odoo>
    <data>

        <record id="view_immediate_transfer_inherited" model="ir.ui.view">
            <field name="name">stock.immediate.transfer.view.form.inherited</field>
            <field name="model">stock.immediate.transfer</field>
            <field name="inherit_id" ref="stock.view_immediate_transfer"/>
            <field name="arch" type="xml">
                <xpath expr="//group[1]" position="replace">
                	<group>
                    	<p>You have not recorded <i>done</i> quantities yet, by clicking on <i>apply</i> ERP will process all the quantities.</p>
                	</group>
        		</xpath>
            </field>
        </record>

    </data>
</odoo>