<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        
         <record id="action_account_invoice_xls" model="ir.actions.server">
            <field name="name">Quick Export</field>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="binding_model_id" ref="account.model_account_move"/>
            <field name="binding_view_types">list</field>
            <field name="state">code</field>
            <field name="code">
                if records:
                    action = records.generate_xlsx_customized_report()
            </field>
        </record>

         <record id="inherited_account_analytic_tag_form_view" model="ir.ui.view">
            <field name="name">account.analytic.tag.inherited.form.view</field>
            <field name="model">account.analytic.tag</field>
            <field name="inherit_id" ref="analytic.account_analytic_tag_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='company_id']" position="attributes">
                    <attribute name="required">True</attribute>
                </xpath>
            </field>
        </record>

        <record id="inherited_account_move_form_view" model="ir.ui.view">
            <field name="name">account.move.inherited.form.view</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='auto_post']" position="after">
                    <field name="hide_post_button" invisible="1"/>
                </xpath>
                <xpath expr="//field[@name='invoice_incoterm_id']" position="attributes">
                    <attribute name="options">{'no_open': True}</attribute>
                </xpath>
                <xpath expr="//field[@name='invoice_cash_rounding_id']" position="attributes">
                    <attribute name="domain">[('company_id', '=', company_id)]</attribute>
                </xpath>
                <xpath expr="//field[@name='partner_bank_id'][1]" position="attributes">
                    <attribute name="options">{'no_create': True, 'no_open': True}</attribute>
                </xpath>
                <xpath expr="//group[@id='other_tab_group']/group/field[@name='partner_bank_id']" position="attributes">
                    <attribute name="options">{'no_create': True, 'no_open': True}</attribute>
                </xpath>
                <xpath expr="//field[@name='line_ids']/tree/field[@name='partner_id']" position="attributes">
                    <attribute name="domain">['|', ('parent_id', '=', False), ('is_company', '=', True),('company_id', '=', company_id)]</attribute>
                </xpath>
        
                <!-- Alert for Auto Post (modified) -->
                <xpath expr="//form//div[contains(@class, 'alert-info') and .//field[@name='date']]"
                    position="attributes">
                    <attribute name="attrs">
                        {'invisible': ['|', ('state', '!=', 'draft'), ('auto_post', '!=', 'at_date')]}
                    </attribute>
                </xpath>
            </field>
        </record>

        <record id="inherited_account_setup_bank_manual_config__wizard_form_view" model="ir.ui.view">
            <field name="name">account.setup.bank.manual.config.wizard.form.view</field>
            <field name="model">account.setup.bank.manual.config</field>
            <field name="inherit_id" ref="account.setup_bank_account_wizard"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='bank_id']" position="attributes">
                    <attribute name="options">{'no_create': True, 'no_open': True}</attribute>
                </xpath>
            </field>
        </record>

        <record id="view_move_line_tree_grouped_inherited_custom" model="ir.ui.view">
            <field name="name">account.move.line.tree.grouped.inherited</field>
            <field name="model">account.move.line</field>
            <field name="inherit_id" ref="account.view_move_line_tree_grouped"/>
            <field name="arch" type="xml">
                <!-- Add custom tax amount field -->
                <xpath expr="//field[@name='amount_currency']" position="after">
                            <field name="tax_amount_custom"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
