<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Product Template -->
    <record id="product_template_form_view_inherit" model="ir.ui.view">
        <field name="name">Product Template form</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//form//field[@name='company_id']" position="attributes">
                <attribute name="required">1</attribute>
	        </xpath>
            <xpath expr="//page[@name='purchase']" position="attributes">
                <attribute name="groups">purchase.group_purchase_user,purchase.group_purchase_manager</attribute>
            </xpath>
            <xpath expr="//div[@name='standard_price_uom']" position="attributes">
                <attribute name="groups">!metroerp_customizations.group_hide_cost_price</attribute>
            </xpath>
        </field>
    </record>


    <record id="product_template_form_view_procurement_button_inherit" model="ir.ui.view">
        <field name="name">product.template_procurement Inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="stock.product_template_form_view_procurement_button"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='responsible_id']" position="attributes">
                <attribute name="domain">[('company_id', '=', company_id)]</attribute>
            </xpath>
        </field>
    </record>

		<!-- Product Template Inherited Form View -->
		<record id="view_product_template_tags_inherit" model="ir.ui.view">
            <field name="name">product.template.tags</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_only_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='company_id']" position="after">
                    	<field name="tag_id" widget="many2many_tags" options="{'color_field': 'color'}" placeholder="Select Tags..." domain="['|',('company_id', '=', False), ('company_id', '=', company_id)]"
						attrs="{'invisible': [('product_variant_count', '>', 1)]}"/>
                </xpath>
                <!--Hide Product Cost Price-->
                <xpath expr="//label[@for='standard_price']" position="attributes">
                    <attribute name="groups">!metroerp_customizations.group_hide_cost_price</attribute>
                 </xpath>
                 <xpath expr="//field[@name='standard_price']" position="attributes">
                    <attribute name="groups">!metroerp_customizations.group_hide_cost_price</attribute>
                 </xpath>
            </field>
        </record>

        <!-- Product Template Inherited Tree View -->
        <record id="view_product_template_tree_tags_inherit" model="ir.ui.view">
            <field name="name">product.template.tags.tree</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_tree_view"/>
            <field name="arch" type="xml">
				<xpath expr="//field[@name='categ_id']" position="before">
				    <field name="tag_id" optional="hide" widget="many2many_tags" options="{'color_field': 'color'}"/>
				</xpath>
                <xpath expr="//field[@name='standard_price']" position="attributes">
                    <attribute name="groups">!metroerp_customizations.group_hide_cost_price</attribute>
                 </xpath>
            </field>
        </record>


        <record id="product_template_kanban_view" model="ir.ui.view">
            <field name="name">product.template.kanban.inherit</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_kanban_view"/>
            <field name="arch" type="xml">
                <xpath expr="//div[hasclass('oe_kanban_details')]" position="after">
                    <div>
                        <span class="oe_kanban_list_many2many">
                            <field name="tag_id" widget="many2many_tags" options="{'color_field': 'color'}"/>
                        </span>
                    </div>
                </xpath>
            </field>
        </record>

        <record id="product_template_search_view" model="ir.ui.view">
            <field name="name">product.template.search.view.inherit</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_search_view"/>
            <field name="arch" type="xml">
                <xpath expr="//search" position="inside">
                    <field name="tag_id" string="Product Tag" filter_domain="[('tag_id.name', 'ilike', self)]"/>
                </xpath>
            </field>
        </record>

            <!-- Product Product Inherited Form View -->
		<record id="view_product_product_tags_inherit" model="ir.ui.view">
            <field name="name">product.product.tags</field>
            <field name="model">product.product</field>
            <field name="inherit_id" ref="product.product_normal_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='company_id']" position="after">
                    	<field name="tag_id" widget="many2many_tags" options="{'color_field': 'color'}" placeholder="Select Tags..." domain="['|',('company_id', '=', False), ('company_id', '=', company_id)]"/>
                </xpath>
                <!--Hide Product Cost Price-->
                <xpath expr="//label[@for='standard_price']" position="attributes">
                    <attribute name="groups">!metroerp_customizations.group_hide_cost_price</attribute>
                </xpath>
                <xpath expr="//field[@name='standard_price']" position="attributes">
                    <attribute name="groups">!metroerp_customizations.group_hide_cost_price</attribute>
                </xpath>
            </field>
        </record>

              <!-- Product Product Inherited Tree View -->
        <record id="view_product_product_tree_tags_inherit" model="ir.ui.view">
            <field name="name">product.product.tags.tree</field>
            <field name="model">product.product</field>
            <field name="inherit_id" ref="product.product_product_tree_view"/>
            <field name="arch" type="xml">
				<xpath expr="//field[@name='categ_id']" position="before">
				    <field name="tag_id" optional="hide" widget="many2many_tags" options="{'color_field': 'color'}"/>
				</xpath>
                <xpath expr="//field[@name='standard_price']" position="attributes">
                    <attribute name="groups">!metroerp_customizations.group_hide_cost_price</attribute>
                </xpath>
            </field>
        </record>

         <!-- Product Product Inherited Kanban View -->
        <record id="product_product_kanban_view" model="ir.ui.view">
            <field name="name">product.product.kanban.inherit</field>
            <field name="model">product.product</field>
            <field name="inherit_id" ref="product.product_kanban_view"/>
            <field name="arch" type="xml">
                <xpath expr="//div[hasclass('oe_kanban_details')]" position="after">
                    <div>
                        <span class="oe_kanban_list_many2many">
                            <field name="tag_id" widget="many2many_tags" options="{'color_field': 'color'}"/>
                        </span>
                    </div>
                </xpath>
            </field>
        </record>

        <record id="product_variant_easy_edit_view_inherit" model="ir.ui.view">
            <field name="name">product.variant.easy.edit.inherit</field>
            <field name="model">product.product</field>
            <field name="inherit_id" ref="product.product_variant_easy_edit_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='barcode']" position="after">
                    <field name="tag_id" widget="many2many_tags" options="{'color_field': 'color'}"/>
                </xpath>
            </field>
        </record>
</odoo>
