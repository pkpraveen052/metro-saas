<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="stock_picking_inherited_form_view" model="ir.ui.view">
            <field name="name">stock.picking.form.view</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.view_picking_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form//field[@name='priority']" position="after">
                    <field name="sale_id" invisible="1"/>
                </xpath>
                <xpath expr="//header/button[@name='action_cancel']" position="after">
                    <button name="action_send_mail" string="Send Mail" type="object"
                    attrs="{'invisible': ([('sale_id', '=', False)])}"/>
                </xpath>
                <xpath expr="//page[@name='extra']//field[@name='user_id']" position="attributes">
                    <attribute name="domain">[('share', '=', False), ('company_id', '=', company_id)]</attribute>
                </xpath>
                <xpath expr="//page[@name='extra']" position="after">
                    <page string="Customer Signature" name="customer_signature" attrs="{'invisible': ['|', ('require_signature', '=', False), ('picking_type_code', '!=', 'outgoing'),'&amp;', ('signed_by', '=', False), ('signature', '=', False), ('signed_on', '=', False)]}">
                        <group>
                            <field name="signed_by"/>
                            <field name="signed_on"/>
                            <field name="signature" widget="image"/>
                        </group>
                    </page>
                </xpath>
                <xpath expr="//group[@name='other_infos']/field[@name='picking_type_code']" position="before">
                    <field name="so_reference"/>
                    <field name="require_signature" attrs="{'invisible': [('picking_type_code','!=','outgoing')]}"/>
                </xpath>
                <xpath expr="//button[@name='action_view_stock_valuation_layers']" position="after">
                    <button name="preview_delivery"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-globe icon"
                            attrs="{'invisible': ['|',('picking_type_code','!=','outgoing'),('require_signature', '=', False)]}">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">Customer</span>
                                <span class="o_stat_text">Preview</span>
                            </div>
                            
                    </button>
                </xpath>
                <xpath expr="//field[@name='move_ids_without_package']/tree/field[@name='description_picking']" position="replace">
                    <field name="description_picking" string="Description"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
