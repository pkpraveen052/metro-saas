<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <record id="inherited_view_account_payment_form" model="ir.ui.view">
            <field name="name">account.payment.form.inherit</field>
            <field name="model">account.payment</field>
            <field name="inherit_id" ref="account.view_account_payment_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='partner_bank_id']" position="attributes">
                    <attribute name="options">{'no_create': True, 'no_open': True}</attribute>
	            </xpath>
                <xpath expr="//field[@name='partner_id']" position="attributes">
                    <attribute name="domain">[('company_id', '=', company_id)]</attribute>
                </xpath>
            </field>
        </record>

	<record id="account_payment_search_view" model="ir.ui.view">
            <field name="name">account.payment.search.view.inherit</field>
            <field name="model">account.payment</field>
            <field name="inherit_id" ref="account.view_account_payment_search"/>
            <field name="arch" type="xml">
                    <!-- Modify the partner_id field label -->
                    <xpath expr="//field[@name='partner_id']" position="attributes">
                        <attribute name="string">Payer/Payee</attribute>
                    </xpath>
                    <!-- Modify the Customer Payments filter label -->
                    <xpath expr="//filter[@name='inbound_filter']" position="attributes">
                        <attribute name="string">Payer Payments</attribute>
                    </xpath>
                    <!-- Modify the Vendor Payments filter label -->
                    <xpath expr="//filter[@name='outbound_filter']" position="attributes">
                        <attribute name="string">Payee Payments</attribute>
                    </xpath>
                    <!-- Modify the group by Customer/Vendor filter label -->
                    <xpath expr="//filter[@name='partner']" position="attributes">
                        <attribute name="string">Payer/Payee</attribute>
                    </xpath>
            </field>
        </record>

    </data>
</odoo>
