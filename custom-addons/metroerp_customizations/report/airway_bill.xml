<!--        </div>-->
    </template>

    <template id="report_airwaybill">
        <t t-foreach="docs" t-as="o">
            <t t-call="metroerp_customizations.report_airway_document" t-lang="o.partner_id.lang"/>
        </t>
    </template>

    <record id="paperformat_airway_bill" model="report.paperformat">
        <field name="name">Point of Sale receipt</field>
        <field name="default" eval="False" />
        <field name="format">custom</field>
        <field name="page_height">150</field>
        <field name="page_width">60</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">4</field>
        <field name="margin_bottom">4</field>
        <field name="margin_left">3</field>
        <field name="margin_right">3</field>
        <field name="header_line" eval="False" />
        <field name="header_spacing">30</field>
        <field name="dpi">130</field>
    </record>

    <record id="report_event_airway_bill" model="ir.actions.report">
        <field name="name">Airway Bill</field>
        <field name="model">stock.picking</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">metroerp_customizations.report_airwaybill</field>
        <field name="report_file">metroerp_customizations.report_airwaybill</field>
        <field name="print_report_name">'Airway Bill - %s - %s' % (object.partner_id.name or '', object.name)</field>
        <field name="paperformat_id" ref="metroerp_customizations.paperformat_airway_bill"/>
    </record>

</odoo>