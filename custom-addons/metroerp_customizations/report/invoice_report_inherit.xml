<?xml version="1.0" encoding="utf-8"?>
<odoo>
<!--    Calling new custom header for the Invoice report -->
    <template id="report_invoice_inherit_document">
        <t t-set="o" t-value="o.with_context(lang=o.partner_id.lang)" />
        <t t-call="metroerp_customizations.custom_external_invoice_layout">
            <div class="page" style="font-family: 'Open Sans', Arial, sans-serif; font-size:10.0pt;">
                <div class="oe_structure"/>
                <div class="row">
                    <div class="col-6 text-left">
                        <div>
                            <b>
                                <span t-if="o.partner_id.company_type == 'company'" style="font-size:13.0pt;" t-field="o.partner_id.name"/>
                                <t t-if="o.partner_id.company_type == 'person'">
                                    <t t-if="o.partner_id.parent_id.name"><span style="font-size:13.0pt;" t-field="o.partner_id.parent_id.name"/></t>
                                    <t t-else=""><span style="font-size:13.0pt;" t-field="o.partner_id.name"/></t>
                                </t>
                            </b>
                        </div>
                        <div>
                            Attn: <span t-if="o.partner_id.company_type == 'person' and o.partner_id.parent_id" t-field="o.partner_id.name"/>
                        </div>
                        <div>
                            Address:
                            <t t-if="o.partner_id.street">
                                <span t-field="o.partner_id.street"/>,
                            </t>
                            <t t-if="o.partner_id.street2">
                                <span t-field="o.partner_id.street2"/>,
                            </t>
                            <t t-if="o.partner_id.street or o.partner_id.street2">
                                <br/>
                            </t>
                            <t t-if="o.partner_id.city">
                                <span t-field="o.partner_id.city"/>,
                            </t>
                            <t t-if="o.partner_id.state_id">
                                <span t-field="o.partner_id.state_id.name"/>,
                            </t>
                            <t t-if="o.partner_id.zip">
                                <span t-field="o.partner_id.zip"/>,
                            </t>
                            <t t-if="o.partner_id.country_id">
                                <span t-field="o.partner_id.country_id.name"/>
                            </t>
                        </div>
                        <div t-if="o.partner_id.phone">
                            Phone: <span t-field="o.partner_id.phone"/>
                        </div>
                        <div t-if="o.partner_id.email">
                            Email: <span t-field="o.partner_id.email"/>
                        </div>
                    </div>
                    <div class="col-1"/>
                    <div class="col-5 text-left" id="informations" style="margin-top:-2px;">
                        <div>
                            <strong>
                                <span t-if="o.move_type == 'out_invoice' and o.state == 'posted'" style="font-size: 13.0pt;color: #495057;">INVOICE</span>
                                <span t-if="o.move_type == 'out_invoice' and o.state == 'draft'" style="font-size: 13.0pt;color: #495057;">DRAFT INVOICE</span>
                                <span t-if="o.move_type == 'out_invoice' and o.state == 'cancel'" style="font-size: 13.0pt;color: #495057;">CANCELLED INVOICE</span>
                                <span t-if="o.move_type == 'out_refund'" style="font-size: 13.0pt;color: #495057;">CREDIT NOTE</span>
                                <span t-if="o.move_type == 'in_refund'" style="font-size: 13.0pt;color: #495057;">VENDOR CREDIT NOTE</span>
                                <span t-if="o.move_type == 'in_invoice'" style="font-size: 13.0pt;color: #495057;">VENDOR BILL</span>
                                <span style="font-size: 13.0pt;color: #495057;"># <span t-field="o.name" style="font-size: 13.0pt;color: #495057;"/></span>
                            </strong>
                        </div>
                        <div>
                            <div t-if="o.invoice_date">
                                <strong style="color: #495057;">Invoice Date: <span t-field="o.invoice_date" t-options="{&quot;widget&quot;: &quot;date&quot;}"/></strong>
                            </div>
                            <div t-if="o.invoice_date_due">
                                <strong style="color: #495057;">Due Date: <span t-field="o.invoice_date_due" t-options="{&quot;widget&quot;: &quot;date&quot;}"/></strong>
                            </div>
                            <div t-if="o.invoice_origin">
                                <strong style="color: #495057;">Reference: <span t-field="o.invoice_origin"/></strong>
                            </div>
                            <div t-if="o.invoice_payment_term_id" name="payment_term">
                                <strong style="color: #495057;">Payment Terms: <span t-field="o.invoice_payment_term_id.name"/></strong>
                            </div>
                        </div>
                    </div>
                </div>
                <br/>
                <!-- Is there a discount on at least one line? -->
                <t t-set="display_discount" t-value="any(l.discount for l in o.invoice_line_ids)"/>
                <table class="table table-sm o_main_table" name="invoice_line_table" style="table-layout:fixed">
                    <t t-if="not display_discount">
                        <col width="10%"/>
                        <col width="45%"/>
                        <col width="10%"/>
                        <col width="10%"/>
                        <col width="10%"/>
                        <col width="15.5%"/>
                        <t t-set="total_style" t-value="'page-break-inside: avoid;table-layout:fixed;margin-right: 0;margin-left: auto;width:35%;'"/>
                    </t>
                    <t t-if="display_discount">
                        <col width="10%"/>
                        <col width="35%"/>
                        <col width="10%"/>
                        <col width="10%"/>
                        <col width="10%"/>
                        <col width="10%"/>
                        <col width="15.5%"/>
                        <t t-set="total_style" t-value="'page-break-inside: avoid;table-layout:fixed;margin-right: 0;margin-left: auto;width:45%;'"/>
                    </t>
                    <thead>
                        <tr>
                            <th name="th_item" class="text-center" style="vertical-align: middle;">Item</th>
                            <th name="th_description" class="text-center" style="vertical-align: middle;"><span>Description</span></th>
                            <th name="th_quantity" class="text-center" style="vertical-align: middle;"><span>Quantity</span></th>
                            <th name="th_priceunit" t-attf-class="text-center {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}" style="vertical-align: middle;"><span>Price</span></th>
                            <th name="th_price_unit" t-if="display_discount" t-attf-class="text-center {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}" style="vertical-align: middle;">
                                <span>Disc.%</span>
                            </th>
                            <th name="th_taxes" t-attf-class="text-center {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}" style="vertical-align: middle;"><span>Taxes</span></th>
                            <th name="th_subtotal" class="text-center" style="vertical-align: middle;">
                                <span groups="account.group_show_line_subtotals_tax_excluded">Amount</span>
                                <span groups="account.group_show_line_subtotals_tax_included">Total</span>
                            </th>
                        </tr>
                    </thead>
                    <t t-set="item_num" t-value="0"/>
                    <tbody class="invoice_tbody">
                        <t t-set="current_subtotal" t-value="0"/>
                        <t t-set="lines" t-value="o.invoice_line_ids.sorted(key=lambda l: (-l.sequence, l.date, l.move_name, -l.id), reverse=True)"/>
                        <t t-foreach="lines" t-as="line">
                            <t t-set="current_subtotal" t-value="current_subtotal + line.price_subtotal" groups="account.group_show_line_subtotals_tax_excluded"/>
                            <t t-set="current_subtotal" t-value="current_subtotal + line.price_total" groups="account.group_show_line_subtotals_tax_included"/>

                            <tr t-att-class="'bg-200 font-weight-bold o_line_section' if line.display_type == 'line_section' else 'font-italic o_line_note' if line.display_type == 'line_note' else ''">
                                <t t-if="not line.display_type" name="account_invoice_line_accountable">
                                    <t t-set="item_num" t-value="item_num+1"/>
                                    <td name="td_item" class="text-center"><span t-esc="item_num"/></td>
                                    <td name="account_invoice_line_name">
                                        <span style="font-weight:bold;font-size:11.0pt;" t-field="line.product_id.name"/><br/>
                                        <span t-field="line.name" t-options="{'widget': 'text'}"/>
                                    </td>
                                    <td name="td_quantity" class="text-center">
                                        <span t-field="line.quantity"/>
                                        <span t-field="line.product_uom_id"/>
                                    </td>
                                    <td t-attf-class="text-center {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                                        <span class="text-nowrap" t-field="line.price_unit"/>
                                    </td>
                                    <td t-if="display_discount" t-attf-class="text-center {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                                        <span class="text-nowrap" t-field="line.discount"/>
                                    </td>
                                    <td t-attf-class="text-center {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                                        <span t-esc="', '.join(map(lambda x: (x.description or x.name), line.tax_ids))" id="line_tax_ids"/>
                                    </td>
                                    <td class="text-center o_price_total" name="td_price_total">
                                        <span class="text-nowrap" t-field="line.price_subtotal" groups="account.group_show_line_subtotals_tax_excluded"/>
                                        <span class="text-nowrap" t-field="line.price_total" groups="account.group_show_line_subtotals_tax_included"/>
                                    </td>
                                </t>
                                <t t-if="line.display_type == 'line_section'">
                                    <td colspan="99">
                                        <span t-field="line.name" t-options="{'widget': 'text'}"/>
                                    </td>
                                    <t t-set="current_section" t-value="line"/>
                                    <t t-set="current_subtotal" t-value="0"/>
                                </t>
                                <t t-if="line.display_type == 'line_note'">
                                    <td colspan="99">
                                        <span t-field="line.name" t-options="{'widget': 'text'}"/>
                                    </td>
                                </t>
                            </tr>
                            <t t-if="current_section and (line_last or lines[line_index+1].display_type == 'line_section')">
                                <tr class="is-subtotal text-right">
                                    <td colspan="99">
                                        <strong class="mr16">Subtotal</strong>
                                        <span t-esc="current_subtotal" t-options="{&quot;widget&quot;: &quot;monetary&quot;, &quot;display_currency&quot;: o.currency_id}"/>
                                    </td>
                                </tr>
                            </t>
                        </t>
                    </tbody>
                </table>

                <div class="clearfix">
                    <div id="total" name="main_total">
                        <table class="table table-sm" t-att-style="total_style">
                            <tr class="border-black o_subtotal" style="border:1px solid black;" name="o_subtotal">
                                <td style="border:1px solid black;"><strong>Subtotal</strong></td>
                                <td style="border:1px solid black;" class="text-right">
                                    <span t-field="o.amount_untaxed"/>
                                </td>
                            </tr>
                            <t t-foreach="o.amount_by_group" t-as="amount_by_group">
                                <tr style="">
                                    <t t-if="len(o.line_ids.filtered(lambda line: line.tax_line_id)) in [0, 1] and o.amount_untaxed == amount_by_group[2]">
                                        <td style="background-color: white;color: black;"><strong class="text-nowrap" t-esc="amount_by_group[0]"/></td>
                                        <td style="background-color: white;color: black;" class="text-right o_price_total">
                                            <span t-esc="amount_by_group[3]"/>
                                        </td>
                                    </t>
                                    <t t-else="">
                                        <td style="background: white;color: black;">
                                            <strong>
                                                <span t-esc="amount_by_group[0]"/>
                                                <span class="text-nowrap"> on
                                                    <t t-esc="amount_by_group[4]"/>
                                                </span>
                                            </strong>
                                        </td>
                                        <td style="background: white;color: black;" class="text-right o_price_total">
                                            <span t-esc="amount_by_group[3]"/>
                                        </td>
                                    </t>
                                </tr>
                            </t>
                            <tr class="border-black o_total">
                                <td style="border-right: 1px solid rgb(73, 80, 87);background: white;"><strong style="color: black;">Total</strong></td>
                                <td class="text-right" style="background-color: white;color: black;">
                                    <span class="text-nowrap" t-field="o.amount_total"/>
                                </td>
                            </tr>
                            <t t-if="print_with_payments">
                                <t t-if="o.payment_state != 'invoicing_legacy'">
                                    <t t-set="payments_vals" t-value="o.sudo()._get_reconciled_info_JSON_values()"/>
                                        <t t-foreach="payments_vals" t-as="payment_vals">
                                            <tr>
                                                <td>
                                                    <i class="oe_form_field text-right oe_payment_label">Paid on <t t-esc="payment_vals['date']" t-options="{&quot;widget&quot;: &quot;date&quot;}"/></i>
                                                </td>
                                                <td class="text-right">
                                                    <span t-esc="payment_vals['amount']" t-options="{&quot;widget&quot;: &quot;monetary&quot;, &quot;display_currency&quot;: o.currency_id}"/>
                                                </td>
                                            </tr>
                                        </t>
                                        <t t-if="len(payments_vals) &gt; 0">
                                            <tr class="border-black">
                                                <td style="background: white;border:1px solid black;"><strong style="color: black;">Amount Due</strong></td>
                                                <td class="text-right" style="background-color: white;color: black;border:1px solid black;">
                                                    <span t-field="o.amount_residual"/>
                                                </td>
                                            </tr>
                                        </t>
                                </t>
                            </t>
                        </table>
                    </div>
                </div>

                <div class="oe_structure"/>

                <t t-if="o.narration">
                    <strong style="color: black;">TERMS AND CONDITIONS:</strong>
                    <div>
                        <span t-field="o.narration"/>
                    </div>
                </t>
                <br/>
                <p t-if="o.move_type in ('out_invoice', 'in_refund') and o.payment_reference" name="payment_communication">
                    <span>Please use the following communication for your payment: <b><span t-field="o.payment_reference"/></b></span>
                </p>
                <p t-if="o.fiscal_position_id.note" name="note">
                    <span t-field="o.fiscal_position_id.note"/>
                </p>
                <p t-if="o.invoice_incoterm_id" name="incoterm">
                    <span><strong style="color: black;">Incoterm: </strong><span t-field="o.invoice_incoterm_id.code"/> - <span t-field="o.invoice_incoterm_id.name"/></span>
                </p>
                <div id="qrcode" t-if="o.display_qr_code">
                    <p t-if="qr_code_urls.get(o.id)">
                        <strong class="text-center">Scan me with your banking app.</strong><br/><br/>
                        <img class="border border-dark rounded" t-att-src="qr_code_urls[o.id]"/>
                    </p>
                </div>
            </div>
        </t>
    </template>

    <template id="custom_external_invoice_layout">
        <!-- Multicompany -->
        <t t-if="not o and doc">
            <t t-set="o" t-value="doc"/>
        </t>
        <t t-if="o and 'company_id' in o">
            <t t-set="company" t-value="o.company_id"/>
        </t>
        <t t-if="not o or not 'company_id' in o">
            <t t-set="company" t-value="res_company"/>
        </t>
       <t t-call="metroerp_customizations.custom_external_invoice_layout_standard">
           <t t-raw="0"/>
       </t>
    </template>

    <template id="custom_external_invoice_layout_standard">
        <div class="header">
            <div class="o_boxed_header" style="font-family: sans-serif;color: #495057;font-size:10.0pt;">
                <div class="row">
                    <div class="col-6 text-left" style="display: flex;justify-content: flex-start;align-items: center;">
                        <img style="max-width: 100%;" t-if="o.company_id.logo" t-att-src="image_data_uri(o.company_id.logo)" alt="Logo"/>
                    </div>
                    <div class="col-1"/>
                    <div class="col-6 text-left">
                        <table>
                            <tr>
                                <div>
                                    <b><span style="font-size: 125%;color:black;" t-field="o.company_id.name"/></b><br/>
                                </div>
                                <div>
                                    <t t-if="o.company_id.street">
                                        <span t-field="o.company_id.street"/>,
                                    </t>
                                    <t t-if="o.company_id.street2">
                                        <span t-field="o.company_id.street2"/>,
                                    </t>
                                </div>
                                <div>
                                    <t t-if="o.company_id.city">
                                        <span t-field="o.company_id.city"/>
                                    </t>
                                    <t t-if="o.company_id.state_id.name">
                                        <span t-field="o.company_id.state_id.name"/>
                                    </t>
                                    <t t-if="o.company_id.zip">
                                        <span t-field="o.company_id.zip"/>
                                    </t>
                                    <t t-if="o.company_id.country_id">
                                        <span>
                                            <t t-esc="o.company_id.country_id.name"/><br/>
                                        </span>
                                    </t>
                                </div>
                            </tr>
                            <tr>
                                <t t-if="o.company_id.vat">
                                    <td>GST Reg No: <span t-field="o.company_id.vat"/>,
                                        <span t-if="o.company_id.l10n_sg_unique_entity_number" style="display: inline-block;">
                                            UEN: <span t-field="o.company_id.l10n_sg_unique_entity_number"/>
                                        </span>
                                        <span t-if="not o.company_id.l10n_sg_unique_entity_number and o.company_id.company_registry" style="display: inline-block;">
                                            UEN: <span t-field="o.company_id.company_registry"/>
                                        </span>
                                    </td>
                                </t>
<!--                                <t t-if="o.company_id.l10n_sg_unique_entity_number">-->
<!--                                    <td>UEN: <span t-field="o.company_id.l10n_sg_unique_entity_number"/>,-->
<!--                                        <span t-if="o.company_id.vat" style="display: inline-block;">-->
<!--                                            GST Reg No:-->
<!--                                        </span>-->
<!--                                        <span t-field="o.company_id.vat"/>-->
<!--                                    </td>-->
<!--                                </t>-->
<!--                                <t t-if="not o.company_id.l10n_sg_unique_entity_number and o.company_id.company_registry">-->
<!--                                    <td>UEN: <span t-field="o.company_id.company_registry"/>,-->
<!--                                        <span t-if="o.company_id.vat" style="display: inline-block;">-->
<!--                                            GST Reg No:-->
<!--                                        </span>-->
<!--                                        <span t-field="o.company_id.vat"/>-->
<!--                                    </td>-->
<!--                                </t>-->
                            </tr>
                            <tr>
                                <t t-if="o.company_id.phone or o.company_id.email">
                                    <td>
                                       <span t-if="o.company_id.phone">Phone: <span t-field="o.company_id.phone"/>, </span>
                                       <span t-if="o.company_id.email" style="display: inline-block;">Email: <span t-field="o.company_id.email"/></span>
                                    </td>
                                </t>
                            </tr>
                        </table>
                        <br/>
                    </div>
                </div>
            </div>
        </div>
        <div class="article o_report_layout_boxed" t-att-data-oe-model="o and o._name" t-att-data-oe-id="o and o.id" t-att-data-oe-lang="o and o.env.context.get('lang')">
            <t t-call="web.address_layout"/>
            <t t-raw="0"/>
        </div>
        <div t-attf-class="footer o_boxed_footer o_company_#{company.id}_layout">
            <div class="text-center">
                <div t-if="report_type == 'pdf'">
                    Page: <span class="page"/> / <span class="topage"/>
                </div>
            </div>
        </div>
    </template>

    <template id="account.report_invoice">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-set="lang" t-value="o.invoice_user_id.sudo().lang if o.move_type in ('in_invoice', 'in_refund') else o.partner_id.lang"/>
                <t t-if="o._get_name_invoice_report() == 'metroerp_customizations.report_invoice_inherit_document'"
                    t-call="metroerp_customizations.report_invoice_inherit_document" t-lang="lang"/>
            </t>
        </t>
    </template>

    <template id="account.report_invoice_with_payments">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-set="lang" t-value="o.invoice_user_id.sudo().lang if o.move_type in ('in_invoice', 'in_refund') else o.partner_id.lang"/>
                <t t-set="print_with_payments" t-value="True"/>
                <t t-if="o._get_name_invoice_report() == 'metroerp_customizations.report_invoice_inherit_document'"
                    t-call="metroerp_customizations.report_invoice_inherit_document" t-lang="lang"/>
            </t>
        </t>
    </template>

<!--    Overridden-->
    <record id="account.account_invoices" model="ir.actions.report">
        <field name="name">Invoices</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">account.report_invoice_with_payments</field>
        <field name="report_file">account.report_invoice_with_payments</field>
        <field name="print_report_name">(object._get_report_base_filename())</field>
        <field name="attachment">(object.state == 'posted') and ((object.name or 'INV').replace('/','_')+'.pdf')</field>
        <field name="binding_model_id" ref="model_account_move"/>
        <field name="binding_type">report</field>
        <field name="groups_id" eval="[(4, ref('account.group_account_invoice')),
(4, ref('account.group_account_readonly'))]"/>
        <field name="paperformat_id" ref="paperformat_sale_invoice"/>
    </record>

<!--    Overridden-->
    <record id="account.account_invoices_without_payment" model="ir.actions.report">
        <field name="name">Invoices without Payment</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">account.report_invoice</field>
        <field name="report_file">account.report_invoice</field>
        <field name="print_report_name">(object._get_report_base_filename())</field>
        <field name="attachment">(object.state == 'posted') and ((object.name or 'INV').replace('/','_')+'.pdf')</field>
        <field name="binding_model_id" ref="model_account_move"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="paperformat_sale_invoice"/>
    </record>

</odoo>