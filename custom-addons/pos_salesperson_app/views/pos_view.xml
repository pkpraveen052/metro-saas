<?xml version="1.0"?>
<odoo>
	
	<template id="assets" inherit_id="point_of_sale.assets">
		<xpath expr="." position="inside">
			<script type="text/javascript" src="/pos_salesperson_app/static/src/js/pos.js"/>
			<link rel="stylesheet" href="/pos_salesperson_app/static/src/css/custom.css"/>
		</xpath>
	</template>

	<record id="inherit_orderline_salesperson_pos_config_form" model="ir.ui.view">
		<field name="name">inherit_orderline_salesperson_pos_config_form</field>
		<field name="model">pos.config</field>
		<field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
		<field name="arch" type="xml">
			<xpath expr="//div[4]" position="after">
				<br/>
				<h2>SalesPerson</h2>
				<div class="row mt16 o_settings_container" id="session_config">
					<div class="col-xs-12 col-md-6 o_setting_box">
						<div class="o_setting_left_pane">
							<field name="enable_salesperson"/>
						</div>
						<div class="o_setting_right_pane">
							<label for="enable_salesperson"/>
							<div class="text-muted">
								Salesperson on Orderline
							</div>
						</div>
					</div>	
				</div>
			</xpath>
		</field>
	</record>

	<record model="ir.ui.view" id="pos_order_inherit">
		<field name="name">pos.order.view.form</field>
		<field name="model">pos.order</field>
		<field name="inherit_id" ref="point_of_sale.view_pos_pos_form"/>
		<field name="arch" type="xml">
			<xpath expr="//field[@name='lines']/tree/field[@name='qty']" position="after">
				<field name="sales_person_id"/>
			</xpath>
		</field>
	</record>

	<record model="ir.ui.view" id="pos_order_pivot_inherit">
		<field name="name">pos.order.view.form</field>
		<field name="model">report.pos.order</field>
		<field name="inherit_id" ref="point_of_sale.view_report_pos_order_pivot"/>
		<field name="arch" type="xml">
			<xpath expr="//field[@name='order_id']" position="after">
				<field name="sales_person_id"/>
			</xpath>
		</field>
	</record>
</odoo>
