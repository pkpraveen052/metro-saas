<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="base.module_category_security_management_security" model="ir.module.category">
            <field name="name">Security</field>
            <field name="description">Manages all security-related operations, including visitor tracking, access control, and gate management within the system</field>
            <field name="sequence">51</field>
        </record>
    
        <record id="metro_security_management_group_user" model="res.groups">
            <field name="name">User</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="category_id" ref="base.module_category_security_management_security"/>
        </record>
    
        <record id="metro_security_management_group_manager" model="res.groups">
            <field name="name">Administrator</field>
            <field name="category_id" ref="base.module_category_security_management_security"/>
            <field name="implied_ids" eval="[(4, ref('metro_security_management_group_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>
    
        <record id="base.default_user" model="res.users">
            <field name="groups_id" eval="[(4, ref('metro_security_management.metro_security_management_group_user'))]"/>
        </record>
    
    </data>
</odoo>
