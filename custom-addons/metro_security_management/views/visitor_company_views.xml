<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="visitor_company_tree_view" model="ir.ui.view">
            <field name="name">visitor.company.list.view</field>
            <field name="model">visitor.company</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="phone"/>
                    <field name="address"/>
                </tree>
            </field>
        </record>

        <record id="visitor_company_form_view" model="ir.ui.view">
            <field name="name">visitor.company.form.view</field>
            <field name="model">visitor.company</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name" placeholder="Enter company name"/>
                                <field name="phone" placeholder="Enter phone number"/>
                                <field name="address" placeholder="Enter address"/>
                                <field name="vehicle_ids" widget="many2many_tags" invisible="1"/>
                            </group>
                            <group>
                                <field name="company_id" invisible="1"/>
                            </group>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids" />
                    </div>
                </form>
            </field>
        </record>


    <record id="visitor_company_action_window" model="ir.actions.act_window">
        <field name="name">Company Info</field>
        <field name="res_model">visitor.company</field>
        <field name="view_mode">tree,form</field>
    </record>
    
    <menuitem id="visitor_company_menu_root"
        parent="configuration_menu"
        action="visitor_company_action_window"
        name="Company Info"/>

    </data>
</odoo>