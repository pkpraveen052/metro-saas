    <template id="visitor_portal" inherit_id="portal.portal_my_home">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="url">/new/visitor</t>
                <t t-set="title">Register Visitor</t>
                <t t-set="placeholder_count" t-value="'visitor_counts'"/>
            </t>
        </xpath>
    </template>


