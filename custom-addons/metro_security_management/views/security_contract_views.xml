<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="security_contract_tree_view" model="ir.ui.view">
            <field name="name">security.contract.list.view</field>
            <field name="model">security.contract</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="contract_ref" />
                    <field name="name"/>
                    <field name="partner_id" />
                    <field name="service_buyer" />
                    <field name="state" decoration-success="state == 'running'" decoration-info="state == 'draft'" decoration-danger="state == 'expired'" widget="badge" optional="show"/>
                    <field name="activity_ids" widget="list_activity" optional="show"/>
                    <field name="contract_date" optional="hide"/>
                    <field name="expired_date" optional="hide" attrs="{'invisible': [('expired_date','=',False)]}"/>
                </tree>
            </field>
        </record>
        <record id="security_contract_form_view" model="ir.ui.view">
            <field name="name">security.contract.form.view</field>
            <field name="model">security.contract</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <field name="state" widget="statusbar" class="oe_highlight" clickable="1"/>
                    </header>
                    <sheet>
                        <widget name="web_ribbon" title="Archived" bg_color="bg-danger" attrs="{'invisible': [('active', '=', True)]}"/>
                        <h1>
                            <field name="contract_ref" readonly="1"/>
                        </h1>
                        <group>
                            <group>
                                <field name="name" placeholder="Enter contract name"/>
                                <field name="partner_id" widget="res_partner_many2one"
                                domain="[('company_id','=', company_id)]" context="{'res_partner_search_mode': 'customer', 'show_address': 1, 'show_vat': True}" options="{&quot;always_reload&quot;: True}"/>
                                <field name="phone" widget="phone"/>
                                <field name="email" widget="email"/>
                                <field name="company_id"/>
                            </group>
                            <group>
                                <field name="service_buyer" placeholder="Type here"/>
                                <field name="contract_date"/>
                                <field name="expired_date" attrs="{'invisible': [('expired_date','=',False)]}" decoration-danger="expired_date"/>
                                <field name="description" placeholder="Enter description"/>
                                <field name="active" invisible="1"/>
                                <field name="color" invisible="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Location Details">
                                <field name="location_ids">
                                    <tree>
                                        <field name="location_ref" optional="hide"/>
                                        <field name="location_name" placeholder="Enter Location"/>
                                        <field name="address_id"/>
                                        <field name="start_date"/>
                                        <field name="end_date"/>
                                    </tree>
                                    <form>
                                            <h1>
                                                <field name="location_ref" readonly="1"/>
                                            </h1>
                                            <group>
                                                <group>
                                                    <field name="location_name" placeholder="Enter location name"/>
                                                    <field name="address_id" widget="res_partner_many2one" context="{'res_partner_search_mode': 'customer', 'show_address': 1, 'show_vat': True}" options="{&quot;always_reload&quot;: True}" placeholder="Select or Create address"/>
                                                </group>
                                                <group>
                                                    <field name="start_date" />
                                                    <field name="end_date" />
                                                    <field name="active" invisible="1"/>
                                                    <field name="color" invisible="1"/>
                                                </group>
                                            </group>
                                            <notebook>
                                                <page string="CheckPoints">
                                                    <field name="checkpoint_ids">
                                                        <tree editable="bottom">
                                                            <field name="sequence"/>
                                                            <field name="name" placeholder="Enter Check-Point Name"/>
                                                            <field name="item_type"/>
                                                            <field name="device_id" placeholder="23224434"/>
                                                        </tree>
                                                    </field>
                                                </page>
                                                <page string="Security Info">
                                                    <group>
                                                        <group>
                                                            <field name="security_ids" widget="many2many_tags"/>
                                                        </group>
                                                    </group>
                                                </page>
                                            </notebook>
                                    </form>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids" />
                    </div>
                </form>
            </field>
        </record>

        <record id="security_contract_kanban_view" model="ir.ui.view">
            <field name="name">security.contract.kanban.view</field>
            <field name="model">security.contract</field>
            <field name="priority" eval="1"/>
            <field name="arch" type="xml">
                <kanban sample="1">
                    <field name="name"/>
                    <field name="state"/>
                    <field name="color"/>
                    <field name="active"/>
                    <field name="activity_state" />
                    <field name="activity_ids" />
                    <!-- <progressbar field="activity_state" colors='{"planned": "success", "today": "warning", "overdue": "danger"}'/> -->
                    <templates>
                        <t t-name="kanban-box">
                            <div t-attf-class="#{!selection_mode ? kanban_color(record.color.raw_value) : ''} oe_kanban_global_click">
                                <!-- Dropdown Menu -->
                                <div class="o_dropdown_kanban dropdown">
                                    <a class="dropdown-toggle o-no-caret btn" role="button" data-toggle="dropdown" data-display="static" href="#" aria-label="Dropdown menu" title="Dropdown menu">
                                        <span class="fa fa-ellipsis-v"/>
                                    </a>
                                    <div class="dropdown-menu" role="menu">
                                        <t t-if="widget.editable">
                                            <a role="menuitem" type="edit" class="dropdown-item">Edit</a>
                                        </t>
                                        <t t-if="widget.deletable">
                                            <a role="menuitem" type="delete" class="dropdown-item">Delete</a>
                                        </t>
                                        <ul class="oe_kanban_colorpicker" data-field="color"/>
                                    </div>
                                </div>
                                
                                <!-- Main Content -->
                                <div class="oe_kanban_content">
                                    <!-- Contract Reference -->
                                    <div class="o_kanban_record_title">
                                        <h4><field name="contract_ref"/></h4>
                                    </div>
                                    
                                    <!-- Partner and Service Buyer -->
                                    <div class="o-kanban-partner-info">
                                        <div>
                                            <!-- <i class="fa fa-briefcase" aria-hidden="true" title="Contract"></i> -->
                                            <span><b>Contract Name: </b><field name="name"/></span>
                                        </div>
                                        <div>
                                            <!-- <i class="fa fa-user" aria-hidden="true" title="Partner"></i> -->
                                            <span><b>Contact Person: </b><field name="partner_id"/></span>
                                        </div>
                                        <div>
                                            <!-- <i class="fa fa-handshake-o" aria-hidden="true" title="Service Buyer"></i> -->
                                            <span><b>Service Buyer: </b><field name="service_buyer"/></span>
                                        </div>
                                        <div>
                                            <span><b>Contract Date: </b><field name="contract_date"/></span>
                                        </div>
                                    </div>

                                    <!-- Locations Display -->
                                    <div class="o-kanban-locations">
                                        <div class="text-right">
                                            <a type="object" name="action_view_locations">
                                                <strong><field name="location_count" class="oe_inline"/> Locations</strong>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                    
                                <!-- Bottom Section -->
                                <div class="o-kanban-bottom d-flex justify-content-between align-items-center">
                                    <!-- Left Section: Create Location Button -->
                                    <div class="text-left">
                                        <button name="action_create_new" type="object" class="btn btn-primary btn-md">
                                            <span>Create Location</span>
                                        </button>
                                    </div>
                                
                                    <!-- Center Section: Activity IDs -->
                                    <div class="text-center">
                                        <field name="activity_ids" widget="kanban_activity"/>
                                    </div>
                                
                                    <!-- Right Section: Status -->
                                    <div class="text-right">
                                        <field name="state" widget="label_selection" options="{'classes': {'draft': 'warning', 'expired': 'danger', 'running': 'success'}}"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="security_contract_search_view" model="ir.ui.view">
            <field name="name">security.contract.search.view</field>
            <field name="model">security.contract</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="contract_ref"/>
                    <field name="partner_id"/>
                    <field name="service_buyer"/>
                    <filter name="filter_active" string="Archived"  domain="[('active','=',False)]"/>
                    <separator/>
                    <filter string="Draft" name="draft_state" domain="[('state','=','draft')]"/>
                    <filter string="Running" name="running_state" domain="[('state','=','running')]"/>
                    <filter string="Expired" name="expired_state" domain="[('state','=','expired')]"/>
                    <separator/>
                    <filter string="Create Date" name="filter_create_date" date="create_date"/>
                    <separator/>
                    <group expand="1" string="Group By">
                        <filter string="Contact Name" name='contact_name' context="{'group_by':'partner_id'}"/>
                        <filter string="Service Buyer" name="service_buyer" context="{'group_by':'service_buyer'}"/>
                        <filter string="Status" name="status" context="{'group_by':'state'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="security_contract_action_window" model="ir.actions.act_window">
            <field name="name">Contract</field>
            <field name="res_model">security.contract</field>
            <field name="view_mode">kanban,tree,form,search</field>
        </record>

    <menuitem id="security_contract_menu_root"
        name="Security Management"
        web_icon="metro_security_management,static/description/icon.png"
        groups="metro_security_management.metro_security_management_group_manager,metro_security_management.metro_security_management_group_user"
        sequence="5"/>

    <menuitem id="security_contract_menu"
        parent="security_contract_menu_root"
        name="Contract"
        action="security_contract_action_window"
        sequence="0"/>

    </data>
</odoo>