<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="security_responses_tree_view" model="ir.ui.view">
            <field name="name">security.responses.list.view</field>
            <field name="model">security.responses</field>
            <field name="arch" type="xml">
                <tree delete="false">
                    <field name="name" />
                    <field name="check_point_id"/>
                    <field name="device_id"/>
                    <field name="location_id" />
                    <field name="contract_id"/>
                    <field name="timestamp" />
                </tree>
            </field>
        </record>
        <record id="security_responses_form_view" model="ir.ui.view">
            <field name="name">security.responses.form.view</field>
            <field name="model">security.responses</field>
            <field name="arch" type="xml">
                <form delete="false">
                    <sheet>
                        <group>
                            <group>
                                <field name="name" />
                                <field name="check_point_id"/>
                                <field name="location_id" />
                                <field name="contract_id"/>
                                <field name="device_id"/>
                                <field name="company_id" invisible="1"/>
                            </group>
                            <group>
                                <field name="timestamp" />
                            </group>
                            <group>
                            </group>
                            <group>
                                <field name="remarks" placeholder="Type here"/>
                            </group>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids" />
                    </div>
                </form>
            </field>
        </record>

        
        <record id="security_responses_search_view" model="ir.ui.view">
            <field name="name">security.responses.search.view</field>
            <field name="model">security.responses</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name" />
                    <field name="location_id" />
                    <field name="check_point_id"/>
                    <field name="contract_id"/>
                    <separator/>
                    <filter string="Create Date" name="filter_create_date" date="create_date"/>
                    <separator/>
                    <group expand="1" string="Group By">
                        <filter string="Checkpoint" name='check_point' context="{'group_by':'check_point_id'}"/>
                        <filter string="Location" name='location' context="{'group_by':'location_id'}"/>
                        <filter string="Contract" name='contract' context="{'group_by':'contract_id'}"/>
                    </group>
                </search>
            </field>
        </record>


        <record id="security_responses_action_window" model="ir.actions.act_window">
            <field name="name">Responses</field>
            <field name="res_model">security.responses</field>
            <field name="view_mode">tree,form,search</field>
        </record>

    <menuitem id="security_responses_menu"
        parent="security_contract_menu_root"
        name="Responses"
        action="security_responses_action_window"
        sequence="3"/>

    </data>
</odoo>