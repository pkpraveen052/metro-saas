<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="security_contract_checkpoint_tree_view" model="ir.ui.view">
            <field name="name">security.contract.checkpoint.list.view</field>
            <field name="model">security.contract.checkpoint</field>
            <field name="arch" type="xml">
                <tree create="false" edit="false">
                    <field name="name" />
                    <field name="location_id" />
                    <field name="contract_id"/>
                    <field name="item_type" />
                    <field name="device_id" />
                </tree>
            </field>
        </record>

        <record id="security_contract_checkpoint_form_view" model="ir.ui.view">
            <field name="name">security.contract.checkpoint.form.view</field>
            <field name="model">security.contract.checkpoint</field>
            <field name="arch" type="xml">
                <form create="false" edit="false">
                    <sheet>
                        <group>
                            <group>
                                <field name="name" />
                                <field name="location_id" />
                                <field name="contract_id" required="1"/>
                                <field name="company_id" invisible="1"/>
                            </group>
                            <group>
                                <field name="item_type" />
                                <field name="device_id" placeholder="000123"/>
                                <field name="sequence"/>
                            </group>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids" />
                    </div>
                </form>
            </field>
        </record>

        <record id="security_contract_checkpoint_search_view" model="ir.ui.view">
            <field name="name">security.contract.checkpoint.search.view</field>
            <field name="model">security.contract.checkpoint</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="item_type"/>
                    <field name="location_id"/>
                    <field name="device_id"/>
                    <filter string="Point" name="point" domain="[('item_type','=','point')]"/>
                    <filter string="Plat" name="plat" domain="[('item_type','=','plat')]"/>
                    <separator/>
                    <filter string="Create Date" name="filter_create_date" date="create_date"/>
                    <separator/>
                    <group expand="1" string="Group By">
                        <filter string="Item Type" name='item_type' context="{'group_by':'item_type'}"/>
                        <filter string="Location" name='location' context="{'group_by':'location_id'}"/>
                    </group>
                </search>
            </field>
        </record>

    <record id="security_contract_checkpoint_action_window" model="ir.actions.act_window">
        <field name="name">CheckPoints</field>
        <field name="res_model">security.contract.checkpoint</field>
        <field name="view_mode">tree,form,search</field>
    </record>


    <menuitem id="security_contract_checkpoint_menu"
        parent="security_contract_menu_root"
        name="CheckPoints"
        action="security_contract_checkpoint_action_window"
        sequence="2"/>

    </data>
</odoo>