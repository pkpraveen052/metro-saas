<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="res_config_settings_view_security_form" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.security</field>
            <field name="model">res.config.settings</field>
            <field name="priority" eval="40"/>
            <field name="inherit_id" ref="base.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//div[hasclass('settings')]" position="inside">
                    <div class="app_settings_block" data-string="Security Management" string="Security Management" data-key="metro_security_management">
                        <h2>Terms and Conditions</h2>
                        <div class="row mt16 o_settings_container">
                            <div class="col-12 col-lg-6 o_setting_box" id="use_visitor_tc">
                                <div class="o_setting_left_pane">
                                    <field name="use_visitor_tc"/>
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="use_visitor_tc"/>
                                    <span class="fa fa-lg fa-building-o" title="Values set here are company-specific." aria-label="Values set here are company-specific." groups="base.group_multi_company" role="img"/>
                                    <div class="text-muted">
                                        Show standard terms &amp; conditions on Visitor Slip.
                                    </div>
                                    <div class="content-group" attrs="{'invisible': [('use_visitor_tc','=',False)]}">
                                        <div class="mt16">
                                            <field name="visitor_tc" placeholder="Insert your terms &amp; conditions here..."/>
                                        </div>
                                    </div>
                                </div>
                        </div>
                        </div>
                    </div>
                </xpath>
            </field>
    </record>
    
        <record id="action_security_config_settings" model="ir.actions.act_window">
            <field name="name">Settings</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">res.config.settings</field>
            <field name="view_mode">form</field>
            <field name="target">inline</field>
            <field name="context">{'module' : 'metro_security_management', 'bin_size': False}</field>
        </record>
    
        <menuitem id="menu_security_general_settings"
            name="Settings"
            parent="metro_security_management.configuration_menu_root"
            sequence="0"
            action="action_security_config_settings"
            groups="base.group_system"/>
    </data>
</odoo>
