<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="ic_number_tree_view" model="ir.ui.view">
            <field name="name">ic.number.list.view</field>
            <field name="model">ic.number</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="ic_number"/>
                    <field name="phone"/>
                    <field name="email"/>
                </tree>
            </field>
        </record>

        <record id="ic_number_form_view" model="ir.ui.view">
            <field name="name">ic.number.form.view</field>
            <field name="model">ic.number</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <field name="image_1920" widget="image" class="oe_avatar"/>
                        <group>
                            <group>
                                <field name="name" placeholder="Enter name"/>
                                <field name="ic_number" placeholder="Enter IC number"/>
                                <field name="active" invisible="1"/>
                            </group>
                            <group>
                                <field name="phone" placeholder="Enter phone number"/>
                                <field name="email" placeholder="Enter email address"/>
                                <field name="company_id" invisible="1"/>
                                <field name="active" invisible="1"/>
                            </group>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids" />
                    </div>
                </form>
            </field>
        </record>

        <record id="ic_number_search_view" model="ir.ui.view">
            <field name="name">ic.number.search.view</field>
            <field name="model">ic.number</field>
            <field name="arch" type="xml">
                <search>
                    <field name="ic_number"/>
                    <field name="name"/>
                    <field name="phone"/>
                    <field name="email"/>
                    <filter name="filter_active" string="Archived"  domain="[('active','=',False)]"/>
                    <separator/>
                    <filter string="Create Date" name="filter_create_date" date="create_date"/>
                </search>
            </field>
        </record>


    <record id="ic_number_action_window" model="ir.actions.act_window">
        <field name="name">Visitor Info</field>
        <field name="res_model">ic.number</field>
        <field name="view_mode">tree,form,search</field>
    </record>
    
    <menuitem id="ic_number_menu_root"
        parent="configuration_menu"
        action="ic_number_action_window"
        name="Visitor Info"/>

    </data>
</odoo>