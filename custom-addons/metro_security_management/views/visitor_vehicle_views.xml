<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="visitor_vehicle_tree_view" model="ir.ui.view">
            <field name="name">visitor.vehicle.list.view</field>
            <field name="model">visitor.vehicle</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="phone"/>
                    <field name="vehicle_number"/>
                </tree>
            </field>
        </record>

        <record id="visitor_vehicle_form_view" model="ir.ui.view">
            <field name="name">visitor.vehicle.form.view</field>
            <field name="model">visitor.vehicle</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name" placeholder="Enter name"/>
                                <field name="phone" placeholder="Enter phone number"/>
                                <field name="vehicle_number" placeholder="Enter vehicle number"/>
                                <field name="visitor_company_ids" widget="many2many_tags"/>
                            </group>
                            <group>
                                <field name="vehicle_image" widget="image" height="150" width="150"/>
                                <field name="company_id" invisible="1"/>
                            </group>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids" />
                    </div>
                </form>
            </field>
        </record>


    <record id="visitor_vehicle_action_window" model="ir.actions.act_window">
        <field name="name">Vehicle Info</field>
        <field name="res_model">visitor.vehicle</field>
        <field name="view_mode">tree,form</field>
    </record>
    
    <menuitem id="visitor_vehcile_menu_root"
        parent="configuration_menu"
        action="visitor_vehicle_action_window"
        name="Vehicle Info"/>

    </data>
</odoo>