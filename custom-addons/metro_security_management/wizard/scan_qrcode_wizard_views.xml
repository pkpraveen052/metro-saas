<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="scan_qrcode_form" model="ir.ui.view">
        <field name="name">scan.qrcode.wizard.form</field>
        <field name="model">scan.qrcode.wizard</field>
        <field name="arch" type="xml">
            <form>
                <script>
                    $(document).ready(function() {
                        var myInterval = setInterval(function() {
                            if($('.qrcode_note').hasClass('o_invisible_modifier')){
                                $("#save_btn").trigger("click");
                                clearInterval(myInterval);
                            };
                        }, 1000);
                    })
                </script>
                <field name="visitor_id" invisible="1"/>
                <field name="is_valid" invisible="1" />
                <div class="qrcode_note" attrs="{'invisible': [('is_valid','=', True)]}" style="color:red;">
                    <strong>Note: Scan Visitor QR code here.</strong>
                </div>
                <group>
                    <field name="qrcode"/>
                </group>
                <footer>
                    <button id="save_btn" string="Submit" type="object" name="save_data" class="btn btn-primary"/>
                    <button string="Cancel" special="cancel" type="object" class="btn btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
