<?xml version="1.0"?>
<odoo>

    <record id="financial_documents_view_tree" model="ir.ui.view">
        <field name="name">financial.documents.tree</field>
        <field name="model">financial.documents</field>
        <field name="arch" type="xml">
            <tree string="Financial Documents" multi_edit="1" sample="1">
                <field name="sequence" widget="handle"/>
                <field name="name" class="field_name"/>
                <field name="tech_name"/>
            </tree>
        </field>
    </record>

    <record id="financial_documents_view_form" model="ir.ui.view">
        <field name="name">financial.documents.form</field>
        <field name="model">financial.documents</field>
        <field name="arch" type="xml">
            <form string="fs search" class="oe_form_configuration" create="0" delete="0" edit="0">
                <sheet>
                    <div class="oe_title" id='title'>
                        <label for="name" class="oe_edit_only"/>
                        <h1 id="name"><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="tech_name" readonly="1"/>
                            <field name="sequence" readonly="1"/>
                        </group>
                        <group/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="financial_documents_view_kanban" model="ir.ui.view" >
        <field name="name">financial.documents.dashboard</field>
        <field name="model">financial.documents</field>
        <field name="arch" type="xml">
            <kanban class="oe_background_grey o_kanban_dashboard o_emphasize_colors o_fs_kanban" create="0">
                <field name="name"/>
                <field name="color"/>
                <field name="tech_name"/>
                <field name="sequence"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="#{!selection_mode ? kanban_color(record.color.raw_value) : ''}">
                            <span class="oe_kanban_color_help" t-attf-title="In #{kanban_getcolorname(record.color.raw_value)}" role="img" t-attf-aria-label="In #{kanban_getcolorname(record.color.raw_value)}"/>
                            <div t-attf-class="o_kanban_card_header">
                                <div class="o_kanban_card_header_title">
                                    <div class="o_primary" style="font-size: 20px !important;"><field name="name"/></div>
                                </div>
                                <div class="o_kanban_manage_button_section" t-if="!selection_mode" groups="metro_helpdesk.group_helpdesk_manager">
                                    <a class="o_kanban_manage_toggle_button" href="#"><i class="fa fa-ellipsis-v" role="img" aria-label="Manage" title="Manage"/></a>
                                </div>
                            </div>
                            <div class="container o_kanban_card_content" t-if="!selection_mode" attrs="{'invisible': [('tech_name','!=','fs')]}">
                                <div class="row">
                                    <div class="col-6 o_kanban_primary_left">
                                        <button class="btn btn-primary" name="%(metroerp_fs.director_statement_action)d" type="action">View</button>
                                        <button class="btn btn-primary" name="action_create_fs" type="object">Create</button>
                                    </div>
                                    <div class="col-6 o_kanban_primary_right" style="font-size: 15px;text-align: right;">
                                        <div class="mb8">
                                            <a name="action_fs_select_template" type="object">Select Template</a>
                                        </div>
                                        <div class="mb8" groups="metroerp_accounting_addons.documents_overview_admin_group">
                                            <a name="action_fs_view_default" type="object">Default Configuration</a>
                                        </div>
                                    </div>
                                </div>
                                <!-- Smiley indicator of rating:
                                <div t-if="record.use_rating.raw_value and record.rating_percentage_satisfaction.raw_value &gt;= 0" class="row text-center">
                                    <a name="action_view_all_rating" type="object" title="Percentage of happy people about this team" class="float-right">
                                        <h5 t-attf-class="badge #{record.rating_percentage_satisfaction.raw_value &gt;= 50 ? 'badge-success' : 'badge-warning'}">
                                            <i t-attf-class="fa #{record.rating_percentage_satisfaction.raw_value &gt;= 50 ? 'fa-smile-o' : 'fa-frown-o'}" role="img" aria-label="Satisfaction rate" title="Satisfaction rate"/> <t t-raw="record.rating_percentage_satisfaction.raw_value"/> %
                                        </h5>
                                    </a>
                                </div> -->
                            </div>
                            <div class="container o_kanban_card_content" t-if="!selection_mode" attrs="{'invisible': [('tech_name','!=','cs_doc')]}">
                                <div class="row">
                                    <div class="col-6 o_kanban_primary_left">
                                        <button class="btn btn-primary" name="action_view_csdoc" type="object">View</button>
                                        <button class="btn btn-primary" name="action_create_csdoc" type="object">Create</button>
                                    </div>
                                </div>
                            </div>
                            <div class="container o_kanban_card_content" t-if="!selection_mode" attrs="{'invisible': [('tech_name','!=','xbrl')]}">
                                <div class="row">
                                    <div class="col-6 o_kanban_primary_left">
                                        <button class="btn btn-primary" name="action_view_xbrl" type="object">View</button>
                                        <button class="btn btn-primary" name="action_create_xbrl" type="object">Create</button>
                                    </div>
                                    <div class="col-6 o_kanban_primary_right" style="font-size: 15px;text-align: right;">
                                        <div class="mb8" groups="metroerp_accounting_addons.documents_overview_admin_group">
                                            <a name="action_xbrl_lines" type="object">View XBRL Lines</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="container o_kanban_card_content" t-if="!selection_mode" attrs="{'invisible': [('tech_name','!=','form_cs')]}">
                                <div class="row">
                                    <div class="col-6 o_kanban_primary_left">
                                        <button class="btn btn-primary" name="action_view_formcs" type="object">View</button>
                                        <button class="btn btn-primary" name="action_create_formcs" type="object">Create</button>
                                    </div>
				    <div class="col-6 o_kanban_primary_right" style="font-size: 15px;text-align: right;">
					<div class="mb8">
                                            <a name="action_import_formcs_bulk" type="object">Import bulk records</a>
                                        </div>
                                        <div class="mb8" groups="metroerp_accounting_addons.documents_overview_admin_group">
                                            <a name="action_coa_mapping" type="object">COA Mapping</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="container o_kanban_card_content" t-if="!selection_mode" attrs="{'invisible': [('tech_name','!=','gst')]}">
                                <div class="row">
                                    <div class="col-6 o_kanban_primary_left">
                                        <button class="btn btn-primary mb8" name="%(metroerp_iras.gst_returns_f5f8_action)d" type="action">GST Returns (F5 and F8)</button>
                                        <button class="btn btn-primary" name="%(metroerp_iras.gst_returns_f7_action)d" type="action">Past GST Return (GST F7)</button>
                                    </div>
                                    <div class="col-6 o_kanban_primary_right" style="font-size: 15px;text-align: right;">
                                        <div class="mb8" groups="metroerp_accounting_addons.documents_overview_admin_group">
                                            <a name="%(account.action_tax_form)d" type="action">View Taxes</a>
                                        </div>
                                        <div class="mb8" groups="base.group_system">
                                            <a name="%(ks_dynamic_financial_report.ks_df_tax_report_action)d" type="action">Tax Report</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="container o_kanban_card_manage_pane dropdown-menu" role="menu">

                                <div t-if="widget.editable" class="o_kanban_card_manage_settings row">
                                    <div role="menuitem" aria-haspopup="true" class="col-8">
                                        <ul class="oe_kanban_colorpicker" data-field="color" role="menu"/>
                                    </div>
                                    <div role="menuitem" class="col-4 text-right">
                                        <a type="edit">Settings</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="financial_documents_dashboard_action_main" model="ir.actions.act_window">
        <field name="name">Overview</field>
        <field name="res_model">financial.documents</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="context">{}</field>
        <field name="view_id" ref="metroerp_accounting_addons.financial_documents_view_kanban"/>
        <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
                No records found
            </p>
        </field>
    </record>


    <menuitem id="fs_menu_root" name="Documents Overview"
        sequence="25"
        web_icon="metroerp_accounting_addons,static/description/icon.png"
        groups="metroerp_accounting_addons.documents_overview_user_group,metroerp_accounting_addons.documents_overview_admin_group"/>

    <menuitem id="fs_menu_team_dashboard" action="metroerp_accounting_addons.financial_documents_dashboard_action_main"
        sequence="5" parent="metroerp_accounting_addons.fs_menu_root" name="Dashboard"/>
</odoo>
