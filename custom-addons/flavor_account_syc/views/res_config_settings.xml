<?xml version="1.0" encoding="utf-8" ?>

<odoo>

    <record id="res_config_settings_view_flavor_form" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.flavor</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="account.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//div[@name='fiscal_localization_setting_container']" position="after">
                    <h2>Flavor</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-12 o_setting_box"
                            title="CorpPass Authentication">
                            <div class="o_setting_left_pane">
                                <field name="enable_flavor_sync"/>
                            </div>
                            <div class="o_setting_right_pane">
<!--                                <span class="o_form_label">Flavor</span>-->
                                <!-- <div class="content-group">
                                    <div class="row mt16">
                                        <label for="enable_flavor_sync" string="Flavor Sync" class="col-lg-3 o_light_label"/>
                                        <field name="enable_flavor_sync"/>
                                    </div>
                                </div> -->
                                <label for="enable_flavor_sync"/>
                                    <!-- <span title="Values set here are company-specific." aria-label="Values set here are company-specific." groups="base.group_multi_company" role="img"/> -->
<!--                                     <div class="text-muted">
                                        Allow to configure taxes using cash basis
                                    </div> -->
                                <br/><br/><button name="action_auto_generate" string="Generate" type="object"
                                    attrs="{'invisible': ['|',('enable_flavor_sync','=',False),('flavor_apikey', '!=', False)]}" icon="fa-check-circle-o" class="oe_highlight"/>
                                <div class="content-group" attrs="{'invisible': [('enable_flavor_sync','=',False)]}">
                                    <div class="row mt16">
                                        <label for="flavor_apikey" string="API Key" class="col-lg-3 o_light_label"/>
                                        <field name="flavor_apikey"/>
                                    </div>
                                    <div class="row mt16">
                                        <label for="flavor_apisecret" string="API Secret" class="col-lg-3 o_light_label"/>
                                        <field name="flavor_apisecret"/>
                                    </div>
                                    <button name="action_regenerate" string="Regenerate" type="object"
                                        attrs="{'invisible': ['|',('enable_flavor_sync','=',False),('flavor_apikey', '=', False)]}" icon="fa-check-circle-o" class="oe_highlight"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </xpath>
            </field>
    </record>

</odoo>
