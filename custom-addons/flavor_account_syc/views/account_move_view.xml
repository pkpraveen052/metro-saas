<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!--    account move    -->
        <record id="account_move_form_flavor" model="ir.ui.view">
            <field name="name">flavor.account.move.form</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <field name="partner_id" position="after">
                    <field name="flavor_ref_no" groups="flavor_account_syc.group_flavor_sync"/>
                </field>
            </field>
        </record>

        <record id="account_move_list_flavor" model="ir.ui.view">
            <field name="name">flavor.account.move.list</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_out_invoice_tree"/>
            <field name="arch" type="xml">
                <field name="name" position="after">
                    <field name="flavor_ref_no" groups="flavor_account_syc.group_flavor_sync"/>
                </field>
            </field>
        </record>

        <record id="account_move_filter_flavor" model="ir.ui.view">
            <field name="name">flavor.account.move.filter</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_account_move_filter"/>
            <field name="arch" type="xml">
                <field name="partner_id" position="after">
                    <field name="flavor_ref_no" groups="flavor_account_syc.group_flavor_sync"/>
                </field>
                <xpath expr="//group" position="inside">
                    <filter string="Flavor Ref No" domain="[]" name="flavor_ref_no" context="{'group_by':'flavor_ref_no'}" groups="flavor_account_syc.group_flavor_sync"/>
                </xpath>
            </field>
        </record>

        <record id="view_account_invoice_filter_flavor" model="ir.ui.view">
            <field name="name">flavor.account.invoice.select</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_account_invoice_filter"/>
            <field name="arch" type="xml">
                <field name="partner_id" position="after">
                    <field name="flavor_ref_no" groups="flavor_account_syc.group_flavor_sync"/>
                </field>
                <xpath expr="//group" position="inside">
                    <filter string="Flavor Ref No" domain="[]" name="flavor_ref_no" context="{'group_by':'flavor_ref_no'}" groups="flavor_account_syc.group_flavor_sync"/>
                </xpath>
            </field>
        </record>


        <!--    account payment    -->
        <record id="account_payment_form_flavor" model="ir.ui.view">
            <field name="name">flavor.account.payment.form</field>
            <field name="model">account.payment</field>
            <field name="inherit_id" ref="account.view_account_payment_form"/>
            <field name="arch" type="xml">
                <field name="payment_type" position="before">
                    <field name="flavor_ref_no" groups="flavor_account_syc.group_flavor_sync"/>
                </field>
            </field>
        </record>

        <record id="account_payment_list_flavor" model="ir.ui.view">
            <field name="name">flavor.account.payment.list</field>
            <field name="model">account.payment</field>
            <field name="inherit_id" ref="account.view_account_payment_tree"/>
            <field name="arch" type="xml">
                <field name="name" position="after">
                    <field name="flavor_ref_no" groups="flavor_account_syc.group_flavor_sync"/>
                </field>
            </field>
        </record>
    </data>
</odoo>