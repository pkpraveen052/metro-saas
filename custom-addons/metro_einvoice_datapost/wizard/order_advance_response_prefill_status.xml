<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="order_advance_response_prefill_status_form_view" model="ir.ui.view">
        <field name="name">order.advance.response.prefill.status.form</field>
        <field name="model">order.advance.response.prefill.status</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="response_code"/>
                        </group>
                        <field name="message" nolabel="1"/>
                    </group>
                </sheet>
                
                <footer>
                    <button string="Proceed" name="action_order_advance_response_queue_out" type="object" class="oe_highlight"/>
                    <button string="Cancel" class="btn btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>