<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="peppol_manual_send_payment_wizard_form_view" model="ir.ui.view">
        <field name="name">peppol.manual.send.payment.wizard.form</field>
        <field name="model">peppol.manual.send.payment.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="message" nolabel="1"/>
                </group>
                <footer>
                    <button string="Send" name="action_send_payment" type="object" class="oe_highlight"/>
                    <button string="Cancel" class="btn btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>