<?xml version="1.0" encoding="utf-8"?>

<odoo>

    <record id="peppol_sg_move_form" model="ir.ui.view">
        <field name="name">metro_einvoice_datapost.account.move.form</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <button name="open_reconcile_view" position="after">
                <button invisible="1"
                    name="generate_ubl_report"
                    class="oe_stat_button"
                    type="object"
                    help="Generate UBL.">
                    <span style="padding-right: 3px;">
                        <img width="32" height="32" alt="PEPPOL"/><!-- src="/metro_einvoice_datapost/static/description/peppol.png" -->
                    </span>
                    <span>
                        Generate UBL
                    </span>
                </button>
            </button>
            <xpath expr="//field[@name='name']" position='before'>
                <div class="ribbon ribbon-top-right" style="margin-top:-53px;" attrs="{'invisible': [('outgoing_inv_doc_ref', '=', False)]}">
                    <span style="font-size: 12px;height:45px;width:365px;text-indent:-94px;padding:24px 44px;" class="bg-info">Peppol</span>
                </div>
            </xpath>
            <!-- <xpath expr="//page[@id='other_tab_entry']" position="after">
                <page string="Peppol Info" attrs="{'invisible': [('move_type', 'in', ('out_invoice'))]}">
                    <group string="Peppol" name="accounting_peppol">
                        <group>
                            <field name="peppol_invoice_no" string="Invoice Number"/>
                        </group>
                        <group>
                            <field name="peppol_invoice_doc_ids" widget="many2many_binary" readonly="1"/>
                        </group>
                    </group>
                </page>
            </xpath> -->
            <xpath expr="//group[@name='accounting_info_group']" position="after">
              <group string="Outgoing Invoice Queue" attrs="{'invisible': [('move_type', 'not in', ('out_invoice','out_refund'))]}">
                  <field name="outgoing_inv_doc_ref"  readonly="1"/>
              </group>
                <group string="Outgoing Invoice Queue" attrs="{'invisible': [('move_type', 'not in', ('out_invoice', 'out_refund'))]}">
                  <field name="outgoing_inv_doc_ref_c5" readonly="1"/>
              </group>
            </xpath>
            <xpath expr="//button[@name='action_invoice_sent']" position="after">
              <button name="action_send_via_peppol" type="object" string="Send to InvoiceNow" attrs="{'invisible':['|', '|',('state', '!=', 'posted'), ('move_type', 'not in', ('out_invoice','out_refund')),('outgoing_inv_doc_ref','!=',False)]}" class="oe_highlight"/>
            </xpath>
             <xpath expr="//button[@name='action_invoice_sent']" position="after">
              <button name="action_send_via_peppol_c5" type="object" string="Send to GST InvoiceNow" attrs="{'invisible':['|',('state', '!=', 'posted'), ('move_type', 'not in', ('in_invoice','in_refund'))]}" class="oe_highlight"/>
            </xpath>
        </field>
    </record>

    <record model="ir.actions.server" id="action_move_peppol_send">
        <field name="name">Send Invoice</field>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="state">code</field>
        <field name="code">
    if records:
        action = records._peppol_action_manual_send()
        </field>
    </record>

    <record id="peppol_account_invoice_filter" model="ir.ui.view">
        <field name="name">peppol.account.invoice.filter</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_account_invoice_filter"/>
        <field name="arch" type="xml">
            <filter name="activities_upcoming_all" position="after">
                <separator/>
                <!-- <filter name="e-Invoices" domain="[('outgoing_inv_doc_ref','!=',False)]"/> -->
                <filter name="Sent to InvoiceNow" domain="[('outgoing_inv_doc_ref.state','in',['Send Success','Completed'])]"/>
                <filter name="peppol_ready" string="Peppol Ready" domain="[('state','=','posted'),('outgoing_inv_doc_ref','=',False)]"/>
            </filter>
        </field>
    </record>

    <record id="view_pepppol_in_invoice_tree_view" model="ir.ui.view">
        <field name="name">account.move.tree.view</field>
        <field name="model">account.move</field>
        <field name="arch" type="xml">
            <tree string="Invoices" js_class="account_tree" sample="1" decoration-info="state == 'draft'" decoration-muted="state == 'cancel'">
                <button name="map_to_incoming_invoice" type="object" string="Map" class="oe_highlight"/>
                <field name="name" decoration-bf="1"/>
                <field name="partner_id" invisible="1"/>
                <field name="invoice_source_email" invisible="1"/>
                <field name="invoice_partner_display_name" invisible="context.get('default_move_type') not in ('in_invoice', 'in_refund','in_receipt')" groups="base.group_user" string="Vendor"/>
                <field name="invoice_partner_display_name" invisible="context.get('default_move_type') not in ('out_invoice', 'out_refund','out_receipt')" groups="base.group_user" string="Customer"/>
                <field name="invoice_date" optional="show" invisible="context.get('default_move_type') not in ('in_invoice', 'in_refund','in_receipt')" string="Bill Date"/>
                <field name="invoice_date" optional="show" invisible="context.get('default_move_type') not in ('out_invoice', 'out_refund','out_receipt')" string="Invoice Date"/>
                <field name="invoice_date_due" widget="remaining_days" optional="show"/>
                <field name="invoice_origin" optional="hide" string="Source Document"/>
                <field name="payment_reference" optional="hide" invisible="context.get('default_move_type') in ('out_invoice', 'out_refund','out_receipt')"/>
                <field name="ref" optional="hide"/>
                <field name="invoice_user_id" optional="hide" invisible="context.get('default_move_type') not in ('out_invoice', 'out_refund','out_receipt')" string="Sales Person" widget="many2one_avatar_user"/>
                <field name="activity_ids" widget="list_activity" optional="show"/>
                <field name="company_id" options="{'no_create': True}" optional="show"/>
                <field name="amount_untaxed_signed" string="Tax Excluded" sum="Total" optional="show"/>
                <field name="amount_tax_signed" string="Tax" sum="Total" optional="hide"/>
                <field name="amount_total_signed" string="Total" sum="Total" decoration-bf="1" optional="show"/>
                <field name="amount_residual_signed" string="Amount Due" sum="Amount Due" optional="hide"/>
                <field name="currency_id" invisible="1"/>
                <field name="company_currency_id" invisible="1"/>
                <field name="state" widget="badge" decoration-success="state == 'posted'" decoration-info="state == 'draft'" optional="show"/>
                <field name="move_type" invisible="context.get('default_move_type', True)"/>
            </tree>
        </field>
    </record>

</odoo>
