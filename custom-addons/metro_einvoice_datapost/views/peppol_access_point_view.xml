<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="pepple_access_point_sg_view" model="ir.ui.view">
        <field name="name">Peppol Access Point SG</field>
        <field name="model">peppol.access.point.sg</field>
        <field name="arch" type="xml">
            <form string="Peppol Access Point SG">
            <header>
               <button name="get_access_token" type="object" string="Get Token" class="oe_highlight"/>
               <button name="refresh_access_token" type="object" string="Refresh Token" class="oe_highlight"/>
            </header>
                <sheet>
                    <group>
                        <group>
                            <field name="endpoint"/>
                            <field name="api_version"/>
                        </group>
                        <group>
                            <field name="company_id"/>
                        </group>
                        <group string="Authorization">
                            <field name="api_key"/>
                            <field name="api_secret" password="True"/>
                        </group>
                        <group string="Tokens">
                            <field name="access_token" readonly="1" style="white-space: pre-wrap; word-wrap: break-word; max-width: 400px;"/>
                            <field name="refresh_token" readonly="1" style="white-space: pre-wrap; word-wrap: break-word; max-width: 400px;"/>
                        </group>
                    </group>
                    <field name="note" nolabel="1" placeholder="Extra Notes..."/>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="pepple_access_point_sg_tree_view" model="ir.ui.view">
        <field name="name">Peppol Access Point SG</field>
        <field name="model">peppol.access.point.sg</field>
        <field name="arch" type="xml">
            <tree string="Peppol Access Points" multi_edit="1" sample="1">
                <field name="company_id" />
                <field name="active" invisible="1"/>
                <field name="endpoint"/>
                <field name="api_key"/>
            </tree>
        </field>
    </record>

    <record id="action_pepple_access_point_sg_view" model="ir.actions.act_window">
        <field name="name">Peppol Access Point</field>
        <field name="res_model">peppol.access.point.sg</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="product.product_template_kanban_view"/>
    </record>

    <menuitem id="menu_peppole_access_point" parent="menu_peppol_configuration" action="action_pepple_access_point_sg_view" sequence="2"  name="Access Point" groups="metro_einvoice_datapost.group_peppol_admin"/>

</odoo>
