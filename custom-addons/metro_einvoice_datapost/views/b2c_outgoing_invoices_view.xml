<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_b2c_outgoing_invoices_form" model="ir.ui.view">
        <field name="name">b2c.outgoing.invoices.form</field>
        <field name="model">b2c.outgoing.invoices</field>
        <field name="arch" type="xml">
            <form string="POS/STI Outgoing Invoices" create="false" edit="false">
                <header>
                    <button name="action_send" type="object" string=" Send" icon="fa-paper-plane" states="ready_to_send"/>
                    <button name="action_retry" type="object" string=" Retry" states="error,Send Error" icon="fa-repeat"/>
                    <button name="action_reset" type="object" string=" Reset" states="error,cancelled" icon="fa-mail-reply"/>
                    <button name="action_cancel" type="object" string=" Cancel" states="ready_to_send,error,Send Error" icon="fa-times-circle" confirm="Are you sure you want to perform this action?"/>
                    <button name="action_check_status" type="object" string=" Check Document Status" icon="fa-refresh"  style="color: #005796;"/>
                    <field name="state" widget="statusbar" statusbar_visible="ready_to_send"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="receiver" readonly="1"/>
                            <field name="company_id" readonly="1"/>
                            <field name="tax_amount" readonly="1"/>
                            <field name="taxable_amount" readonly="1"/>
                            <field name="tax_inclusive_amount" readonly="1"/>
                        </group>
                        <group>
                            <field name="invoice_date"/>
                            <field name="uuid" readonly="1"/>
                            <field name="note"/>
                            <field name="currency_id" readonly="1"/>
                        </group>

                    </group>
                    <notebook>
                        <page string="Document Submission Evidence/Response">
                            <group>
                                <group string="IRAS Tracked Response">
                                    <field name="acknowledgement_id" readonly="1"/>
                                    <field name="transmission_id" readonly="1"/>
                                    <field name="status" readonly="1"/>
                                </group>
                                <group string="Extracted Info">
                                    <field name="sender_id" readonly="1"/>
                                    <field name="received" readonly="1" invisible="1"/>
                                </group>
                            </group>
                        </page>

                        <page string="Technical"  attrs="{'invisible': [('xml_data','=',False)]}" groups="base.group_erp_manager">
                            <separator string="XML Invoice Data" attrs="{'invisible': [('xml_data','=',False)]}"/>
<!--                            <button style="font-size: 80%;" name="action_copy" id="copy_response_id" string=" Copy to Clipboard" attrs="{'invisible': [('xml_data','=',False)]}" icon="fa-copy"/><br/>-->
                            <div id="response_id" style="overflow-x: auto;height: 200px;" attrs="{'invisible': [('xml_data','=',False)]}">
                                <field name="xml_data" nolabel="1" readonly="1"/>
                            </div>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_b2c_outgoing_invoices_tree" model="ir.ui.view">
        <field name="name">b2c.outgoing.invoices.tree</field>
        <field name="model">b2c.outgoing.invoices</field>
        <field name="arch" type="xml">
            <tree string="POS/STI Outgoing Invoices" create="false" decoration-danger="state in ['error','Send Error']" decoration-info="state == 'ready_to_send'" decoration-muted="state in ('Completed', 'cancelled')" decoration-success="state == 'Send Success'">
                <field name="name"/>
                <field name="company_id"/>
                <field name="partner_id"/>
                <field name="receiver"/>
                <field name="invoice_date"/>
                <field name="tax_amount"/>
                <field name="taxable_amount"/>
                <field name="tax_inclusive_amount"/>
                <field name="currency_id"/>
                <field name="create_date" string="Submission Date"/>
                <field name="status" string="IRAS Status"/>
                <field name="acknowledgement_id"/>
                <field name="transmission_id" string="IRAS Transmission UUID"/>
                <field name="uuid" optional="hide"/>
                <field name="state" decoration-bf="1"/>
            </tree>
        </field>
    </record>

    <record id="action_b2c_outgoing_invoices" model="ir.actions.act_window">
        <field name="name">POS/STI Outgoing Invoices</field>
        <field name="res_model">b2c.outgoing.invoices</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create New POS/STI Invoices
            </p>
        </field>

    </record>

    <menuitem id="menu_b2c_outgoing_invoices"
              parent="metro_einvoice_datapost.menu_non_peppol_documents"
              action="action_b2c_outgoing_invoices"
              sequence="3"
    />
</odoo>
