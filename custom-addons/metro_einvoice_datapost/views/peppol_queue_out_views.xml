<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="peppol_queue_out_form" model="ir.ui.view">
        <field name="name">peppol.queue.out.form</field>
        <field name="model">peppol.queue.out</field>
        <field name="arch" type="xml">
            <form string="PEPPOL Outgoing Document" create="false" edit="true">
                <script>
                    document.getElementById("copy_response_id").onclick = copyTextResponse;
                    function copyTextResponse(response_id) {
                        let element = document.getElementById("response_id");
                        let elementText = element.textContent;
                        copyText(elementText);
                    }
                    function copyText(text) {
                         navigator.clipboard.writeText(text);
                    }
                </script>
                <header>
                    <button name="action_send" type="object" string=" Send" states="ready_to_send" icon="fa-paper-plane"/>
                    <button name="action_retry" type="object" string=" Retry" states="error,Send Error" icon="fa-repeat"/>
                    <button name="action_reset" type="object" string=" Reset" states="error,cancelled" icon="fa-mail-reply"/>
                    <button name="action_cancel" type="object" string=" Cancel" states="ready_to_send,error,Send Error" icon="fa-times-circle" confirm="Are you sure you want to perform this action?"/>
                    <button name="action_check_status" type="object" string=" Check Document Status" icon="fa-refresh" states="Pending,Processing,Send Success" style="color: #005796;"/>
                    <field name="state" widget="statusbar" statusbar_visible="ready_to_send"/>
                </header>
<!--                 <div class="alert alert-info" role="alert" style="margin-bottom:0px;text-align: center;" attrs="{'invisible': ['|','|',('invalidated','=',False),('invalidated', '!=', 'yes'),('state','=','cancelled')]}">
                    This document became invalidated as the server has received with the same Document number again. Click on <button name="action_force_cancel" type="object" string="Cancel"/> to cancel this document.
                </div> -->
                <div class="alert alert-info" role="alert" style="margin-bottom:0px;text-align: center;" attrs="{'invisible': [('state','!=','error')]}">
                    The detailed description of the error is logged under the form.
                </div>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_invoice_response_queue_in" type="object" class="oe_stat_button" icon="fa-list" style="width:200px;">
                            <field string="Received Responses" name="received_inv_responses_count" class="o_stat_value" widget="statinfo"/>
                        </button>
                    </div>
                    <h1>
                        <field name="invoice_id" readonly="1"/>
                    </h1>
                    <group>
                        <group>                        
                            <field name="partner_id"/>
                            <field name="client_ref" attrs="{'invisible': [('client_ref','=',False)]}" readonly="1"/>
                            <field name="peppol_document_type"/>
                            <field name="invoice_type" invisible="1"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company" readonly="1"/>
                            <field name="create_date"/>
                            <field name="create_uid"/>
                            <field name="iras_status" string="Status" attrs="{'invisible': [('iras_status','=',False)]}" readonly="1"/>
                            <field name="status_message" readonly="1" string="Status" attrs="{'invisible': [('status_message','=',False)]}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Document Submission Evidence/Response" attrs="{'invisible': [('state','in',['ready_to_send','error','cancelled'])]}">
                            <group>
                                <group string="Document uploaded/received time">
                                    <field name="upload_time" readonly="1" string="Uploaded on (SGT)"/>
                                </group> 
                                <group string="Extracted Info">
                                    <field name="extracted_senderid" readonly="1"/>
                                    <field name="extracted_receiverid" readonly="1"/>
                                    <field name="extracted_docno" readonly="1"/>
                                    <field name="extracted_totamount" readonly="1"/>
                                </group>
                            </group>
                            <div id="content">
                                <group>
                                    <group string="Other">
                                        <field name="server_receipt" readonly="1"/>
                                        <field name="invalidated" readonly="1"/>                                
                                    </group>
                                    <group string="Response Status Received" attrs="{'invisible': [('response_status_code','=',False)]}">
                                        <field name="response_status_code" readonly="1"/>
                                    </group>                 
                                    <group string="Status Message" attrs="{'invisible': [('status_message','=',False)]}" invisible="1">
                                        <field name="status_message" readonly="1" string="Status"/>
                                    </group>    
                                    <group string="IRAS Tracked Responses">
                                        <field name="iras_acknowledgement_id" string="Acknowledgement ID" readonly="1"/>
                                        <field name="iras_transmission_id" string="Transmission ID" readonly="1"/>
                                        <field name="document_uuid" invisible="1"/>
                                        <field name="iras_status" string="Status" readonly="1"/>
                                    </group>                          
                                </group>
                            </div>
                        </page>
                        <page string="Documents Sent" attrs="{'invisible': [('state','in',['ready_to_send'])]}">
                            <group string="Internal Documents">
                                <group>
                                    <field name="attachment_ids" widget="many2many_binary" readonly="1"/>
                                </group>
                            </group>
                        </page>   
                        <page string="Technical" attrs="{'invisible': [('xml_data','=',False)]}" groups="base.group_erp_manager">
                            <separator string="XML Invoice Data" attrs="{'invisible': [('xml_data','=',False)]}"/>
                            <button style="font-size: 80%;" name="action_copy" id="copy_response_id" string=" Copy to Clipboard" attrs="{'invisible': [('xml_data','=',False)]}" icon="fa-copy"/><br/>
                            <div id="response_id" style="overflow-x: auto;height: 200px;" attrs="{'invisible': [('xml_data','=',False)]}">
                                <field name="xml_data" nolabel="1" readonly="1"/>
                            </div>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="peppol_queue_out_tree" model="ir.ui.view">
        <field name="name">peppol.queue.out.tree</field>
        <field name="model">peppol.queue.out</field>
        <field name="arch" type="xml">
            <tree string="PEPPOL Outgoing Documents" create="false" edit="false"
                  decoration-danger="state in ['error','Send Error']" decoration-info="state == 'ready_to_send'" decoration-muted="state in ('Completed', 'cancelled')" decoration-success="state == 'Send Success'" >
                <field name="name"/>
                <field name="invoice_type" invisible="1"/>
                <field name="partner_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="create_date"/>
                <field name="create_uid"/>
                <field name="iras_status" string="IRAS Status"/>
                <field name="iras_acknowledgement_id"/>
                <field name="iras_transmission_id" string="IRAS Transmission UUID"/>
                <field name="document_uuid" optional="hide"/>
                <field name="state" decoration-bf="1"/>
                <button class="oe_inline oe_stat_button" type="object" icon="fa-paper-plane" string="Send" name="action_send" attrs="{'invisible':[('state','!=','ready_to_send')]}"/>
                <button name="action_retry" type="object" string="Retry" states="error,Send Error" icon="fa-repeat"/>
                <button name="action_reset" type="object" string=" Reset" states="error,cancelled" icon="fa-mail-reply"/>            
                <button name="action_cancel" type="object" string="Cancel" states="ready_to_send,error,Send Error" icon="fa-times-circle" confirm="Don't send this document to PEPPOL?"/>
                <button name="action_check_status" type="object" string=" Check Document Status" icon="fa-refresh" states="Pending,Processing,Send Success"/>
            </tree>
        </field>
    </record>

    <record id="peppol_queue_out_search" model="ir.ui.view">
        <field name="name">peppol.queue.out.search</field>
        <field name="model">peppol.queue.out</field>
        <field name="arch" type="xml">
            <search string="PEPPOL Outgoing Documents">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="invoice_type" invisible="1"/>
                <field name="state"/>
                <separator/>
                <filter string="Ready to Send" name="filter_state_readytosend" domain="[('state', '=', 'ready_to_send')]"/>
                <filter string="Pending" name="filter_state_pending" domain="[('state', '=', 'Pending')]"/>
                <filter string="Processing" name="filter_state_processing" domain="[('state', '=', 'Processing')]"/>
                <filter string="Send Success" name="filter_state_sendsuccess" domain="[('state', '=', 'Send Success')]"/>
                <filter string="Send Error" name="filter_state_senderror" domain="[('state', '=', 'Send Error')]"/>
                <filter string="Failed" name="filter_state_error" domain="[('state', '=', 'error')]"/>
                <filter string="Cancelled" name="filter_state_cancelled" domain="[('state', '=', 'cancelled')]"/>
                <separator/>
                <filter string="Invoices" name="out_invoice" domain="[('invoice_type','=','out_invoice')]" />
                <filter string="Credit Notes" name="out_refund" domain="[('invoice_type','=','out_refund')]" />
                <separator/>
                <group expand="1" string="Group By">
                    <filter string="Status" name="state" context="{'group_by':'state'}"/>
                    <filter string="Customer" name="partner_id" context="{'group_by':'partner_id'}"/>
                    <filter string="Company" name="company_id" context="{'group_by':'company_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="peppol_queue_out_action" model="ir.actions.act_window">
        <field name="name">Outgoing Invoices</field>
        <field name="res_model">peppol.queue.out</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">['|', ('invoice_type','=','out_invoice'),('invoice_type','=','out_refund')]</field>
        <field name="context">{'search_default_filter_state_readytosend': 1}</field>
        <field name="help" type="html">
          <p class="o_view_nocontent_neutral_face">
            No Documents found.
          </p>
        </field>
        <field name="search_view_id" ref="metro_einvoice_datapost.peppol_queue_out_search"/>
    </record>

    <menuitem id="peppol_queue_out_menu"
        action="peppol_queue_out_action"
        parent="menu_peppol_documents"
        sequence="2"/>

    <record id="peppol_credit_queue_out_action" model="ir.actions.act_window">
        <field name="name">Outgoing Credit Notes</field>
        <field name="res_model">peppol.queue.out</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('invoice_type','=','out_refund')]</field>
        <field name="context">{'search_default_filter_state_readytosend': 1}</field>
        <field name="help" type="html">
          <p class="o_view_nocontent_neutral_face">
            No Documents found.
          </p>
        </field>
        <field name="search_view_id" ref="metro_einvoice_datapost.peppol_queue_out_search"/>
    </record>

<!--     <menuitem id="peppol_credit_queue_out_menu"
        action="peppol_credit_queue_out_action"
        parent="menu_peppol_credit_documents"
        sequence="2"/> -->

    <record id="peppol_queue_out_send_action" model="ir.actions.server">
        <field name="name">Send</field>
        <field name="model_id" ref="metro_einvoice_datapost.model_peppol_queue_out"/>
        <field name="binding_model_id" ref="metro_einvoice_datapost.model_peppol_queue_out"/>
        <field name="state">code</field>
        <field name="code">action = records.action_send()</field>
    </record>

    <record id="peppol_queue_out_confirm_action" model="ir.actions.server">
        <field name="name">Check Document status</field>
        <field name="model_id" ref="metro_einvoice_datapost.model_peppol_queue_out"/>
        <field name="binding_model_id" ref="metro_einvoice_datapost.model_peppol_queue_out"/>
        <field name="state">code</field>
        <field name="code">action = records.action_check_status()</field>
    </record>

    <record id="peppol_queue_out_retry_action" model="ir.actions.server">
        <field name="name">Retry</field>
        <field name="model_id" ref="metro_einvoice_datapost.model_peppol_queue_out"/>
        <field name="binding_model_id" ref="metro_einvoice_datapost.model_peppol_queue_out"/>
        <field name="state">code</field>
        <field name="code">action = records.action_retry()</field>
    </record>

    <record id="peppol_queue_out_cancel_action" model="ir.actions.server">
        <field name="name">Cancel</field>
        <field name="model_id" ref="metro_einvoice_datapost.model_peppol_queue_out"/>
        <field name="binding_model_id" ref="metro_einvoice_datapost.model_peppol_queue_out"/>
        <field name="state">code</field>
        <field name="code">action = records.action_cancel()</field>
    </record>
</odoo>
