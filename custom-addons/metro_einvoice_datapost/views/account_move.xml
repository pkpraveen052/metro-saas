<?xml version="1.0" encoding="utf-8"?>

<odoo>

    <record id="peppol_sg_move_form" model="ir.ui.view">
        <field name="name">metro_einvoice_datapost.account.move.form</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <button name="open_reconcile_view" position="after">
                <button invisible="1"
                    name="generate_ubl_report"
                    class="oe_stat_button"
                    type="object"
                    help="Generate UBL.">
                    <span style="padding-right: 3px;">
                        <img width="32" height="32" alt="PEPPOL"/><!-- src="/metro_einvoice_datapost/static/description/peppol.png" -->
                    </span>
                    <span>
                        Generate UBL
                    </span>
                </button>
            </button>
            <xpath expr="//field[@name='name']" position='before'>
                <div class="ribbon ribbon-top-right" style="margin-top:-53px;" attrs="{'invisible': [('peppol_document_type', '=', 'nonpeppol')]}">
                    <span style="font-size: 12px;height:45px;width:365px;text-indent:-94px;padding:24px 44px;" class="bg-info">Peppol</span>
                </div>
                <div class="ribbon ribbon-top-right" style="margin-top:-53px;" attrs="{'invisible': [('peppol_document_type', '=', 'peppol')]}">
                     <span style="font-size:11px;width:510px;left:-130px;top:4px;text-align:center;" class="bg-info">NONPEPPOL</span>
<!--                    <span style="font-size: 12px;height:45px;width:365px;text-indent:-94px;padding:24px 44px;" class="bg-info">NonPeppol</span>-->
                </div>
            </xpath>
            <!-- <xpath expr="//page[@id='other_tab_entry']" position="after">
                <page string="Peppol Info" attrs="{'invisible': [('move_type', 'in', ('out_invoice'))]}">
                    <group string="Peppol" name="accounting_peppol">
                        <group>
                            <field name="peppol_invoice_no" string="Invoice Number"/>
                        </group>
                        <group>
                            <field name="peppol_invoice_doc_ids" widget="many2many_binary" readonly="1"/>
                        </group>
                    </group>
                </page>
            </xpath> -->
            <xpath expr="//group[@name='accounting_info_group']" position="after">
              <group string="Outgoing Invoice Queue" attrs="{'invisible': [('move_type', 'not in', ('out_invoice','out_refund','in_invoice','in_refund')), ('document_type', '=', True)]}">
                  <field name="outgoing_inv_doc_ref"  readonly="1" attrs="{'invisible': [('outgoing_inv_doc_ref','=',False)]}"/>
                  <field name="outgoing_inv_doc_ref_c5" readonly="1" attrs="{'invisible': [('outgoing_inv_doc_ref_c5','=',False)]}"/>
                  <field name="b2c_outgoing_inv_doc_ref" readonly="1" attrs="{'invisible': [('b2c_outgoing_inv_doc_ref','=',False)]}"/>
                  <field name="pcp_outgoing_inv_doc_ref" readonly="1" attrs="{'invisible': [('pcp_outgoing_inv_doc_ref','=',False)]}"/>
                  <field name="peppol_document_type" invisible="1"/>
              </group>
                <group string="Flipped Data" attrs="{'invisible': [('move_type', 'not in', ('out_invoice','out_refund','in_invoice','in_refund'))]}">
                    <field name="document_type" invisible="1"/>
                    <field name="sale_order_id"  readonly="1" attrs="{'invisible': [('sale_order_id','=',False)]}"/>
                    <field name="note" readonly="1" attrs="{'invisible': [('note','=',False)]}"/>
                    <field name="business_unit_id"/>
                    <field name="order_ref"/>
              </group>
            </xpath>
            <xpath expr="//button[@name='action_invoice_sent']" position="after">
              <button name="action_send_via_peppol" type="object" string="Send to InvoiceNow" groups="metro_einvoice_datapost.group_peppol_submitter" attrs="{'invisible':['|', '|', '|', '|', '|', ('state', '!=', 'posted'), ('move_type', 'not in', ('out_invoice','out_refund','in_invoice','in_refund')),('outgoing_inv_doc_ref','!=',False),('outgoing_inv_doc_ref_c5','!=',False),('b2c_outgoing_inv_doc_ref','!=',False),('pcp_outgoing_inv_doc_ref','!=',False)]}" class="oe_highlight"/>
              <button name="action_send_via_peppol" type="object" string="Send to GST InvoiceNow" groups="metro_einvoice_datapost.group_c5_submitter" attrs="{'invisible':['|', '|', '|', '|','|', ('state', '!=', 'posted'), ('move_type', 'not in', ('out_invoice','out_refund','in_invoice','in_refund')),('outgoing_inv_doc_ref','!=',False),('outgoing_inv_doc_ref_c5','!=',False),('b2c_outgoing_inv_doc_ref','!=',False),('pcp_outgoing_inv_doc_ref','!=',False)]}" class="oe_highlight"/>
            </xpath>
            <xpath expr="//field[@name='partner_shipping_id']" position="after">
                <field name="customer_contact_person" readonly="1" invisible="1"/>
                <field name="vendor_id" readonly="1" invisible="1"/>
                <field name="vendor_identification" readonly="1" invisible="1"/>
                <field name="supplier_email_address" widget="email" readonly="1" invisible="1"/>
            </xpath>
             <xpath expr="//form//field[@name='invoice_line_ids']//tree//field[@name='product_id']" position="before">
                <field name="line_item_id" readonly="1" optional="hide"/>
            </xpath>

<!--             <xpath expr="//button[@name='action_invoice_sent']" position="after">-->
<!--              <button name="action_send_via_peppol_c5" type="object" string="Send to InvoiceNow" attrs="{'invisible':['|',('state', '!=', 'posted'), ('move_type', 'not in', ('in_invoice','in_refund'))]}" class="oe_highlight"/>-->
<!--            </xpath>-->
        </field>
    </record>

    <record id="invoice_tree_view_inherit" model="ir.ui.view">
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_invoice_tree" />
        <field name="arch" type="xml">
            <field name="payment_state" position="after">
                <field name="peppol_document_type" optional="hide"/>
                <field name="peppol_state" optional="hide" widget="badge"/>
            </field>
        </field>
    </record>

    <record model="ir.actions.server" id="action_move_peppol_send">
        <field name="name">Send to InvoiceNow</field>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="groups_id" eval="[(6, 0, [ref('metro_einvoice_datapost.group_peppol_submitter')])]"/>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="state">code</field>
        <field name="code">
    if records:
        action = records._peppol_action_manual_send()
        </field>
    </record>

    <record model="ir.actions.server" id="action_move_peppol_send_to_gstinvoicenow">
        <field name="name">Send to GST InvoiceNow</field>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="groups_id" eval="[(6, 0, [ref('metro_einvoice_datapost.group_c5_submitter')])]"/>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="state">code</field>
        <field name="code">
    if records:
        action = records._peppol_action_manual_send()
        </field>
    </record>

    <record id="peppol_account_invoice_filter" model="ir.ui.view">
        <field name="name">peppol.account.invoice.filter</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_account_invoice_filter"/>
        <field name="arch" type="xml">
            <filter name="activities_upcoming_all" position="after">
                <separator/>
                <!-- <filter name="e-Invoices" domain="[('outgoing_inv_doc_ref','!=',False)]"/> -->
                <filter name="invoices_sent" string="Sent to InvoiceNow"
                        domain="['|', '|', '|', ('outgoing_inv_doc_ref.state','in',['Send Success','Completed']), ('outgoing_inv_doc_ref_c5.state','in',['Send Success','Completed']), ('b2c_outgoing_inv_doc_ref.state','in',['Send Success','Completed']),
                ('pcp_outgoing_inv_doc_ref.state','in',['Send Success','Completed'])]"
                groups="metro_einvoice_datapost.group_peppol_submitter"/>
                <filter name="invoices_pending" string="Pending to InvoiceNow"
                        domain="[('state','=','posted'), ('outgoing_inv_doc_ref','=',False),
                        ('outgoing_inv_doc_ref_c5','=',False), ('b2c_outgoing_inv_doc_ref','=',False),('pcp_outgoing_inv_doc_ref','=',False)]"
                groups="metro_einvoice_datapost.group_peppol_submitter"/>
                <filter name="invoices_failed" string="Failed to InvoiceNow" domain="['|', '|', '|', ('outgoing_inv_doc_ref.state','in',['error','Send Error']), ('outgoing_inv_doc_ref_c5.state','in',['error','Send Error']), ('b2c_outgoing_inv_doc_ref.state','in',['error','Send Error']),
                ('pcp_outgoing_inv_doc_ref.state','in',['error','Send Error'])]" groups="metro_einvoice_datapost.group_peppol_submitter"/>

                <filter name="invoices_sent" string="Sent to GST InvoiceNow" groups="metro_einvoice_datapost.group_c5_submitter" domain="['|', '|', '|', ('outgoing_inv_doc_ref.state','in',['Send Success','Completed']), ('outgoing_inv_doc_ref_c5.state','in',['Send Success','Completed']), ('b2c_outgoing_inv_doc_ref.state','in',['Send Success','Completed']),
                ('pcp_outgoing_inv_doc_ref.state','in',['Send Success','Completed'])]"/>
                <filter name="invoices_pending" string="Pending to GST InvoiceNow" groups="metro_einvoice_datapost.group_c5_submitter" domain="[('state','=','posted'), ('outgoing_inv_doc_ref','=',False), ('outgoing_inv_doc_ref_c5','=',False), ('b2c_outgoing_inv_doc_ref','=',False),('pcp_outgoing_inv_doc_ref','=',False)]"/>
                <filter name="invoices_failed" string="Failed to GST InvoiceNow" groups="metro_einvoice_datapost.group_c5_submitter" domain="['|', '|', '|', ('outgoing_inv_doc_ref.state','in',['error','Send Error']), ('outgoing_inv_doc_ref_c5.state','in',['error','Send Error']), ('b2c_outgoing_inv_doc_ref.state','in',['error','Send Error']),
                ('pcp_outgoing_inv_doc_ref.state','in',['error','Send Error'])]"/>
            </filter>
        </field>
    </record>

    <record id="view_pepppol_in_invoice_tree_view" model="ir.ui.view">
        <field name="name">account.move.tree.view</field>
        <field name="model">account.move</field>
        <field name="arch" type="xml">
            <tree string="Invoices" js_class="account_tree" sample="1" decoration-info="state == 'draft'" decoration-muted="state == 'cancel'">
                <button name="map_to_incoming_invoice" type="object" string="Map" class="oe_highlight"/>
                <field name="name" decoration-bf="1"/>
                <field name="partner_id" invisible="1"/>
                <field name="invoice_source_email" invisible="1"/>
                <field name="invoice_partner_display_name" invisible="context.get('default_move_type') not in ('in_invoice', 'in_refund','in_receipt')" groups="base.group_user" string="Vendor"/>
                <field name="invoice_partner_display_name" invisible="context.get('default_move_type') not in ('out_invoice', 'out_refund','out_receipt')" groups="base.group_user" string="Customer"/>
                <field name="invoice_date" optional="show" invisible="context.get('default_move_type') not in ('in_invoice', 'in_refund','in_receipt')" string="Bill Date"/>
                <field name="invoice_date" optional="show" invisible="context.get('default_move_type') not in ('out_invoice', 'out_refund','out_receipt')" string="Invoice Date"/>
                <field name="invoice_date_due" widget="remaining_days" optional="show"/>
                <field name="invoice_origin" optional="hide" string="Source Document"/>
                <field name="payment_reference" optional="hide" invisible="context.get('default_move_type') in ('out_invoice', 'out_refund','out_receipt')"/>
                <field name="ref" optional="hide"/>
                <field name="invoice_user_id" optional="hide" invisible="context.get('default_move_type') not in ('out_invoice', 'out_refund','out_receipt')" string="Sales Person" widget="many2one_avatar_user"/>
                <field name="activity_ids" widget="list_activity" optional="show"/>
                <field name="company_id" options="{'no_create': True}" optional="show"/>
                <field name="amount_untaxed_signed" string="Tax Excluded" sum="Total" optional="show"/>
                <field name="amount_tax_signed" string="Tax" sum="Total" optional="hide"/>
                <field name="amount_total_signed" string="Total" sum="Total" decoration-bf="1" optional="show"/>
                <field name="amount_residual_signed" string="Amount Due" sum="Amount Due" optional="hide"/>
                <field name="currency_id" invisible="1"/>
                <field name="company_currency_id" invisible="1"/>
                <field name="state" widget="badge" decoration-success="state == 'posted'" decoration-info="state == 'draft'" optional="show"/>
                <field name="move_type" invisible="context.get('default_move_type', True)"/>
            </tree>
        </field>
    </record>

    <record id="inherit_view_send_money_form" model="ir.ui.view">
        <field name="model">account.move</field>
        <field name="inherit_id" ref="metroerp_send_receive_money.view_move_send_money_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form//notebook//page[@id='aml_tab']" position="after">
                <page name="other_info" string="Info">
                    <group name="c5_invoice_sent" string="Outgoing Invoice Queue">
                      <field name="outgoing_inv_doc_ref_c5" readonly="1"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="inherit_view_send_money_tree" model="ir.ui.view">
        <field name="model">account.move</field>
        <field name="inherit_id" ref="metroerp_send_receive_money.view_send_money_tree"/>
        <field name="arch" type="xml">
            <field name="payment_state" position="after">
                <field name="peppol_document_type" optional="hide"/>
                <field name="peppol_state" optional="hide" widget="badge"/>
            </field>
        </field>
    </record>

</odoo>
