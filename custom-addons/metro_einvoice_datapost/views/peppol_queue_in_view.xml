<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="pepppol_log_sg_view" model="ir.ui.view">
        <field name="name">pepppol.queue.in.view</field>
        <field name="model">peppol.queue.in</field>
        <field name="arch" type="xml">
            <form string="Incoming Invoice Document" create="false" edit="false" delete="true">
                <script>
                    document.getElementById("copy_response_id").onclick = copyTextResponse;
                    function copyTextResponse(response_id) {
                        let element = document.getElementById("response_id");
                        let elementText = element.textContent;
                        copyText(elementText);
                    }
                    document.getElementById("copy_exception_id").onclick = copyTextException;
                    function copyTextException(exception_id) {
                        let element = document.getElementById("exception_id");
                        let elementText = element.textContent;
                        copyText(elementText);
                    }
                    function copyText(text) {
                         navigator.clipboard.writeText(text);
                    }

                    document.getElementById("suggestion_id").onclick = displayMenus;
                    function displayMenus() {
                    document.getElementById("suggestion_id").style.visibility = "hidden";
                    setTimeout(function(){document.getElementById("create").innerHTML = 'Create a Record';}, 1000);
                    setTimeout(function(){document.getElementById("list").innerHTML = 'Verify in the List';}, 1500);
                }
                </script>
                <header>
                    <button name="action_retry" icon="fa-repeat" type="object" string="Retry" attrs="{'invisible': [('state', '!=','error')]}"/>                
                    <!-- <button name="action_view_invoice_bill" type="object" string="Inspect &amp; Match Bill" class="oe_highlight"/> -->
                    <button name="action_view_orders" type="object" string="View &amp; Map PO" class="oe_highlight" 
                            attrs="{'invisible': ['|',('convert_to_purchase_invoice_bill', '!=', 'PO'),('state','!=','sent_to_process')]}"/>
                    <button name="action_invoice_response_out" string=" Send a Response" type="object" icon="fa-mail-reply-all" help="Send Invoice Response"/>
                    <button name="action_cancel" icon="fa-times" type="object" string="Cancel" attrs="{'invisible': [('state', '=','cancelled')]}"/>
                    <button name="action_convert_to_purchase_invoice" type="object" string="Convert to Purchase Invoice"
                            attrs="{'invisible': [('convert_to_purchase_invoice_bill', '!=', 'Direct')]}"/>              
                    <field name="state" widget="statusbar" options="{'fold_field': 'fold'}" statusbar_visible="received"/>
                </header>
                <div class="alert alert-info" role="alert" style="margin-bottom:0px;text-align: center;" attrs="{'invisible': [('gst_no','=',False)]}">
                    GST should not be charged as <field name="gst_no" readonly="1" nolabel="1"/> is not GST-registered.
                </div>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_invoice_response_queue_out" type="object" class="oe_stat_button" icon="fa-list" style="width:200px;">
                            <field string="Sent Responses" name="sent_inv_responses_count" class="o_stat_value" widget="statinfo"/>
                        </button>
                    </div>
                    <div class="oe_title" attrs="{'invisible': [('invoice_no','=',False)]}">
                        <span class="o_form_label">Invoice Ref</span>
                        <h1>
                            <field name="invoice_no" readonly="1"/>
                            <field name="gst_no" invisible="0"/>
                        </h1>
                    </div>
                    <div attrs="{'invisible': [('state','not in',['received','error'])]}">
                        <group>
                            <group>
                                <field name="extracted_docno"/>
                                <field name="extracted_totamount"/>

                            </group>
                            <group>                    
                                <field name="invalidated" attrs="{'invisible': [('invalidated', '=', False)]}"/>
                                <field name="instance_id" attrs="{'invisible': [('instance_id', '=', False)]}"/>
                                <field name="client_ref" attrs="{'invisible': [('instance_id', '=', False)]}"/>
                                <field name="iras_status" attrs="{'invisible': [('iras_status', '=', False)]}"/>
                                <field name="iras_statusinfo" attrs="{'invisible': [('iras_statusinfo', '=', False)]}"/>
                                <field name="status_message" attrs="{'invisible': [('status_message', '=', False)]}"/>
                            </group>
                        </group>
                    </div>
                    <div attrs="{'invisible': [('state','=','received')]}">
                        <group name="grp_main">
                            <group name="grp_left" attrs="{'invisible': [('po_id','=',False)]}">
                              <field name="po_id"/>
                            </group>
                            <group name="grp_right">
                                <field name="error_type" invisible="1"/>
                            </group>
                            <group name="grp_right" invisible="1">
                              <button style="margin-top:25px;padding:4px;padding-left:20px;padding-right:20px;background:blue;font-weight: bold;color:white;border:0"
                                      name="action_suggestion" id="suggestion_id" string="Suggestions"/><br/>
                              <button id="create" name="action_create_record" type="object" style="margin-top:5px;border:0;color:blue;text-decoration: underline;"/><br/>
                              <button id="list" name="action_verify_list" type="object" style="margin-top:1px;border:0;color:blue;text-decoration: underline;"/>
                            </group>
                        </group>
                        <group>
                            <group string="Supplier/Vendor" attrs="{'invisible': [('state', '=','error')]}">
                                <field name="sender_party_name"/>
                                <label for="sender_address_line1" string="Address"/>
                                <div class="o_address_format">
                                    <field name="sender_address_line1" class="o_address_street"/>
                                    <field name="sender_address_line2" class="o_address_street"/>
                                    <field name="sender_address_city" class="o_address_city"/>
                                    <field name="sender_address_county" class="o_address_county"/>
                                    <field name="sender_address_zip" class="o_address_zip"/>
                                    <field name="sender_address_country" class="o_address_country"/>
                                </div>
                                <field name="uen_no" placeholder="e.g. 53201802A"/>
                                <field name="gst_no"/>
                                <field name="is_gst_register"/>
                                <field name="registration_status"/>
                                <label for="sender_contact_name" string="Contact"/>
                                <div class="o_address_format">
                                    <field name="sender_contact_name" class="o_address_street"/>
                                    <field name="sender_contact_phone" class="o_address_street"/>
                                    <field name="sender_contact_email" class="o_address_street"/>
                                </div>
                            </group>
                            <group string="">
                                <separator/><separator/><br/>
                                <field name="create_date" string="Created On"/>
                                <field name="issue_date" attrs="{'invisible': [('state', '=','error')]}"/>
                                <field name="due_date" attrs="{'invisible': [('state', '=','error')]}"/>
                                <field name="tax_point_date" attrs="{'invisible':[('tax_point_date','=',False)]}"/>
                                <field name="document_currency_code" attrs="{'invisible': [('state', '=','error')]}"/>
                                <field name="buyer_reference" attrs="{'invisible': [('state', '=','error')]}"/>
                                <field name="order_reference" attrs="{'invisible': ['|',('state', '=','error'),('order_reference','=',False)]}"/>
                                <field name="currency_id" invisible="1"/>
                                <field name="doc_type" invisible="1"/>
                                <field name="convert_to_purchase_invoice_bill" invisible="1"/>
                            </group>
                            <group string="Sender's GST/TAX Details" attrs="{'invisible': [('state', '=','error')]}">
                                <field name="sender_party_tax_scheme_companyid" string="Tax Registration ID"/>
                                <field name="sender_party_tax_scheme_id" string="ID"/>
                            </group>
                            <group>
                                <separator/><separator/><br/>
                                <field name="extracted_senderid" string="Sender Peppol ID"/>
                                <field name="extracted_receiverid" string="Receiver Peppol ID"/>
                            </group>
                            <group string="Payment Terms" attrs="{'invisible': ['|',('state', '=','error'),('payment_terms','=',False)]}">
                                <field name="payment_terms"/>
                            </group>
                            <group string="Payment Means" attrs="{'invisible': ['|',('state', '=','error'),('payment_means','=',False)]}">
                                <field name="payment_means" nolabel="1" style="overflow-x: auto;"/>
                            </group>
                            <group string="Invoice Period" attrs="{'invisible': ['|','&amp;',('state', '=','error'),('period_start','=',False),('period_end','=',False),]}">
                                <field name="period_start" attrs="{'invisible': [('period_start','=',False)]}"/>
                                <field name="period_end" attrs="{'invisible': [('period_end','=',False)]}"/>
                            </group>
                        </group>
                        <separator string="Detailed Information"/>
                        <field name="message" nolabel="1" decoration-success="state=='success'"/>
                        <notebook>
                            <page string="Invoice Lines" attrs="{'invisible': [('state', '=','error')]}">
                                <field name="invoice_line_ids">
                                    <tree>
                                        <field name="name"/>
                                        <field name="description"/>
                                        <field name="quantity"/>
                                        <field name="price_amount"/>
                                        <field name="allowance_charges" string="Discount"/>
                                        <field name="tax_type"/>
                                        <field name="tax_percentage"/>
                                        <field name="tax_category_code"/>
                                        <field name="amount_excluding_tax" string="Amount (Exclu. Tax)"/>
                                    </tree>
                                </field>
                                <group class="oe_subtotal_footer oe_right">
                                    <field name="amt_untaxed" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="taxed_amt" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="discount_amt" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <div class="oe_subtotal_footer_separator oe_inline">
                                        <label for="amt_including_tax" string="Total(Inc. tax)"/>
                                    </div>
                                    <field name="amt_including_tax" nolabel="1" class="oe_subtotal_footer_separator" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                </group>
                            </page>
                            <page string="Other Info" attrs="{'invisible': [('state', '=','error')]}">
                                <group>
                                    <group string="Receiver Details">
                                        <field name="company_id"/>
                                    </group>
                                    <group string="Additional Documents">
                                        <field name="document_ids" widget="many2many_binary"/>
                                    </group>
                                </group>
                            </page>
                            <page string="Technical">
                                <separator string="Error Exception" attrs="{'invisible': [('error_exception','=',False)]}"/>
                                <button style="font-size: 80%;" name="action_copy" id="copy_exception_id" string=" Copy to Clipboard" attrs="{'invisible': [('error_exception','=',False)]}" icon="fa-copy"/><br/>
                                <div id="exception_id" style="overflow-x: auto;height: 200px;" attrs="{'invisible': [('error_exception','=',False)]}">
                                    <field name="error_exception" nolabel="1"/>
                                </div>
                                <separator string="XML Invoice Data" attrs="{'invisible': [('xml_data','=',False)]}"/>
                                <button style="font-size: 80%;" name="action_copy" id="copy_response_id" string=" Copy to Clipboard" attrs="{'invisible': [('xml_data','=',False)]}" icon="fa-copy"/><br/>
                                <div id="response_id" style="overflow-x: auto;height: 200px;" attrs="{'invisible': [('xml_data','=',False)]}">
                                    <field name="xml_data" nolabel="1"/>
                                </div>                            
                            </page>
                        </notebook>
                        <group>
                            <label for="note" attrs="{'invisible': [('note','=',False)]}"/>
                            <field name="note" readonly="1" nolabel="1"/>
                        </group>
                    </div>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>


    <record id="pepppol_log_sg_tree_view" model="ir.ui.view">
        <field name="name">pepppol.queue.in.tree.view</field>
        <field name="model">peppol.queue.in</field>
        <field name="arch" type="xml">
            <tree string="Incoming Invoice Documents" decoration-danger="state=='error'" decoration-success="state=='success'" decoration-info="state=='sent_to_process'" create="false" edit="true">
                <field name="invoice_no" string="Invoice Ref"/>
                <field name="sender_party_name"/>
                <field name="issue_date"/>
                <field name="due_date"/>
                <field name="create_date"/>              
                <field name="currency_id" invisible="1"/>
                <field name="order_reference" optional="hide"/>
                <field name="extracted_senderid" optional="hide"/>
                <field name="extracted_receiverid" optional="hide"/>
                <field name="amt_untaxed" optional="show" widget="monetary" options="{'currency_field': 'currency_id'}" string="Tax Excluded"/> 
                <field name="amt_including_tax" widget="monetary" options="{'currency_field': 'currency_id'}"/>              
                <field name="discount_amt" optional="hide" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="taxed_amt" optional="hide" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="state" decoration-bf="1"/>  
                <button name="action_retry" type="object" icon="fa-repeat" string="Retry" attrs="{'invisible': [('state', '!=','error')]}"/>
                <button name="action_invoice_response_out" type="object" icon="fa-mail-reply-all" attrs="{'invisible': [('state', '=','cancelled')]}" help="Send Invoice Response"/>
            </tree>
        </field>
    </record>

    <record model="ir.ui.view" id="peppol_search_view">
        <field name="name">peppol.queue.in.search.view</field>
        <field name="model">peppol.queue.in</field>
        <field name="arch" type="xml">
            <search string="Incoming Invoice Documents">
                <field name="invoice_no"/>
                <field name="sender_party_name"/>
                <field name="state"/>
                <field name="company_id"/>
                <separator/>
                <filter string="Success" name="Mapped" domain="[('state', '=', 'success')]"/>
                <filter string="Unmapped" name="sent_to_process" domain="[('state', '=', 'sent_to_process')]"/>
                <filter string="Failed" name="Failed" domain="[('state', '=', 'error')]"/>
                <filter string="Cancelled" name="cancelled" domain="[('state', '=', 'cancelled')]"/>
                <group expand="0" string="Group By">
                    <filter string="Vendor" name="sender" domain="[]" context="{'group_by': 'sender_party_name'}"/>
                    <filter string="Status" name="status" domain="[]" context="{'group_by': 'state'}"/>
                    <filter string="Issue Date" name="issuedate" domain="[]" context="{'group_by': 'issue_date'}" help="Issue Date"/>
                    <filter string="Due Date" name="duedate" domain="[]" context="{'group_by': 'due_date'}" help="Due Date"/>
                    <filter string="Company" name="company" domain="[]" context="{'group_by': 'company_id'}" groups="base.group_multi_company"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_pepppol_log_sg_view" model="ir.actions.act_window">
        <field name="name">Incoming Invoices</field>
        <field name="res_model">peppol.queue.in</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="peppol_search_view"/>
        <field name="domain">[('doc_type','in',['invoices','credit-notes'])]</field>
        <field name="help" type="html">
          <p class="o_view_nocontent_neutral_face">
            No Documents found.
          </p>
        </field>
    </record>

    <menuitem id="menu_sub_peppol_log"
        parent="menu_peppol_documents"
        action="action_pepppol_log_sg_view"
        sequence="1"/>

    <record id="action_pepppol_log_sg_view2" model="ir.actions.act_window">
        <field name="name">Incoming Credit Notes</field>
        <field name="res_model">peppol.queue.in</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="peppol_search_view"/>
        <field name="domain">[('doc_type','=','credit-notes')]</field>
        <field name="help" type="html">
          <p class="o_view_nocontent_neutral_face">
            No Documents found.
          </p>
        </field>
    </record>

<!--     <menuitem id="menu_sub_peppol_log2"
        parent="menu_peppol_credit_documents"
        action="action_pepppol_log_sg_view2"
        sequence="1"/> -->

</odoo>
