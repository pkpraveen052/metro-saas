<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- (Invoices, Credit notes) :: Outgoing Documents -->
        <record id="ir_cron_peppol_document_send_confirm" model="ir.cron">
            <field name="name">PEPPOL: Send Invoices &amp; Credit Notes and Check Document status</field>
            <field name="interval_number">30</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="model_id" ref="model_peppol_queue_out"/>
            <field name="code">model._cron_process_documents()</field>
            <field name="state">code</field>
        </record>

        <!-- (Invoices, Credit notes) :: Incoming Documents -->
        <record id="webhooks_event_notification" model="ir.cron">
