        <record id="ir_cron_update_c5_status" model="ir.cron">
            <field name="name">Update C5 Activation Status</field>
            <field name="model_id" ref="model_c5_activation"/>
            <field name="state">code</field>
            <field name="code">model.cron_update_c5_status()</field>
            <field name="interval_type">minutes</field>
            <field name="interval_number">5</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>

        <record id="ir_cron_refresh_access_token" model="ir.cron">
            <field name="name">Refresh Peppol Access Token</field>
            <field name="model_id" ref="model_peppol_access_point_sg"/>
            <field name="state">code</field>
            <field name="code">model.cron_refresh_access_token()</field>
            <field name="interval_type">minutes</field>
            <field name="interval_number">30</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>

        <record id="ir_cron_check_gst_register" model="ir.cron">
            <field name="name">Partner - Check GST Register</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="state">code</field>
            <field name="code">model.cron_auto_check_gst_register()</field>
            <field name="interval_type">days</field>
            <field name="interval_number">1</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>

<!--        C5: Send Invoices or Credit Notes and Check Document status-->
