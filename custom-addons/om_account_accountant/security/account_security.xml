<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="group_fiscal_year" model="res.groups">
            <field name="name">Allow to define fiscal years of more or less than a year</field>
            <field name="category_id" ref="base.module_category_hidden"/>
        </record>

        <record id="base.module_category_accounting_accounting" model="ir.module.category">
            <field name="name">Accounting</field>
        </record>

        <record id="account.group_account_user" model="res.groups">
            <field name="category_id" ref="base.module_category_accounting_accounting" />
            <field name="implied_ids" eval="[(4, ref('account.group_account_invoice'))]" />
            <field name="users" eval="[(4, ref('base.user_admin')), (4, ref('base.user_root'))]" />
            <field name="name">Accountant</field>
        </record>

        <record id="account.group_account_manager" model="res.groups">
            <field name="implied_ids" eval="[(4, ref('account.group_account_user')), (3, ref('account.group_account_invoice'))]" />
            <field name="name">Advisor</field>
        </record>

        <record id="account.group_account_readonly" model="res.groups">
            <field name="name">Auditor</field>
            <field name="category_id" ref="base.module_category_accounting_accounting" />
        </record>

</data>
    <!-- Metro Code changes -->
    <data>
        <!-- Fiscal Years ('account.fiscal.year') multicompany rule-->
        <record id="account_fiscal_year_rule_company" model="ir.rule">
            <field name="name">Fiscal Years - Internal Users &amp; ERP Admins</field>
            <field ref="om_account_accountant.model_account_fiscal_year" name="model_id"/>
            <field name="domain_force">['|',('company_id','=',False),('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(6,0,[ref('base.group_user')])]"/>
         </record>
        <record id="account_fiscal_year_admin_rule_company" model="ir.rule">
            <field name="name">Fiscal Years - Super Admin</field>
            <field ref="om_account_accountant.model_account_fiscal_year" name="model_id"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(6,0,[ref('base.group_system')])]"/>
        </record>
    </data>
</odoo>
