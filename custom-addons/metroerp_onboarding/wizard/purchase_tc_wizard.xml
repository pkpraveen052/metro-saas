<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="purchase_custom_tc_wizard" model="ir.ui.view">
            <field name="name">purchase_custom_tc_wizard</field>
            <field name="model">purchase.terms.conditions</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="purchase_tc_custom" placeholder="Purchase Terms and Conditions will be shown on orders."/>
                            </group>
                        </group>
                    </sheet>
                    <footer>
                        <button string="Apply" class="oe_highlight" type="object" name="validate"/>
                        <button string="Cancel" special="cancel"/>
                        <button string="Skip" class="btn-secondary" type="object" name="action_skip_onboarding_purchase_tc" />
                    </footer>
                </form>
            </field>
        </record>

</odoo>