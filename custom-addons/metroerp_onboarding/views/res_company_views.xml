<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_company_form_custom_popup" model="ir.ui.view">
        <field name="name">res.company.form.custom.popup</field>
        <field name="model">res.company</field>
        <field name="arch" type="xml">
            <form string="Company">
                <sheet>
                    <field name="logo" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <notebook colspan="4">
                        <page string="General Information" name="general_info">
                            <group>
                                <group>
                                    <field name="partner_id" string="Contact" readonly="1" required="0"
                                           groups="base.group_no_one"/>
                                    <label for="street" string="Address"/>
                                    <div class="o_address_format">
                                        <field name="street" placeholder="Street..." class="o_address_street"/>
                                        <field name="street2" placeholder="Street 2..." class="o_address_street"/>
                                        <field name="city" placeholder="City" class="o_address_city"/>
                                        <field name="state_id" class="o_address_state" placeholder="State"
                                               options='{"no_open": True}'/>
                                        <field name="zip" placeholder="ZIP" class="o_address_zip"/>
                                        <field name="country_id" placeholder="Country" class="o_address_country"
                                               options='{"no_open": True}'/>
                                    </div>
                                    <field name="phone" class="o_force_ltr"/>
                                    <field name="email"/>
                                    <field name="l10n_sg_unique_entity_number"/>
                                    <field name="uenType"/>
                                    <field name="website" string="Website" widget="url"
                                           placeholder="e.g. https://www.website.com"/>
                                </group>
                                <group>
                                    <field name="vat"/>
                                    <field name="company_registry"/>
                                    <field name="currency_id" options="{'no_create': True, 'no_open': True}"
                                           id="company_currency" context="{'active_test': False}"/>
                                    <field name="parent_id" groups="base.group_multi_company"/>
                                    <field name="sequence" invisible="1"/>
                                    <field name="favicon" widget="image" class="float-left oe_avatar"
                                           groups="base.group_no_one"/>
                                </group>
                            </group>
                        </page>
                        <page string="Other Information" name="onboarding_info">
                            <group>
                                <group>
                                    <field name="invoice_terms" string="Default Invoice Terms and Conditions" placeholder="Default Invoice Terms and Conditions will be shown on invoice."/>
                                </group>
                                <group>
                                    <!-- <field name="custom_group_multi_currency" string="Required Multi-Currency?"/> -->
                                    <!--                                    <div class="content-group"-->
                                    <!--                                         attrs="{'invisible': [('custom_group_multi_currency', '=', False)]}">-->
                                    <!--                                        <div class="mt8">-->
                                    <!--                                            <button type="action" name="%(base.action_currency_form)d"-->
                                    <!--                                                    string="Currencies" class="btn-link" icon="fa-arrow-right"/>-->
                                    <!--                                        </div>-->
                                    <!--                                    </div>-->
                                    <field name="group_analytic_accounting" string="Required Analytic Accounting?"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <footer position="replace">
                    <button name="action_save_onboarding_company_step" class="btn btn-primary" type="object"
                            string="Apply"/>
                    <button special="cancel" string="Cancel"/>
                    <button string="Skip" class="btn-secondary" type="object"
                            name="action_skip_onboarding_company_data"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_open_custom_onboarding_company_popup" model="ir.actions.act_window">
        <field name="name">Set your company data</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">res.company</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_company_form_custom_popup"/>
        <field name="target">new</field>
    </record>

    <data>
        <record id="view_company_form_inherit_dashboard_setting" model="ir.ui.view">
            <field name="name">view_company_form_inherit_dashboard_setting</field>
            <field name="model">res.company</field>
            <field name="inherit_id" ref="base.view_company_form"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook" position="inside">
                    <page string="Onboarding Setting" name="onboarding_setting">
                        <group>
                            <group>
                                <field name="account_dashboard_onboarding_state" string="Accounting Onboarding"/>
                            </group>
                            <group>
                                <field name="sale_quotation_onboarding_state" string="Sales Onboarding"/>
                            </group>
                            <group>
                                <field name="purchase_dashboard_onboarding_state" string="Purchase Onboarding"/>
                            </group>
<!--                            <group>-->
<!--                                <field name="account_invoice_onboarding_state" string="Invoice Onboarding"/>-->
<!--                            </group>-->
                        </group>
                    </page>
                </xpath>
            </field>
        </record>
    </data>

</odoo>
