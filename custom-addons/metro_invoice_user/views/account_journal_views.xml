<?xml version="1.0" encoding="UTF-8"?>
<odoo>
   <data>
      <record id="account_journal_dashboard_kanban_view_custom" model="ir.ui.view">
        <field name="name">account.journal.dashboard.kanban.inherit</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.account_journal_dashboard_kanban_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[contains(@class, 'o_kanban_manage_new') and @groups='account.group_account_invoice']" position="attributes">
                <attribute name="groups">account.group_account_invoice,metro_invoice_user.group_account_invoice_user,metro_invoice_user.group_invoice_own_only</attribute>
            </xpath>

            <!-- Added custom group beside account.group_account_invoice for "Upload Invoices" -->
            <xpath expr="//a[contains(@class, 'o_button_upload_bill') and @groups='account.group_account_invoice']" position="attributes">
                <attribute name="groups">account.group_account_invoice,metro_invoice_user.group_account_invoice_user,metro_invoice_user.group_invoice_own_only</attribute>
            </xpath>

            <xpath expr="//button[@name='action_create_new' and @groups='account.group_account_invoice']" position="attributes">
                <attribute name="groups">account.group_account_invoice,metro_invoice_user.group_account_invoice_user,metro_invoice_user.group_invoice_own_only</attribute>
            </xpath>

                <!-- Added custom group beside account.group_account_invoice for "Connect" link -->
            <xpath expr="//a[@name='action_configure_bank_journal' and @groups='account.group_account_invoice']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Added custom group beside account.group_account_invoice for "Connect" button -->
            <xpath expr="//button[@name='action_configure_bank_journal' and @groups='account.group_account_invoice']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Added custom group beside account.group_account_invoice for "Create" link -->
            <xpath expr="//div[@name='bank_statement_create_button' and @groups='account.group_account_invoice']" position="attributes">
                <attribute name="groups">account.group_account_invoice,metro_invoice_user.group_account_invoice_user,metro_invoice_user.group_invoice_own_only</attribute>
            </xpath>

            <!-- Added custom group beside account.group_account_invoice for "New Transaction" link -->
            <xpath expr="//a[@name='create_cash_statement' and @groups='account.group_account_invoice']" position="attributes">
                <attribute name="groups">account.group_account_invoice,metro_invoice_user.group_account_invoice_user,metro_invoice_user.group_invoice_own_only</attribute>
            </xpath>

            <!-- Added custom group beside account.group_account_invoice for "New Transaction" button -->
            <xpath expr="//button[@name='create_cash_statement' and @groups='account.group_account_invoice']" position="attributes">
                <attribute name="groups">account.group_account_invoice,metro_invoice_user.group_account_invoice_user,metro_invoice_user.group_invoice_own_only</attribute>
            </xpath>

            <!-- Add custom group beside account.group_account_invoice for "New Invoice" button -->
            <xpath expr="//button[@name='action_create_new' and @class='btn btn-primary o_invoice_new']" position="attributes">
                <attribute name="groups">account.group_account_invoice,metro_invoice_user.group_account_invoice_user,metro_invoice_user.group_invoice_own_only</attribute>
            </xpath>

            <xpath expr="//button[@name='action_create_new' and @class='btn btn-primary o_invoice_new']" position="after">
                <t t-if="journal_type == 'sale'">
                    <a type="object" name="show_layout_invoice_user" class="o_invoice_new" groups="account.group_account_invoice,metro_invoice_user.group_account_invoice_user,metro_invoice_user.group_invoice_own_only"><span>Select Invoice Layout</span></a>
                </t>
            </xpath>
            <!-- Added custom group beside account.group_account_invoice for "Upload" button -->
            <xpath expr="//button[@class='btn btn-primary o_button_upload_bill oe_kanban_action_button' and @journal_type='purchase' and @groups='account.group_account_invoice']" position="attributes">
                <attribute name="groups">account.group_account_invoice,metro_invoice_user.group_account_invoice_user,metro_invoice_user.group_invoice_own_only</attribute>
            </xpath>

            <!-- Added custom group beside account.group_account_invoice for "Create" link -->
            <xpath expr="//a[@name='action_create_new' and @class='o_invoice_new' and @groups='account.group_account_invoice']" position="attributes">
                <attribute name="groups">account.group_account_invoice,metro_invoice_user.group_account_invoice_user,metro_invoice_user.group_invoice_own_only</attribute>
            </xpath>

        </field>
    </record>

    <!-- <record id="account.open_account_journal_dashboard_kanban" model="ir.actions.act_window">
        <field name="context">{'invoice_user_dashboard': True}</field>
    </record> -->

    <record id="account_view_account_journal_form_inherit" model="ir.ui.view">
        <field name="name">account.journal.form.view.inherit</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.view_account_journal_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='restrict_mode_hash_table']" position="after">
                <field name="show_on_dashboard_invoice_user" 
                    attrs="{'invisible': [('type', 'not in', ['sale','purchase'])]}" />
            </xpath>
        </field>
    </record>

    <!--This is the context for accounting dashboard views -->
    <record id="account.open_account_journal_dashboard_kanban" model="ir.actions.act_window">
        <field name="context">{'from_dashboard_menu': True}</field>
    </record>
   </data>
</odoo>