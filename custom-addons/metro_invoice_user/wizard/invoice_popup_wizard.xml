<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_invoice_popup_wizard" model="ir.ui.view">
    <field name="name">invoice.popup.wizard.form</field>
    <field name="model">invoice.popup.wizard</field>
    <field name="arch" type="xml">
        <form string="Information">
            <group>
                <field name="message" nolabel="1" readonly="1"/>
            </group>

            <footer>
                <button string="Close" class="btn-primary" special="cancel"/>
            </footer>
        </form>
    </field>
</record>
</odoo>
