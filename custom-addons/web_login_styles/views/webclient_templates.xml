<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="custom_login_layout" inherit_id="web.login_layout" priority="9">
    <xpath expr="//div[@class='container py-5']" position="replace">
        <!-- Main container with orientation logic -->
        <div class="background"
             t-attf-style="background-image: url('#{bg_img}'); background-size: cover; background-color: #{color}; height: 100%; display: flex; flex-direction: row; align-items: center;">
            
            <!-- Conditional orientation logic -->
            <div t-if="orientation == 'left'" style="width: 50%; text-align: left; padding-left: 10%;">
                <div class="custom-content">
                    <t t-esc="custom_text_left"/>
                </div>
            </div>

            <div class="login-form" style="flex: 1; max-width: 300px; margin: auto;">
                <div t-attf-class="card border-0 mx-auto bg-100 {{login_card_classes}} o_database_list">
                    <div class="card-body">
                        <div t-attf-class="text-center pb-3 border-bottom {{'mb-3' if form_small else 'mb-4'}}">
                            <img t-attf-src="/web/binary/company_logo{{ '?dbname='+db if db else '' }}" alt="Logo"
                                 style="max-height:120px; max-width: 100%; width:auto"/>
                        </div>
                        <!-- Placeholder for dynamic forms like login/reset_password -->
                        <t t-raw="0"/>
                        <div class="text-center small mt-4 pt-3 border-top" t-if="not disable_footer">
                            <t t-if="not disable_database_manager">
                                <a class="border-right pr-2 mr-1" href="/web/database/manager">Manage Databases</a>
                            </t>
                            <a href="https://www.metrogroup.solutions/solutions/accounting-system" target="_blank">
                                Powered by <span>Metro ERP</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div t-if="orientation == 'right'" style="width: 50%; text-align: right; padding-right: 10%;">
                <div class="custom-content">
                    <t t-esc="custom_text_right"/>
                </div>
            </div>
        </div>
    </xpath>
</template>

</odoo>