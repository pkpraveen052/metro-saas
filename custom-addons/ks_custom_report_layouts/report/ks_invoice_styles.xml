      <!-- Invoice Without Payment-->

        <template id="ks_custom_report_invoice">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-set="lang" t-value="o.invoice_user_id.sudo().lang if o.move_type in ('in_invoice', 'in_refund') else o.partner_id.lang"/>
                    <!-- Multicompany -->
                    <t t-if="company_id">
                        <t t-set="company" t-value="company_id"/>
                    </t>
                    <t t-elif="o and 'company_id' in o">
                        <t t-set="company" t-value="o.company_id.sudo()"/>
                    </t>
                    <t t-else="else">
                        <t t-set="company" t-value="res_company"/>
                    </t>
                    <t t-set="res_config" t-value="o.env['ks.report.configuration'].search([('ks_record_status','=', 'Invoice'), ('company_id','=', company.id)], limit=1)"/>
                    <t t-if="res_config and res_config.ks_is_custom_layout">
                        <t t-if="res_config.sale_report_style_id.name == 'Contemporary'">
                            <t t-call="ks_custom_report_layouts.ks_invoice_report_style_1"
                               t-lang="lang"/>
                        </t>
                        <t t-elif="res_config.sale_report_style_id.name == 'Clean'">
                            <t t-call="ks_custom_report_layouts.ks_invoice_report_style_2"
                               t-lang="lang"/>
                        </t>
                        <t t-elif="res_config.sale_report_style_id.name == 'Professional'">
                            <t t-call="ks_custom_report_layouts.ks_invoice_report_style_3"
                               t-lang="lang"/>
                        </t>
                        <t t-elif="res_config.sale_report_style_id.name == 'Advanced'">
                            <t t-call="ks_custom_report_layouts.ks_invoice_report_style_4"
                               t-lang="lang"/>
                        </t>
                        <t t-elif="res_config.sale_report_style_id.name == 'Exclusive'">
                            <t t-call="ks_custom_report_layouts.ks_invoice_report_style_5"
                               t-lang="lang"/>
                        </t>
                        <t t-elif="res_config.sale_report_style_id.name == 'Elegant'">
                            <t t-call="ks_custom_report_layouts.ks_invoice_report_style_6"
                               t-lang="lang"/>
                        </t>
                        <t t-elif="res_config.sale_report_style_id.name == 'Retro'">
                            <t t-call="ks_custom_report_layouts.ks_invoice_report_style_7"
                               t-lang="lang"/>
                        </t>
                        <t t-elif="res_config.sale_report_style_id.name == 'Modern'">
                            <t t-call="ks_custom_report_layouts.ks_invoice_report_style_8"
                               t-lang="lang"/>
                        </t>
                        <t t-elif="res_config.sale_report_style_id.name == 'Classic'">
                            <t t-call="ks_custom_report_layouts.ks_invoice_report_style_9"
                               t-lang="lang"/>
                        </t>
                        <t t-elif="res_config.sale_report_style_id.name == 'Slim'">
                            <t t-call="ks_custom_report_layouts.ks_invoice_report_style_10"
                               t-lang="lang"/>
                        </t>
                        <t t-elif="res_config.sale_report_style_id.name == 'Minimalist'">
                            <t t-call="ks_custom_report_layouts.report_invoice_inherit_document_dynamic"
                            t-lang="lang"/>
                        </t>
                        <t t-elif="res_config.sale_report_style_id.name == 'MCT'">
                            <t t-call="ks_custom_report_layouts.metro_custom_invoice_report_style_2"
                            t-lang="lang"/>
                        </t>
                        <t t-else="">
                            <t t-call="#{ o._get_name_invoice_report() }" t-lang="lang"/>
                        </t>
                    </t>
                    <t t-else="">
                        <t t-call="#{ o._get_name_invoice_report() }" t-lang="lang"/>
                    </t>
                </t>
            </t>
        </template>

