<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="ks_custom_report_picking">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <!-- Multicompany -->
                <t t-if="company_id">
                    <t t-set="company" t-value="company_id"/>
                </t>
                <t t-elif="o and 'company_id' in o">
                    <t t-set="company" t-value="o.company_id.sudo()"/>
                </t>
                <t t-else="else">
                    <t t-set="company" t-value="res_company"/>
                </t>
                <t t-set="res_config"
                   t-value="o.env['ks.report.configuration'].search([('ks_record_status','=', 'picking'), ('company_id','=', company.id)], limit=1)"/>
                <t t-if="res_config and res_config.ks_is_custom_layout">
                    <t t-if=" res_config.sale_report_style_id.name == 'Contemporary' ">
                        <t t-call="ks_custom_report_layouts.ks_report_picking_style_1"/>
                    </t>
                    <t t-elif=" res_config.sale_report_style_id.name == 'Clean'">
                        <t t-call="ks_custom_report_layouts.ks_report_picking_style_2"/>
                    </t>
                    <t t-elif=" res_config.sale_report_style_id.name == 'Professional'">
                        <t t-call="ks_custom_report_layouts.ks_report_picking_style_3"/>
                    </t>
                    <t t-elif=" res_config.sale_report_style_id.name == 'Advanced'">
                        <t t-call="ks_custom_report_layouts.ks_report_picking_style_4"/>
                    </t>
                    <t t-elif=" res_config.sale_report_style_id.name == 'Exclusive'">
                        <t t-call="ks_custom_report_layouts.ks_report_picking_style_5"/>
                    </t>
                    <t t-elif=" res_config.sale_report_style_id.name == 'Elegant'">
                        <t t-call="ks_custom_report_layouts.ks_report_picking_style_6"/>
                    </t>
                    <t t-elif=" res_config.sale_report_style_id.name == 'Retro'">
                        <t t-call="ks_custom_report_layouts.ks_report_picking_style_7"/>
                    </t>
                    <t t-elif=" res_config.sale_report_style_id.name == 'Modern'">
                        <t t-call="ks_custom_report_layouts.ks_report_picking_style_8"/>
                    </t>
                    <t t-elif=" res_config.sale_report_style_id.name == 'Classic'">
                        <t t-call="ks_custom_report_layouts.ks_report_picking_style_9"/>
                    </t>
                    <t t-elif=" res_config.sale_report_style_id.name == 'Slim'">
                        <t t-call="ks_custom_report_layouts.ks_report_picking_style_10"/>
                    </t>
                    <t t-elif="res_config.sale_report_style_id.name == 'Slim'">
                        <t t-call="ks_custom_report_layouts.ks_report_picking_style_10"/>
                    </t>
                    <t t-elif="res_config.sale_report_style_id.name == 'Minimalist'">
                        <t t-call="ks_custom_report_layouts.report_stockpicking_inherit_document"
                           t-lang="o.partner_id.lang"/>
                    </t>
                    <t t-else="">
                        <t t-call="stock.report_picking" t-lang="o.partner_id.lang"/>
                    </t>
                </t>
                <t t-else="">
                    <t t-call="stock.report_picking"/>
                </t>
            </t>
        </t>
    </template>

    <template id="ks_duplicate_report_picking_type_label">
        <t t-set="is_picking_duplicate" t-value="True"/>
        <t t-call="ks_custom_report_layouts.ks_custom_report_picking"/>
    </template>

    <record id="stock.action_report_picking" model="ir.actions.report">
        <field name="name">Picking Operations</field>
        <field name="model">stock.picking</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">ks_custom_report_layouts.ks_custom_report_picking</field>
        <field name="report_file">ks_custom_report_layouts.ks_custom_report_picking</field>
        <field name="print_report_name">'Picking Operations - %s - %s' % (object.partner_id.name or '', object.name)
        </field>
        <field name="binding_model_id" ref="stock.model_stock_picking"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="paperformat_dynamic_picking_slip"/>
    </record>

    <record id="ks_duplicate_action_report_picking" model="ir.actions.report">
        <field name="name">Picking Operations Duplicate</field>
        <field name="model">stock.picking</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">ks_custom_report_layouts.ks_duplicate_report_picking_type_label</field>
        <field name="report_file">ks_custom_report_layouts.ks_duplicate_report_picking_type_label</field>
        <field name="print_report_name">'Picking Operations - %s - %s' % (object.partner_id.name or '', object.name)
        </field>
<!--         <field name="binding_model_id" ref="stock.model_stock_picking"/>
        <field name="binding_type">report</field> -->
    </record>

</odoo>
