                        <t t-set="total_style" t-value="'page-break-inside: avoid;table-layout:fixed;margin-right: 0;margin-left: auto;width:35%;'"/>
                    </t>
                    <t t-elif="res_config.ks_product_desc and not res_config.ks_discount and not res_config.ks_show_taxes and not res_config.show_uom">
                        <col width="25%"/>
                        <col width="30%"/>
                        <col width="10%"/>
                        <col width="35%"/>
                        <t t-set="total_style" t-value="'page-break-inside: avoid;table-layout:fixed;margin-right: 0;margin-left: auto;width:50%;'"/>
                    </t>
                    <t t-elif="res_config.ks_product_desc and not res_config.ks_discount and not res_config.ks_show_taxes and res_config.show_uom">
                        <col width="15%"/>
                        <col width="30%"/>
                        <col width="35%"/>
                        <col width="10%"/>
                        <col width="10%"/>
                        <t t-set="total_style" t-value="'page-break-inside: avoid;table-layout:fixed;margin-right: 0;margin-left: auto;width:50%;'"/>
                    </t>
                    <thead>
                        <tr>
                            <th name="th_item" class="text-center" style="vertical-align: middle;">Item</th>
                            <th name="th_description" class="text-center" style="vertical-align: middle;" t-if="res_config.ks_product_desc"><span>Description</span></th>
                            <th name="th_quantity" class="text-center" style="vertical-align: middle;"><span>Quantity</span></th>
                            <th name="th_uom" class="text-center" style="vertical-align: middle;" t-if="res_config.show_uom"><span>UOM</span></th>
                            <th name="th_priceunit" t-attf-class="text-center {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}" style="vertical-align: middle;"><span>Price</span></th>
                            <th name="th_discount" t-if="res_config.ks_discount" t-attf-class="text-center {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}" style="vertical-align: middle;">
                                <span>Disc.</span>
                            </th>
                            <th name="th_taxes" t-attf-class="text-center {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}" style="vertical-align: middle;" t-if="res_config.ks_show_taxes"><span>Taxes</span></th>
                            <th name="th_exchange_rate" class="text-center" style="vertical-align: middle;"><span>Exchange Rate</span></th>
                            <th name="th_subtotal" class="text-center" style="vertical-align: middle;">
                                <span groups="account.group_show_line_subtotals_tax_excluded">Amount</span>
                                <span groups="account.group_show_line_subtotals_tax_included">Total</span>
                            </th>
                        </tr>
                    </thead>
                    <t t-set="item_num" t-value="0"/>
                    <tbody class="invoice_tbody">
                        <t t-set="current_subtotal" t-value="0"/>
                        <t t-set="lines" t-value="o.invoice_line_ids.sorted(key=lambda l: (-l.sequence, l.date, l.move_name, -l.id), reverse=True)"/>
                        <t t-foreach="lines" t-as="line">
                            <t t-set="current_subtotal" t-value="current_subtotal + line.price_subtotal" groups="account.group_show_line_subtotals_tax_excluded"/>
                            <t t-set="current_subtotal" t-value="current_subtotal + line.price_total" groups="account.group_show_line_subtotals_tax_included"/>
                            <tr t-att-class="'bg-200 font-weight-bold o_line_section' if line.display_type == 'line_section' else 'font-italic o_line_note' if line.display_type == 'line_note' else ''">
                                <t t-if="not line.display_type" name="account_invoice_line_accountable">
                                    <t t-set="item_num" t-value="item_num+1"/>
                                    <td name="td_item" class="text-center" style="padding-bottom:40px;" t-if="res_config.ks_show_space"><span t-esc="item_num"/></td>
                                    <td name="td_item" class="text-center" t-if="not res_config.ks_show_space"><span t-esc="item_num"/></td>
                                    <td name="account_invoice_line_name" t-if="res_config.ks_product_desc">
                                        <t t-if="not res_config.hide_product_label and line.product_id">
                                            <t t-if="res_config.display_internal_ref">
                                                <span style="font-weight:bold;font-size:11.0pt;" t-field="line.product_id.display_name"/><br/>
                                            </t>
                                            <t t-else="">
                                                <span style="font-weight:bold;font-size:11.0pt;" t-field="line.product_id.name"/><br/>
                                            </t>
                                        </t>
                                        <span t-field="line.name" t-options="{'widget': 'text'}"/>
                                    </td>
                                    <td name="td_quantity" class="text-center">
                                        <t t-if="res_config.display_qty_as_integer">
                                            <span t-esc="int(line.quantity)"/>
                                        </t>
                                        <t t-if="not res_config.display_qty_as_integer">
                                            <span t-field="line.quantity" t-options='{"widget": "float", "precision": 2}'/>
                                        </t>
                                        <t t-if="not res_config.show_uom and not res_config.hide_uom">
                                            <span t-field="line.product_uom_id"/> 
                                        </t>
                                    </td>
                                    <td name="td_uom" class="text-left" t-if="res_config.show_uom">
                                        <span t-field="line.product_uom_id"/>
                                    </td>
                                    <td t-attf-class="text-right {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                                        <span class="text-nowrap" t-field="line.price_unit" t-options='{"widget": "float", "precision": 2}' t-if="not res_config.show_decimal"/>
                                        <span class="text-nowrap" t-field="line.price_unit" t-if="res_config.show_decimal"/>
                                    </td>
                                                                
                                    <td t-if="res_config.ks_discount" t-attf-class="text-center {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                                            <t t-set="discount_symbol" t-value="'%' if line.discount_type == 'percent' else '$'"/>
                                            <t t-set="display_discount_symbol" t-value="line.discount > 0"/>
                                            <t t-set="discount_value" t-value="line.discount if display_discount_symbol else line.discount"/>
                                            <span class="text-nowrap">
                                                <t t-esc="discount_value" t-options='{"widget": "float", "precision": 2}'/>
                                                <t t-if="display_discount_symbol">
                                                    <t t-esc="discount_symbol"/>
                                                </t>
                                            </span>
                                    </td>

                                    <td t-attf-class="text-center {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}" t-if="res_config.ks_show_taxes">
                                          <span t-esc="', '.join(map(lambda x: (x.description or x.name), line.tax_ids))" id="line_tax_ids"/>
                                    </td>
                                    
                                    <td name="td_exchange_rate" class="text-center" style="vertical-align: middle;">
                                        <t t-if="o.exchange_rate">
                                            <span>
                                                1 <t t-esc="o.company_currency_id.name"/> =
                                                <t t-esc="o.exchange_rate" t-options="{'widget': 'float', 'precision':4}"/>
                                                <t t-esc="o.currency_id.name"/>
                                            </span>
                                        </t>
                                    </td>

                                    <td class="text-right" name="td_price_total">
                                        <span class="text-nowrap"
                                                t-esc="abs(line.balance)"
                                                groups="account.group_show_line_subtotals_tax_excluded"
                                                t-options='{"widget":"monetary","precision":2,"display_currency": o.company_currency_id}'/>

                                        <span class="text-nowrap"
                                                t-esc="abs(line.balance)"
                                                groups="account.group_show_line_subtotals_tax_included"
                                                t-options='{"widget":"monetary","precision":2,"display_currency": o.company_currency_id}'/>
                                    </td>
                                </t>
                                <t t-if="line.display_type == 'line_section'">
                                    <td colspan="99">
                                        <span t-field="line.name" t-options="{'widget': 'text'}"/>
                                    </td>
                                    <t t-set="current_section" t-value="line"/>
                                    <t t-set="current_subtotal" t-value="0"/>
                                </t>
                                <t t-if="line.display_type == 'line_note'">
                                    <td colspan="99">
                                        <span t-field="line.name" t-options="{'widget': 'text'}"/>
                                    </td>
                                </t>
                            </tr>
                        </t>
                    </tbody>
                </table>
                 <br/>
                <div class="clearfix">
                    <div id="total" name="main_total">
                        <table class="table table-sm" t-att-style="total_style">
                            <tr t-if="res_config.ks_discount_total" class="ks_subtotal">
                                <td style="border-right:none;"><strong>Discount Total</strong></td>
                                <td class="text-right">
                                    <t t-set="discount_sgd"
                                        t-value="o.currency_id._convert(o.discount_total, o.company_currency_id, o.company_id, o.invoice_date or o.date)"/>
                                    <span t-esc="discount_sgd" t-options="{'widget': 'monetary','precision':2,'display_currency': o.company_currency_id}"/>
                                </td>
                            </tr>
                            <tr class="border-black o_subtotal" style="border:1px solid black;" name="o_subtotal" t-if="res_config.display_total_amount">
                                <td><strong>Total</strong></td>
                                <td class="text-right">
                                    <span t-field="o.amount_untaxed_signed"/>
                                </td>
                            </tr>
                            <t>
                                <t t-foreach="o.get_total_tax_per_account().items()" t-as="tax_line">
                                    <tr>
                                        <td style="border-right:none;">
                                            <strong><span t-esc="tax_line[0]"/></strong>
                                        </td>
                                        <td style="text-align: right;">
                                            <span t-esc="tax_line[1]" t-options='{"widget":"monetary","precision":2,"display_currency": o.company_currency_id}'/> <!-- Tax Amount -->
                                        </td>
                                    </tr>
                                </t>
                            </t>
                            <tr class="border-black">
                                <td style="background-color: white;color: black;border-right:none;"><strong>Grand Total</strong></td>
                                <td class="text-right" style="background-color: white;color: black;">
                                    <span class="text-nowrap" t-field="o.amount_total_signed"/>
                                </td>
                            </tr>
                            <t t-if="print_with_payments">
                                <t t-if="o.payment_state != 'invoicing_legacy'">
                                    <t t-set="payments_vals" t-value="o.sudo()._get_reconciled_info_JSON_values()"/>
                                        <t t-foreach="payments_vals" t-as="payment_vals">
                                            <tr>
                                                <td style="border-right: none;">
                                                    <i class="oe_form_field text-right oe_payment_label">Paid on <t t-esc="payment_vals['date']" t-options="{&quot;widget&quot;: &quot;date&quot;}"/></i>
                                                </td>
                                               <t t-set="amount_sgd"
                                                t-value="o.currency_id._convert(payment_vals['amount'], o.company_currency_id, o.company_id, o.invoice_date or o.date)"/>

                                                <td class="text-right">
                                                    <span t-esc="amount_sgd"
                                                        t-options="{'widget': 'monetary', 'display_currency': o.company_currency_id}"/>
                                                </td>
                                            </tr>
                                        </t>
                                        <t t-if="len(payments_vals) &gt; 0">
                                            <tr class="border-black">
                                                <td style="background: white;border-right: none;"><strong style="color: black;">Amount Due</strong></td>
                                                <td class="text-right" style="background-color: white;color: black;">
                                                    <t t-set="amount_residual_sgd"
                                                    t-value="o.currency_id._convert(o.amount_residual, o.company_currency_id, o.company_id, o.invoice_date or o.date)"/>
                                                    
                                                    <span t-esc="amount_residual_sgd"
                                                        t-options="{'widget': 'monetary', 'display_currency': o.company_currency_id}"/>
                                                </td>
                                            </tr>
                                        </t>
                                </t>
                            </t>
                        </table>
                  </div>
             </div>
        </div>
    </template>
</odoo>