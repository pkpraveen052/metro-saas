<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="metro_invoice_report_with_local_currency_template">
        <t t-set="o" t-value="o.with_context(lang=o.partner_id.lang)" />
        <t t-call="ks_custom_report_layouts.custom_external_invoice_layout">
            <div class="page" style="font-family: 'Open Sans', Arial, sans-serif;"
            t-attf-style="font-size: {{ res_config.increase_font_size and '11.0pt' or '10.0pt' }};">
                <div class="oe_structure"/>
                <div class="row">
                    <div class="col-4 text-left" t-attf-style="#{res_config.move_address_right and 'margin-left:2cm;' or ''}">
                        <div>
                            <b>
                                <span t-if="o.partner_id.company_type == 'company'" style="font-size:13.0pt;" t-field="o.partner_id.name"/>
                                <t t-if="o.partner_id.company_type == 'person'">
                                    <t t-if="o.partner_id.parent_id.name">
                                        <span style="font-size:13.0pt;" t-field="o.partner_id.parent_id.name"/>
                                    </t>
                                    <t t-else="">
                                        <span style="font-size:13.0pt;" t-field="o.partner_id.name"/>
                                    </t>
                                </t>
                            </b>
                        </div>
                        <div t-if="o.partner_id.company_type == 'person' and o.partner_id.parent_id">
                            Attn: <span t-field="o.partner_id.name"/>
                        </div>
                        <div>
                            <t t-if="o.partner_id.street or o.partner_id.street2 or o.partner_id.city or o.partner_id.state_id or o.partner_id.zip or o.partner_id.country_id">
                            Address:
                            <t t-if="o.partner_id.street">
                                <span t-field="o.partner_id.street"/>
                            </t>
                            <t t-if="o.partner_id.street and o.partner_id.street2"><br/></t>
                            <t t-if="o.partner_id.street2">
                                <span t-field="o.partner_id.street2"/>,
                            </t>
                            <t t-if="o.partner_id.street or o.partner_id.street2"><br/></t>
                            <t t-if="o.partner_id.city">
                                <span t-field="o.partner_id.city"/>,
                            </t>
                            <t t-if="o.partner_id.state_id">
                                <span t-field="o.partner_id.state_id.name"/>,
                            </t>
                            <t t-if="o.partner_id.country_id">
                                <span t-field="o.partner_id.country_id.name"/>,
                            </t>
                            <t t-if="o.partner_id.zip">
                                <span t-field="o.partner_id.zip"/>
                            </t>
                            </t>
                        </div>
                        <div t-if="o.partner_id.phone">
                            Phone: <span t-field="o.partner_id.phone"/>
                        </div>
                        <div t-if="o.partner_id.email">
                            Email: <span t-field="o.partner_id.email"/>
                        </div>
                    </div>
                    <div class="col-3">
                        <t t-if="o.partner_shipping_id and (o.partner_shipping_id != o.partner_id)">
                            <div class="ks_invoice" groups="sale.group_delivery_invoice_address">
                                <t class="ks_ship_add"><strong>Shipping Address:</strong></t>
                                    <p class="ks_company_add_color pr-4">
                                        <t t-if="o.partner_shipping_id.name">
                                            <b><t t-esc="o.partner_shipping_id.name"/></b>
                                            <br/>
                                        </t>
                                        <t t-if="o.partner_shipping_id.street">
                                            <t t-esc="o.partner_shipping_id.street"/>,
                                        </t>
                                        <t t-if="o.partner_shipping_id.street2">
                                            <t t-esc="o.partner_shipping_id.street2"/>,
                                        </t>
                                        <t t-if="o.partner_shipping_id.city">
                                            <t t-esc="o.partner_shipping_id.city"/>,
                                        </t>
                                        <t t-if="o.partner_shipping_id.state_id">
                                            <t t-esc="o.partner_shipping_id.state_id.name"/>,
                                        </t>
                                        <t t-if="o.partner_shipping_id.country_id">
                                            <t t-esc="o.partner_shipping_id.country_id.name"/>.
                                        </t>
                                        <t t-if="o.partner_shipping_id.zip">
                                            <t t-esc="o.partner_shipping_id.zip"/>
                                            <br/>
                                        </t>
                                        <t t-if="o.partner_shipping_id.phone">
                                            Phone: <span t-field="o.partner_shipping_id.phone"/>
                                            <br/>
                                        </t>
                                        <t t-if="o.partner_shipping_id.email">
                                            Email: <span t-field="o.partner_shipping_id.email"/>
                                        </t>
                                    </p>
                            </div>
                        </t>
                    </div>
                    <div class="col-6 text-left" id="informations" style="margin-top:-2px;">
                        <div>
                            <strong>
                                <span t-if="o.move_type == 'out_invoice' and o.state == 'posted' and not res_config.show_reg_no" style="font-size: 13.0pt;color: #495057;">INVOICE</span>
                                <span t-if="o.move_type == 'out_invoice' and o.state == 'posted' and res_config.show_reg_no and not res_config.reg_no_type == 'gst'" style="font-size: 13.0pt;color: #495057;">INVOICE</span>
                                <span t-if="o.move_type == 'out_invoice' and o.state == 'posted' and res_config.show_reg_no and res_config.reg_no_type == 'gst'" style="font-size: 13.0pt;color: #495057;">TAX INVOICE</span>
                                <span t-if="o.move_type == 'out_invoice' and o.state == 'draft'" style="font-size: 13.0pt;color: #495057;">DRAFT INVOICE</span>
                                <span t-if="o.move_type == 'out_invoice' and o.state == 'cancel'" style="font-size: 13.0pt;color: #495057;">CANCELLED INVOICE</span>
                                <span t-if="o.move_type == 'out_refund'" style="font-size: 13.0pt;color: #495057;">CREDIT NOTE</span>
                                <span t-if="o.move_type == 'in_refund'" style="font-size: 13.0pt;color: #495057;">VENDOR CREDIT NOTE</span>
                                <span t-if="o.move_type == 'in_invoice'" style="font-size: 13.0pt;color: #495057;">VENDOR BILL</span>
                                <span style="font-size: 13.0pt;color: #495057;"># <span t-field="o.name" style="font-size: 13.0pt;color: #495057;"/></span>
                            </strong>
                        </div>
                        <div style="font-weight:bold;">
                            <div t-if="o.invoice_date">
                                <span style="color: #495057;">Invoice Date: <span t-field="o.invoice_date" t-options="{&quot;widget&quot;: &quot;date&quot;}"/></span>
                            </div>
                            <div t-if="o.invoice_date_due and res_config.show_due_date">
                                <span style="color: #495057;">Due Date: <span t-field="o.invoice_date_due" t-options="{&quot;widget&quot;: &quot;date&quot;}"/></span>
                            </div>
                            <div t-if="o.ref">
                                <span style="color: #495057;">Reference: <span t-field="o.ref"/></span>
                            </div>
                            <div t-if="o.partner_id.ref">
                                <span style="color: #495057;">Reference: <span t-field="o.partner_id.ref"/></span>
                            </div>
                            <div t-if="o.invoice_payment_term_id" name="payment_term">
                                <span style="color: #495057;">Payment Terms: <span t-field="o.invoice_payment_term_id.name"/></span>
                            </div>
                            <div t-if="o.invoice_origin" name="source_doc">
                                <span style="color: #495057;">Source Document: <span t-field="o.invoice_origin"/></span>
                            </div>
                        </div>
                    </div>
                </div>
                <br/>
               <t t-call="ks_custom_report_layouts.metro_invoice_report_table_with_local_currency">
                </t>
                <div class="oe_structure"/>
                    <div class="row" style="page-break-inside: avoid;" t-if="not res_config.display_terms_next_page">
                        <div t-attf-class="#{'col-7' if o.move_type == 'out_invoice' else 'col-12'}">
                            <t t-if="o.narration">
                                <strong style="color: black;">
                                    <span t-if="not res_config.show_remark">TERMS AND CONDITIONS:</span>
                                    <span t-if="res_config.show_remark">REMARKS:</span>
                                </strong><br/>
                                <span t-field="o.narration"/>
                            </t>
                        </div>
                        <!-- Dynamic QR Code -->
                        <t t-if="o.generate_qrcode() and res_config.paynow_qr_code and o.move_type == 'out_invoice' and not res_config.use_static_qr">
                            <div class="ks_option_des col-5 float-right" style="padding-left:65px;padding-top: 10px;text-align: right;">
                              <img style="width: 150px; height: 150px; object-fit: cover;" 
                                   t-attf-src="data:image/png;base64,{{ o.generate_qrcode() }}" alt=""/>
                            </div>
                        </t>
                        <!-- Static QR Code -->
                        <t t-if="res_config.use_static_qr and res_config.static_qr_image and o.move_type == 'out_invoice'">
                            <div class="col-5 float-right"
                                style="padding-left:65px; padding-top:10px; text-align:right;">
                                <img t-att-src="'data:image/png;base64,%s' % res_config.static_qr_image.decode('utf-8')"
                                    style="width:150px; height:150px; object-fit:cover;"
                                    alt="Static QR Code"/>
                            </div>
                        </t>
                    </div>

                    <t t-if="res_config.display_terms_next_page">
                        <div class="row" style="page-break-inside: avoid;">
                            <div class="col-7"></div>
                            <!-- Dynamic QR Code -->
                            <t t-if="o.generate_qrcode() and res_config.paynow_qr_code and o.move_type == 'out_invoice' and not res_config.use_static_qr">
                                <div class="ks_option_des col-5 float-right"
                                    style="padding-left:65px; padding-top:10px; text-align:right;">
                                    <img t-attf-src="data:image/png;base64,{{ o.generate_qrcode() }}"
                                        style="width:150px; height:150px; object-fit:cover;"
                                        alt="QR Code"/>
                                </div>
                            </t>
                            <!-- Static QR Code -->
                            <t t-if="res_config.use_static_qr and res_config.static_qr_image and o.move_type == 'out_invoice'">
                                <div class="col-5 float-right"
                                    style="padding-left:65px; padding-top:10px; text-align:right;">
                                    <img t-att-src="'data:image/png;base64,%s' % res_config.static_qr_image.decode('utf-8')"
                                        style="width:150px; height:150px; object-fit:cover;"
                                        alt="Static QR Code"/>
                                </div>
                            </t>
                        </div>
                        <br/><br/>
                        <div class="custom-container">
                            <t t-call="ks_custom_report_layouts.ks_metro_sign_dynamic_on_delivery"/>
                        </div>
                        <div style="page-break-before:always;" class="row">
                            <div class="col-12 text-left" t-if="o.narration">
                                <strong style="color: black;">
                                    <span t-if="not res_config.show_remark">TERMS AND CONDITIONS:</span>
                                    <span t-if="res_config.show_remark">REMARKS:</span>
                                </strong><br/>
                                <span t-field="o.narration"/>
                            </div>
                        </div>
                    </t>

                <br/>
                
                <div class="row" style="page-break-inside: avoid; white-space: nowrap;">
                    <div class="col-12 text-left">
                        <p t-if="o.move_type in ('out_invoice', 'in_refund') and o.payment_reference"
                           name="payment_communication">
                            Please use the following communication for your payment :
                            <span style="display:inline;font-size:17px;font-weight:500;"
                                  t-field="o.payment_reference"/>
                        </p>
                    </div>
                </div>
                <p t-if="o.fiscal_position_id.note" name="note">
                    <span t-field="o.fiscal_position_id.note"/>
                </p>
                <p t-if="o.invoice_incoterm_id" name="incoterm">
                    <span><strong style="color: black;">Incoterm: </strong><span t-field="o.invoice_incoterm_id.code"/> - <span t-field="o.invoice_incoterm_id.name"/></span>
                </p>
                <!-- <div id="qrcode" t-if="o.display_qr_code">
                    <p t-if="qr_code_urls and qr_code_urls.get(o.id)">
                        <strong class="text-center">Scan me with your banking app.</strong><br/><br/>
                        <img class="border border-dark rounded" t-att-src="qr_code_urls[o.id]"/>
                    </p>
                </div> -->
            </div>
            <t t-if="res_config.ks_show_signature and not res_config.display_terms_next_page">
                <br/>
                <t t-call="ks_custom_report_layouts.ks_metro_sign_dynamic_on_delivery"/>
            </t>
            <t t-call="ks_custom_report_layouts.metro_custom_dynamic_footer">
                <t t-set="ks_style" t-value="'ks_style_10'"/>
            </t>  
        </t>
    </template>

    <template id="metro_invoice_report_table_with_local_currency">
