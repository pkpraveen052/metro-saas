                    <div class="container">
                        <div class="row">
                            <div class="col-12" style="font-size:20px;">
                                <span><strong>Payment Receipt:</strong></span>
                                <span><span t-field="o.name"/></span>
                            </div>
                        </div>
                    </div>
                    <br/><br/>
                    <div class="container">
                        <div class="row">
                            <div class="col-4 border-right  text-left ks_details" t-if="o.partner_type">
                                <t>
                                    <t t-if="o.partner_type == 'customer'">
                                        <p class=" font_9 ">Payer:</p>
                                    </t>
                                    <t t-if="o.partner_type == 'supplier'">
                                        <p class="font_9  ">Payee:</p>
                                    </t>
                                    <p class="ks_company_name_color font_10 ks_company_bold "
                                       t-field="o.partner_id"/>
                                </t>
                            </div>
                            <div t-if="o.date" class="col-4 border-right  text-left ks_details">
                                <p class="text_font_color font_9">Payment Date:</p>
                                <p class=" font_10" t-field="o.date"/>
                            </div>
                            <div t-if="o.payment_method_id" class="col-4 text-left ks_details">
                                <p class="text_font_color font_9">Payment Method:</p>
                                <p class="font_10" t-field="o.payment_method_id.name"/>
                            </div>
                        </div>
                        <br/>
                        <div class="row">
                            <div t-if="o.ref" class="col-12  text-left ks_details">
                                <span class="text_font_color font_9">Memo: </span><span class=" font_10" t-field="o.ref"/>
                            </div>
                        </div>
                    </div>
                    <br/>
                    <t t-set="reconciled_invoices" t-value="o.move_id._get_reconciled_invoices_partials()"/>
                    <t t-if="reconciled_invoices">
                    <table class="table table-sm">
                        <t>
                            <col width="10%"/>
                            <col width="12%"/>
                            <col width="16%"/>
                            <col width="15%"/>
                            <col width="16%"/>
                            <col width="17%"/>
                            <col width="15%"/>
                            <t t-set="total_style" t-value="'page-break-inside: avoid;table-layout:fixed;margin-right: 0;margin-left: auto;width:31%;'"/>
                        </t>
                        <thead>
                            <tr>
                                <th class="text-left">Sr. No.</th>
                                <th class="text-left">Invoice Date</th>
                                <th class="text-left">Invoice Number</th>
                                <th class="text-left">Reference</th>
                                <th class="text-left">Original Amount</th>
                                <th class="text-left">Amount Paid</th>
                                <th class="text-right">Balance
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="count" t-value="1"/>
                            <tr t-foreach="o.move_id._get_reconciled_invoices_partials()" t-as="rec">
                                <t t-set="amount" t-value="rec[1]"/>
                                <t t-set="inv" t-value="rec[2].move_id"/>
                                <td class="text-left">
                                    <span t-esc="count"/>
                                </td>
                                <td class="text-left">
                                    <span t-field="inv.invoice_date"/>
                                </td>
                                <td class="text-left">
                                    <span t-field="inv.name"/>
                                </td>
                                <td class="text-left">
                                    <span t-field="inv.ref"/>
                                </td>
                                <td class="text-left">
                                    <t t-if="res_config.display_currency_separately">
                                        <div>
                                            <span class="float-left">
                                                <t t-esc="o.currency_id.symbol" />
                                            </span>
                                            <span class="float-right">
                                                <span t-field="inv.amount_total" t-options='{"widget":"float", "precision":2}'/>
                                            </span>
                                        </div>
                                    </t>
                                    <t t-else="">
                                        <div class="text-left">
                                            <span t-field="inv.amount_total" t-options="{'display_currency': o.currency_id}"/>
                                        </div>
                                    </t>
                                </td>
                                <td class="text-left">
                                    <t t-if="res_config.display_currency_separately">
                                        <div>
                                            <span class="float-left">
                                                <t t-esc="o.currency_id.symbol" />
                                            </span>
                                            <span class="float-right">
                                                <span t-esc="amount" t-options='{"widget":"float", "precision":2}'/>
                                            </span>
                                        </div>
                                    </t>
                                    <t t-else="">
                                        <div class="text-left">
                                            <span t-esc="amount"
                                                  t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                        </div>
                                    </t>
                                </td>
                                <td class="text-right" style="background-color:white;">
                                    <t t-if="res_config.display_currency_separately">
                                        <div>
                                            <span class="float-left">
                                                <t t-esc="o.currency_id.symbol" />
                                            </span>
                                            <span class="float-right">
                                                <span t-field="inv.amount_residual" t-options='{"widget":"float", "precision":2}'/>
                                            </span>
                                        </div>
                                    </t>
                                    <t t-else="">
                                        <div class="text-right">
                                            <span t-field="inv.amount_residual" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                        </div>
                                    </t>
                                </td>
                                <t t-set="count" t-value="count+1"/>
                            </tr>
                        </tbody>
                    </table>
                    <div class="clearfix">
                        <div name="total">
                            <table class="table table-sm" t-att-style="total_style" style="border:none;">
                                <tr>
                                    <td style="font-size:13px;"><strong>Grand Total</strong></td>
                                    <t t-if="res_config.display_currency_separately">
                                        <td class="text-right" style="border-right:none;"><strong><t t-esc="o.currency_id.symbol"/></strong></td>
                                        <td class="text-right">
                                            <span t-field="o.amount" t-options='{"widget":"float", "precision":2}'/>
                                        </td>
                                    </t>
                                    <t t-else="">
                                        <td class="text-right" style="border:none;">
                                            <span t-field="o.amount"
                                            t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                        </td>
                                    </t>
                                </tr>
                            </table>
                        </div>
                    </div>
                  </t>
                  <div class="col-4 offset-8 position-relative" style="margin-top:50px;">
                    <div style="margin-left:20px;" t-if="not reconciled_invoices">
                        <tr style="font-size:15px;">
                            <td class="text-left"><strong>Grand Total: </strong></td>
                            <td class="text-right">
                                <span t-field="o.amount"
                                t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                            </td>
                        </tr>
                    </div>
                   </div>
                    <div class="custom-container">
                        <t t-call="ks_custom_report_layouts.ks_metro_dynamic_sign"/>
                    </div>
                </div>
                <t class="ks_container_9" t-call="ks_custom_report_layouts.metro_custom_dynamic_footer">
                    <t t-set="ks_style" t-value="'ks_style_8'"/>
                </t>
            </t>
        </template>
    
    <!--    Calling custom header in new layout-->
        <template id="custom_external_payment_receipt_layout">
            <!-- Multicompany -->
            <t t-if="not o and o">
                <t t-set="o" t-value="o"/>
            </t>
            <t t-if="o and 'company_id' in o">
                <t t-set="company" t-value="o.company_id"/>
            </t>
            <t t-if="not o or not 'company_id' in o">
                <t t-set="company" t-value="res_company"/>
            </t>
            <t t-call="ks_custom_report_layouts.custom_external_payment_receipt_layout_standard">
               <t t-raw="0"/>
            </t>
        </template>
    
        <template id="custom_external_payment_receipt_layout_standard">
            <div class="header">
                <div class="o_boxed_header" style="font-family: sans-serif;color: #495057;font-size:10.0pt;">
                    <div class="row" t-if="res_config.show_report_header_position == 'right'">
                        <div class="col-4" t-if="not res_config.ks_show_logo"></div>
                        <!-- <div class="col-4 text-left" style="display: flex;justify-content: flex-start;align-items: center;" t-if="res_config.ks_show_logo">
                            <img style="max-width: 100%;" t-att-src="image_data_uri(o.company_id.logo)" alt="Logo"/>
                        </div> -->
                        <div t-attf-class="text-left #{res_config.display_large_logo and 'col-7' or 'col-4'}"
                            style="display: flex;justify-content: flex-start;align-items: center;"
                            t-if="res_config.ks_show_logo">
                            <img style="max-width: 100%;" t-if="o.company_id.logo"
                                t-att-src="image_data_uri(o.company_id.logo)" alt="Logo"/>
                        </div>
                        <div class="col-3" t-if="not res_config.display_large_logo">
                            <div t-if="res_config.ks_show_company">
                                <p class=" pl-2 ks_show_tagline mb-0">
                                    <span t-if="res_config.company_id.ks_report_company_title and res_config.ks_show_company" class="d-block ks_company_name">
                                        <span style="font-size: 95%;color:black;font-weight:bold;" t-esc="res_config.company_id.ks_report_company_title"/>
                                    </span>
                                    <span t-if="not res_config.company_id.ks_report_company_title and res_config.ks_show_company" class="d-block ks_company_name">
                                        <span style="font-size: 95%;color:black;font-weight:bold;" t-field="company.name"/>
                                    </span>
                                    <span t-if="res_config.ks_show_tagline" class="d-block ks_company_tagline">
                                        <t t-if="company.report_header">
                                            <span t-field="company.report_header"/>
                                        </t>
                                        <t t-else="">
                                            Company Tag Line
                                        </t>
                                    </span>
                                </p>
                            </div>
                        </div>
                        <div class="col-6 text-left">
                            <table>
                                <tr>
                                    <div t-if="res_config.ks_display_company" style="font-size: 125%;color:black;">
                                        <t t-set="company_name" t-value="o.company_id.name or ''"/>
                                        <t t-if="res_config.ks_company_name_bold">
                                            <b>
                                                <t t-if="res_config.is_name_split_required">
                                                    <t t-set="parts" t-value="company_name.strip().split(' ', 1)"/>
                                                    <span t-esc="parts[0]"/><br/>
                                                    <span t-esc="parts[1]"/>
                                                </t>
                                                <t t-else="">
                                                    <span t-esc="company_name"/>
                                                </t>
                                            </b>
                                        </t>
                                        <t t-else="">
                                            <t t-if="res_config.is_name_split_required">
                                                <t t-set="parts" t-value="company_name.strip().split(' ', 1)"/>
                                                <span t-esc="parts[0]"/><br/>
                                                <span t-esc="parts[1]"/>
                                            </t>
                                            <t t-else="">
                                                <span t-esc="company_name"/>
                                            </t>
                                        </t>
                                        <br/>
                                    </div>
                                   <t t-if="res_config.show_comma">
                                    <div t-if="res_config.ks_address">
                                        <t t-if="o.company_id.street">
                                            <span t-field="o.company_id.street"/>
                                            <t t-if="o.company_id.city or o.company_id.state_id or o.company_id.zip or o.company_id.street2 or o.company_id.country_id and res_config.show_country">,</t>
                                        </t>
                                        <t t-if="o.company_id.street2">
                                            <span t-field="o.company_id.street2"/>
                                            <t t-if="o.company_id.state_id or o.company_id.zip or o.company_id.city or o.company_id.country_id and res_config.show_country">,</t>
                                        </t>
                                    </div>
                                    <div t-if="res_config.ks_address">
                                        <t t-if="o.company_id.city">
                                            <span t-field="o.company_id.city"/>
                                            <t t-if="o.company_id.state_id or o.company_id.zip or o.company_id.country_id and res_config.show_country">,</t>
                                        </t>
                                        <t t-if="o.company_id.state_id">
                                            <span t-field="o.company_id.state_id.name"/>
                                            <t t-if="o.company_id.zip or o.company_id.country_id and res_config.show_country">,</t>
                                        </t>
                                        <t t-if="o.company_id.country_id and res_config.show_country">
                                            <span t-esc="o.company_id.country_id.name"/>
                                            <t t-if="o.company_id.zip">,</t>
                                        </t>
                                        <t t-if="o.company_id.zip">
                                            <span t-field="o.company_id.zip"/>
                                        </t>
                                    </div>
                                   </t>
                                   <t t-else="">
                                    <div t-if="res_config.ks_address">
                                        <t t-if="o.company_id.street">
                                            <span t-field="o.company_id.street"/>
                                        </t>
                                        <t t-if="o.company_id.street2">
                                            <span t-field="o.company_id.street2"/>
                                        </t>
                                    </div>
                                    <div t-if="res_config.ks_address">
                                        <t t-if="o.company_id.city">
                                            <span t-field="o.company_id.city"/>
                                        </t>
                                        <t t-if="o.company_id.state_id">
                                            <span t-field="o.company_id.state_id.name"/>
                                        </t>
                                        <t t-if="o.company_id.country_id and res_config.show_country">
                                            <span t-esc="o.company_id.country_id.name"/>
                                        </t>
                                        <t t-if="o.company_id.zip">
                                            <span t-field="o.company_id.zip"/>
                                        </t>
                                    </div>
                                   </t>
                                </tr>
                                <tr>
                                    <td t-if="res_config.show_uen_no and res_config.reg_no_type == 'gst'">
                                        UEN: <span t-esc="res_config.company_id.l10n_sg_unique_entity_number"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td t-if="res_config.show_reg_no and res_config.reg_no_type == 'uen' and company.partner_id.l10n_sg_unique_entity_number">
                                        UEN: <span t-field="o.company_id.partner_id.l10n_sg_unique_entity_number"/>
                                    </td>
                                    <td t-if="res_config.show_reg_no and res_config.reg_no_type == 'gst' and company.partner_id.vat">
                                        GST Reg No: <span t-field="o.company_id.partner_id.vat"/>
                                    </td>
                                
                                    <t t-if="not o.company_id.l10n_sg_unique_entity_number and o.company_id.company_registry">
                                        <td>
                                            UEN:<span t-field="o.company_id.company_registry"/>
                                        </td>
                                    </t>
                                </tr>
                                <tr>
                                    <td t-if="company.partner_id.phone and res_config.phone">
                                        Phone: <span t-field="o.company_id.phone"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td t-if="company.partner_id.email and res_config.email">
                                        Email: <span t-field="o.company_id.email"/>
                                    </td>
                                </tr>
                            </table>
                            <br/>
                        </div>
                    </div>
                    <div class="row" t-if="res_config.show_report_header_position == 'left'">
                    <div class="col-5 text-left">
                        <table>
                            <tr>
                                <div t-if="res_config.ks_display_company" style="font-size: 125%;color:black;">
                                    <t t-set="company_name" t-value="o.company_id.name or ''"/>
                                    <t t-if="res_config.ks_company_name_bold">
                                        <b>
                                            <t t-if="res_config.is_name_split_required">
                                                <t t-set="parts" t-value="company_name.strip().split(' ', 1)"/>
                                                <span t-esc="parts[0]"/><br/>
                                                <span t-esc="parts[1]"/>
                                            </t>
                                            <t t-else="">
                                                <span t-esc="company_name"/>
                                            </t>
                                        </b>
                                    </t>
                                    <t t-else="">
                                        <t t-if="res_config.is_name_split_required">
                                            <t t-set="parts" t-value="company_name.strip().split(' ', 1)"/>
                                            <span t-esc="parts[0]"/><br/>
                                            <span t-esc="parts[1]"/>
                                        </t>
                                        <t t-else="">
                                            <span t-esc="company_name"/>
                                        </t>
                                    </t>
                                    <br/>
                                </div>
                                <t t-if="res_config.show_comma">
                                    <div t-if="res_config.ks_address">
                                        <t t-if="o.company_id.street">
                                            <span t-field="o.company_id.street"/>
                                            <t t-if="o.company_id.city or o.company_id.state_id or o.company_id.zip or o.company_id.street2 or o.company_id.country_id and res_config.show_country">,</t>
                                        </t>
                                        <t t-if="o.company_id.street2">
                                            <span t-field="o.company_id.street2"/>
                                            <t t-if="o.company_id.state_id or o.company_id.zip or o.company_id.city or o.company_id.country_id and res_config.show_country">,</t>
                                        </t>
                                    </div>
                                    <div t-if="res_config.ks_address">
                                        <t t-if="o.company_id.city">
                                            <span t-field="o.company_id.city"/>
                                            <t t-if="o.company_id.state_id or o.company_id.zip or o.company_id.country_id and res_config.show_country">,</t>
                                        </t>
                                        <t t-if="o.company_id.state_id">
                                            <span t-field="o.company_id.state_id.name"/>
                                            <t t-if="o.company_id.zip or o.company_id.country_id and res_config.show_country">,</t>
                                        </t>
                                        <t t-if="o.company_id.country_id and res_config.show_country">
                                            <span t-esc="o.company_id.country_id.name"/>
                                            <t t-if="o.company_id.zip">,</t>
                                        </t>
                                        <t t-if="o.company_id.zip">
                                            <span t-field="o.company_id.zip"/>
                                        </t>
                                    </div>
                                </t>
                                <t t-else="">
                                    <div t-if="res_config.ks_address">
                                        <t t-if="o.company_id.street">
                                            <span t-field="o.company_id.street"/>
                                        </t>
                                        <t t-if="o.company_id.street2">
                                            <span t-field="o.company_id.street2"/>
                                        </t>
                                    </div>
                                    <div t-if="res_config.ks_address">
                                        <t t-if="o.company_id.city">
                                            <span t-field="o.company_id.city"/>
                                        </t>
                                        <t t-if="o.company_id.state_id">
                                            <span t-field="o.company_id.state_id.name"/>
                                        </t>
                                        <t t-if="o.company_id.country_id and res_config.show_country">
                                            <span t-esc="o.company_id.country_id.name"/>
                                        </t>
                                        <t t-if="o.company_id.zip">
                                            <span t-field="o.company_id.zip"/>
                                        </t>
                                    </div>
                                </t>
                            </tr>
                            <tr>
                                <td t-if="res_config.show_uen_no and res_config.reg_no_type == 'gst'">
                                    UEN: <span t-esc="res_config.company_id.l10n_sg_unique_entity_number"/>
                                </td>
                            </tr>
                            <tr>
                                <td t-if="res_config.show_reg_no and res_config.reg_no_type == 'uen' and company.partner_id.l10n_sg_unique_entity_number">
                                    UEN: <span t-field="o.company_id.partner_id.l10n_sg_unique_entity_number"/>
                                </td>
                                <td t-if="res_config.show_reg_no and res_config.reg_no_type == 'gst' and company.partner_id.vat">
                                    GST Reg No: <span t-field="o.company_id.partner_id.vat"/>
                                </td>
                                <t t-if="not o.company_id.l10n_sg_unique_entity_number and o.company_id.company_registry">
                                    <td>
                                        UEN:<span t-field="o.company_id.company_registry"/>
                                    </td>
                                </t>
                            </tr>
                            <tr>
                                <td t-if="company.partner_id.phone and res_config.phone">
                                    Phone: <span t-field="o.company_id.phone"/>
                                </td>
                            </tr>
                            <tr>
                                <td t-if="company.partner_id.email and res_config.email">
                                    Email: <span t-field="o.company_id.email"/>
                                </td>
                            </tr>
                        </table>
                        <br/>
                    </div>
                    <div class="col-4 text-center" t-if="not res_config.display_large_logo">
                        <div t-if="res_config.ks_show_company or res_config.ks_show_tagline">
                            <p class=" pl-2 ks_show_tagline mb-0">
                                <span t-if="res_config.company_id.ks_report_company_title and res_config.ks_show_company" class="d-block ks_company_name">
                                    <span style="font-size: 95%;color:black;font-weight:bold;" t-esc="res_config.company_id.ks_report_company_title"/>
                                </span>
                                <span t-if="not res_config.company_id.ks_report_company_title and res_config.ks_show_company" class="d-block ks_company_name">
                                    <span style="font-size: 95%;color:black;font-weight:bold;" t-field="company.name"/>
                                </span>
                                <span t-if="res_config.ks_show_tagline" class="d-block ks_company_tagline">
                                    <t t-if="company.report_header">
                                        <span t-field="company.report_header"/>
                                    </t>
                                    <t t-else="">
                                        Company Tag Line
                                    </t>
                                </span>
                            </p>
                        </div>
                    </div>
                    <div class="col-3" t-if="not res_config.ks_show_logo"></div>
                    <!-- <div class="col-3 text-left" style="display: flex;justify-content: flex-start;align-items: center;" t-if="res_config.ks_show_logo">
                        <img style="max-width: 100%;" t-if="o.company_id.logo" t-att-src="image_data_uri(o.company_id.logo)" alt="Logo"/>
                    </div> -->
                    <div t-attf-class="text-left #{res_config.display_large_logo and 'col-7' or 'col-3'}"
                        style="display: flex;justify-content: flex-start;align-items: center;"
                        t-if="res_config.ks_show_logo">
                        <img style="max-width: 100%;" t-if="o.company_id.logo"
                            t-att-src="image_data_uri(o.company_id.logo)" alt="Logo"/>
                    </div>
                </div>
                 <!--Header With Center Aligned-->
                <div class="row" t-if="res_config.show_report_header_position == 'center'">
                    <div class="col-4" t-if="not res_config.ks_show_logo"></div>
                    <div t-attf-class="text-left #{res_config.display_large_logo and 'col-4' or 'col-4'}"
                        style="display: flex;justify-content: flex-start;align-items: center;"
                        t-if="res_config.ks_show_logo">
                        <img style="max-width: 100%;" t-if="o.company_id.logo"
                            t-att-src="image_data_uri(o.company_id.logo)" alt="Logo"/>
                    </div>
                    <div class="col-4">
                        <table>
                            <tr>
                                <div t-if="res_config.ks_display_company" style="font-size: 125%;color:black;">
                                    <t t-set="company_name" t-value="o.company_id.name or ''"/>
                                    <t t-if="res_config.ks_company_name_bold">
                                        <b>
                                            <t t-if="res_config.is_name_split_required">
                                                <t t-set="parts" t-value="company_name.strip().split(' ', 1)"/>
                                                <span t-esc="parts[0]"/><br/>
                                                <span t-esc="parts[1]"/>
                                            </t>
                                            <t t-else="">
                                                <span t-esc="company_name"/>
                                            </t>
                                        </b>
                                    </t>
                                    <t t-else="">
                                        <t t-if="res_config.is_name_split_required">
                                            <t t-set="parts" t-value="company_name.strip().split(' ', 1)"/>
                                            <span t-esc="parts[0]"/><br/>
                                            <span t-esc="parts[1]"/>
                                        </t>
                                        <t t-else="">
                                            <span t-esc="company_name"/>
                                        </t>
                                    </t>
                                    <br/>
                                </div>
                                <t t-if="res_config.show_comma">
                                    <div t-if="res_config.ks_address">
                                        <t t-if="o.company_id.street">
                                            <span t-field="o.company_id.street"/>
                                            <t t-if="o.company_id.city or o.company_id.state_id or o.company_id.zip or o.company_id.street2 or o.company_id.country_id and res_config.show_country">,</t>
                                        </t>
                                        <t t-if="o.company_id.street2">
                                            <span t-field="o.company_id.street2"/>
                                            <t t-if="o.company_id.state_id or o.company_id.zip or o.company_id.city or o.company_id.country_id and res_config.show_country">,</t>
                                        </t>
                                    </div>
                                    <div t-if="res_config.ks_address">
                                        <t t-if="o.company_id.city">
                                            <span t-field="o.company_id.city"/>
                                            <t t-if="o.company_id.state_id or o.company_id.zip or o.company_id.country_id and res_config.show_country">,</t>
                                        </t>
                                        <t t-if="o.company_id.state_id">
                                            <span t-field="o.company_id.state_id.name"/>
                                            <t t-if="o.company_id.zip or o.company_id.country_id and res_config.show_country">,</t>
                                        </t>
                                        <t t-if="o.company_id.country_id and res_config.show_country">
                                            <span t-esc="o.company_id.country_id.name"/>
                                            <t t-if="o.company_id.zip">,</t>
                                        </t>
                                        <t t-if="o.company_id.zip">
                                            <span t-field="o.company_id.zip"/>
                                        </t>
                                    </div>
                                </t>
                                <t t-else="">
                                    <div t-if="res_config.ks_address">
                                        <t t-if="o.company_id.street">
                                            <span t-field="o.company_id.street"/>
                                        </t>
                                        <t t-if="o.company_id.street2">
                                            <span t-field="o.company_id.street2"/>
                                        </t>
                                    </div>
                                    <div t-if="res_config.ks_address">
                                        <t t-if="o.company_id.city">
                                            <span t-field="o.company_id.city"/>
                                        </t>
                                        <t t-if="o.company_id.state_id">
                                            <span t-field="o.company_id.state_id.name"/>
                                        </t>
                                        <t t-if="o.company_id.country_id and res_config.show_country">
                                            <span t-esc="o.company_id.country_id.name"/>
                                        </t>
                                        <t t-if="o.company_id.zip">
                                            <span t-field="o.company_id.zip"/>
                                        </t>
                                    </div>
                                </t>
                            </tr>
                            <tr>
                                <td t-if="res_config.show_uen_no and res_config.reg_no_type == 'gst'">
                                    UEN: <span t-esc="res_config.company_id.l10n_sg_unique_entity_number"/>
                                </td>
                            </tr>
                            <tr>
                                <td t-if="res_config.show_reg_no and res_config.reg_no_type == 'uen' and company.partner_id.l10n_sg_unique_entity_number">
                                    UEN: <span t-field="o.company_id.partner_id.l10n_sg_unique_entity_number"/>
                                </td>
                                <td t-if="res_config.show_reg_no and res_config.reg_no_type == 'gst' and company.partner_id.vat">
                                    GST Reg No: <span t-field="o.company_id.partner_id.vat"/>
                                </td>
                            
                                <t t-if="not o.company_id.l10n_sg_unique_entity_number and o.company_id.company_registry">
                                    <td>
                                        UEN:<span t-field="o.company_id.company_registry"/>
                                    </td>
                                </t>
                            </tr>
                            <tr>
                                <td t-if="company.partner_id.phone and res_config.phone">
                                    Phone: <span t-field="o.company_id.phone"/>
                                </td>
                            </tr>
                            <tr>
                                <td t-if="company.partner_id.email and res_config.email">
                                    Email: <span t-field="o.company_id.email"/>
                                </td>
                            </tr>
                        </table>
                        <br/>
                    </div>
                    <div class="col-4 text-left" t-if="not res_config.display_large_logo">
                        <div t-if="res_config.ks_show_company">
                            <p class=" pl-2 ks_show_tagline mb-0">
                                <span t-if="res_config.company_id.ks_report_company_title and res_config.ks_show_company" class="d-block ks_company_name">
                                    <span style="font-size: 95%;color:black;font-weight:bold;" t-esc="res_config.company_id.ks_report_company_title"/>
                                </span>
                                <span t-if="not res_config.company_id.ks_report_company_title and res_config.ks_show_company" class="d-block ks_company_name">
                                    <span style="font-size: 95%;color:black;font-weight:bold;" t-field="company.name"/>
                                </span>
                                <span t-if="res_config.ks_show_tagline" class="d-block ks_company_tagline">
                                    <t t-if="company.report_header">
                                        <span t-field="company.report_header"/>
                                    </t>
                                    <t t-else="">
                                        Company Tag Line
                                    </t>
                                </span>
                            </p>
                        </div>
                    </div>
                </div>
                <!--END HEADER-->
                </div>
            </div>
            <div class="article o_report_layout_boxed" t-att-data-oe-model="o and o._name" t-att-data-oe-id="o and o.id" t-att-data-oe-lang="o and o.env.context.get('lang')">
                <t t-call="web.address_layout"/>
                <t t-raw="0"/>
            </div>
            <div t-attf-class="footer o_boxed_footer o_company_#{company.id}_layout">
                <div class="text-center">
                    <div t-if="report_type == 'pdf'">
                        Page:
                        <span class="page"/>
                        /
                        <span class="topage"/>
                    </div>
                </div>
            </div>
        </template>
    
    <!--  Overriden  -->
        <template id="account.report_payment_receipt">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-call="ks_custom_report_layouts.report_payment_receipt_inherit_document" t-lang="o.partner_id.lang"/>
                </t>
            </t>
        </template>
    </data>
</odoo>
