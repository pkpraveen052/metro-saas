<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record model="ir.ui.view" id="ks_invoice_account_form_view_inherits">
        <field name="name">account.move.form</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[hasclass('oe_subtotal_footer')]" position="after">
                <group colspan="4">
                    <field name="ks_total_amount_in_words"/>
                    <field name="company_country_code" invisible="1"/>
                </group>
            </xpath>
            <xpath expr="//group[@id='other_tab_group']" position="inside">
                <group string="PayNow QR Code" col="2" attrs="{'invisible': ['|',('company_country_code', '!=', 'SG'),('move_type', '!=', 'out_invoice')]}">
                    <label for="uen_number"/>
                    <div class="o_row">
                        <field name="uen_number" readonly="1"/>
                        <field name="use_uen_number" widget="boolean_toggle"/>
                    </div>
                
                    <label for="alt_uen_number"/>
                    <div class="o_row">
                        <field name="alt_uen_number"/>
                        <field name="use_alt_uen_number" widget="boolean_toggle"/>
                    </div>
                
                    <label for="mobile_number"/>
                    <div class="o_row">
                        <field name="mobile_number"/>
                        <field name="use_mobile_number" widget="boolean_toggle"/>
                    </div>
                </group>
            </xpath>
        </field>
    </record>

</odoo>