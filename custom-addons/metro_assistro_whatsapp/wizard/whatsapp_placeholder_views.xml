<?xml version="1.0" encoding="UTF-8"?>
<odoo> 
   <data>
      <record id="view_whatsapp_placeholder_wizard_form" model="ir.ui.view">
        <field name="name">whatsapp.placeholder.wizard.form</field>
        <field name="model">whatsapp.placeholder.wizard</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="placeholder" widget="selection"/>
                    </group>
                    <footer>
                        <button string="Insert" type="object" name="action_insert_placeholder" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>
   </data>
</odoo>