<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="stock_picking_inherited_form_view2" model="ir.ui.view">
            <field name="name">stock.picking.form.view.inherited</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.view_picking_form"/>
            <field name="arch" type="xml">
                <xpath expr="//header/button[@name='action_cancel']" position="before">
                    <button name="action_open_whatsapp_composer" string="Send by Whatsapp" icon="fa-whatsapp" class="oe_highlight" type="object"
                    attrs="{'invisible': [('use_assistro', '=', False)]}"/>
                    <field name="use_assistro" invisible="1"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
