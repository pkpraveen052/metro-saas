<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

        <record id="mail_template_service_send_by_mail" model="mail.template">
            <field name="name">Service Request Mail</field>
            <field name="model_id" ref="metroerp_service_management.model_service_management"/>
            <field name="subject">${object.company_id.name} ${'Service'} (Ref ${object.name or 'n/a' })</field>
            <field name="email_from">"${object.company_id.name | safe}" &lt;${(object.company_id.email or user.email) | safe}&gt;</field>
            <field name="email_to">${object.partner_id.email}</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p style="margin: 0px; padding: 0px; font-size: 13px;">
                        Dear ${object.partner_id.name},<br/><br/>
                        Your ${object.template_id.name} is now completed. Thank you for choosing us!
                        <br/><br/>
                        <p>Best regards, Thank you</p>
                    </p>
                </div>
            </field>
<!--            <field name="report_template" ref="stock.action_report_delivery"/>-->
<!--            <field name="report_name">${(object.name or '').replace('/','_')}</field>-->
            <field name="lang">${object.partner_id.lang}</field>
            <field name="auto_delete" eval="True"/>
        </record>
</odoo>