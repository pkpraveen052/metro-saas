<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_service_template_form" model="ir.ui.view">
        <field name="name">service.template.form</field>
        <field name="model">service.template</field>
        <field name="arch" type="xml">
            <form string="Service Template">
                <header>
                    <button name="action_open_create_dynamic_fields"
                            string="Create Field" type="object"
                            class="oe_highlight"

                    />
                    <button name="action_open_create_dynamic_group"
                            string="Create Group" type="object"
                            class="oe_highlight"

                    />
                </header>
                <sheet>
                    <group>
                        <group name="service_template">
                            <field name="name"/>
                            <field name="report_docx_template"/>
                            <field name="report_id"/>
                            <field name="company_id" required="1"/>
                        </group>
                    </group>
                    <notebook>
                        <!-- First Page: Custom Fields -->
                        <page string="Custom Fields">
                            <field name="field_ids">
                                <tree editable="bottom">
                                    <field name="name"/>
                                    <field name="field_description"/>
                                    <field name="model_id"/>
                                    <field name="field_type"/>
                                    <field name="form_view_id"/>
                                    <field name="template_id"/>
                                    <field name="company_id" required="1"/>
                                </tree>
                            </field>
                        </page>

                        <!-- Second Page: Custom Groups -->
                        <page string="Custom Groups">
                            <field name="custom_group_ids">
                                <tree editable="bottom">
                                    <field name="name"/>
                                    <field name="group_string"/>
                                    <field name="template_id"/>
                                    <field name="company_id" required="1"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="service_template_view_kanban" model="ir.ui.view">
        <field name="name">service.template.dashboard</field>
        <field name="model">service.template</field>
        <field name="arch" type="xml">
            <kanban class="oe_background_grey o_kanban_dashboard o_emphasize_colors o_fs_kanban" create="1">
                <field name="name"/>
                <field name="color"/>
                <field name="tech_name"/>
                <field name="sequence"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="#{!selection_mode ? kanban_color(record.color.raw_value) : ''}">
                            <span class="oe_kanban_color_help"
                                  t-attf-title="In #{kanban_getcolorname(record.color.raw_value)}" role="img"
                                  t-attf-aria-label="In #{kanban_getcolorname(record.color.raw_value)}"/>
                            <div t-attf-class="o_kanban_card_header">
                                <div class="o_kanban_card_header_title">
                                    <div class="o_primary" style="font-size: 20px !important;">
                                        <field name="name"/>
                                    </div>
                                </div>
                                <div class="o_kanban_manage_button_section" t-if="!selection_mode"
                                >
                                    <!--                                    groups="metro_helpdesk.group_helpdesk_manager"-->
                                    <a class="o_kanban_manage_toggle_button" href="#">
                                        <i class="fa fa-ellipsis-v" role="img" aria-label="Manage" title="Manage"/>
                                    </a>
                                </div>
                            </div>
                            <div class="container o_kanban_card_content" t-if="!selection_mode"
                            >
                                <!--                                attrs="{'invisible': [('tech_name','!=','sf')]}"-->
                                <div class="row">
                                    <div class="col-6 o_kanban_primary_left">
                                        <button class="btn btn-primary" name="action_view_sf" type="object">View
                                        </button>
                                        <button class="btn btn-primary" name="action_assign_request" type="object">
                                            Assign Request
                                        </button>
                                        <!--                                        <button class="btn btn-primary" name="action_create_sf" type="object">Create-->
                                        <!--                                        </button>-->
                                    </div>
                                </div>
                            </div>
                            <div class="container o_kanban_card_manage_pane dropdown-menu" role="menu">
                                <div t-if="widget.editable" class="o_kanban_card_manage_settings row">
                                    <div role="menuitem" aria-haspopup="true" class="col-8">
                                        <ul class="oe_kanban_colorpicker" data-field="color" role="menu"/>
                                    </div>
                                    <div role="menuitem" class="col-4 text-right">
                                        <a type="edit">Settings</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_service_template_tree" model="ir.ui.view">
        <field name="name">view_service_template_tree</field>
        <field name="model">service.template</field>
        <field name="arch" type="xml">
            <tree string="Service template">
                <field name="name"/>
                <field name="company_id"/>
            </tree>
        </field>
    </record>

    <record id="action_service_template_button" model="ir.actions.act_window">
        <field name="name">Service Template</field>
        <field name="res_model">service.template</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_service_template_tree"/>
    </record>

    <record id="action_service_template_dashboard" model="ir.actions.act_window">
        <field name="name">Service Template</field>
        <field name="res_model">service.template</field>
        <field name="view_mode">kanban</field>
        <field name="view_id" ref="service_template_view_kanban"/>
    </record>


</odoo>