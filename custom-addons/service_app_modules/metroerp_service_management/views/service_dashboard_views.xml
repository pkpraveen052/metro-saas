<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="service_dashboard_view_tree" model="ir.ui.view">
        <field name="name">service.dashboard.tree</field>
        <field name="model">service.dashboard</field>
        <field name="arch" type="xml">
            <tree string="Service Dashboard" multi_edit="1" sample="1">
                <field name="sequence" widget="handle"/>
                <field name="name" class="field_name"/>
                <field name="tech_name"/>
            </tree>
        </field>
    </record>

    <record id="service_dashboard_view_form" model="ir.ui.view">
        <field name="name">service.dashboard.form</field>
        <field name="model">service.dashboard</field>
        <field name="arch" type="xml">
            <form string="fs search" class="oe_form_configuration" create="0" delete="0" edit="0">
                <sheet>
                    <div class="oe_title" id='title'>
                        <label for="name" class="oe_edit_only"/>
                        <h1 id="name">
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="tech_name" readonly="1"/>
                            <field name="sequence" readonly="1"/>
                        </group>
                        <group/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="service_dashboard_view_kanban" model="ir.ui.view">
        <field name="name">service.dashboard.dashboard</field>
        <field name="model">service.dashboard</field>
        <field name="arch" type="xml">
            <kanban class="oe_background_grey o_kanban_dashboard o_emphasize_colors o_fs_kanban" create="0">
                <field name="name"/>
                <field name="color"/>
                <field name="tech_name"/>
                <field name="sequence"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="#{!selection_mode ? kanban_color(record.color.raw_value) : ''}">
                            <span class="oe_kanban_color_help"
                                  t-attf-title="In #{kanban_getcolorname(record.color.raw_value)}" role="img"
                                  t-attf-aria-label="In #{kanban_getcolorname(record.color.raw_value)}"/>
                            <div t-attf-class="o_kanban_card_header">
                                <div class="o_kanban_card_header_title">
                                    <div class="o_primary" style="font-size: 20px !important;">
                                        <field name="name"/>
                                    </div>
                                </div>
                                <div class="o_kanban_manage_button_section" t-if="!selection_mode"
                                     groups="metro_helpdesk.group_helpdesk_manager">
                                    <a class="o_kanban_manage_toggle_button" href="#">
                                        <i class="fa fa-ellipsis-v" role="img" aria-label="Manage" title="Manage"/>
                                    </a>
                                </div>
                            </div>
                            <div class="container o_kanban_card_content" t-if="!selection_mode"
                                 attrs="{'invisible': [('tech_name','!=','sf')]}">
                                <div class="row">
                                    <div class="col-6 o_kanban_primary_left">
                                        <button class="btn btn-primary" name="action_view_sf" type="object">View
                                        </button>
                                        <button class="btn btn-primary" name="action_create_sf" type="object">Create
                                        </button>
                                    </div>
                                </div>
                            </div>
                            <div class="container o_kanban_card_manage_pane dropdown-menu" role="menu">
                                <div t-if="widget.editable" class="o_kanban_card_manage_settings row">
                                    <div role="menuitem" aria-haspopup="true" class="col-8">
                                        <ul class="oe_kanban_colorpicker" data-field="color" role="menu"/>
                                    </div>
                                    <div role="menuitem" class="col-4 text-right">
                                        <a type="edit">Settings</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="service_dashboard_dashboard_action_main" model="ir.actions.act_window">
        <field name="name">Dashboard</field>
        <field name="res_model">service.dashboard</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="context">{}</field>
        <field name="view_id" ref="metroerp_service_management.service_dashboard_view_kanban"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No records found
            </p>
        </field>
    </record>

<!--    <menuitem id="menu_service_dashboard" action="metroerp_service_management.action_service_template_dashboard"-->
<!--        sequence="1" parent="metroerp_service_management.menu_service_root" name="Dashboard"/>-->


</odoo>