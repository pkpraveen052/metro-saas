<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record model="ir.ui.view" id="pos_config_form_view_inherit">
        <field name="name">pos.config.form.extended.view</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//div[@id='accounting_section']" position="after">
                <h2 name="order">Whatsapp Configuration</h2>
                <div class="row mt16 o_settings_container">
                    <div id="autocomplete_address" class="col-xs-12 col-md-6 o_setting_box">
                        <div class="o_setting_left_pane">
                            <field name="enable_whatsapp" />
                        </div>
                        <div class="o_setting_right_pane">
                            <label for="enable_whatsapp" />
                        </div><br/>
                        <div class="o_setting_right_pane">
                            <span class="o_form_label">Whatsapp Method</span>
                            <div class="text-muted">
                                Please select the method to send the whatsapp message
                            </div>
                            <field name="whatsapp_method"/>
                        </div>
                    </div>
                </div>
                <br />
            </xpath>
        </field>
    </record>
</odoo>
