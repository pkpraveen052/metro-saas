<?xml version="1.0" encoding="utf-8" ?>

<odoo>

    <record id="res_config_settings_view_carbonate" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.flavor</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="account.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//div[@name='fiscal_localization_setting_container']" position="after">
                    <h2>Carbonate</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-12 o_setting_box"
                            title="CorpPass Authentication">
                            <div class="o_setting_left_pane">
                                <field name="enable_carbonate_sync"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="enable_carbonate_sync"/>
                                <br/><br/>
                                <button name="action_auto_generate_token" string="Generate" type="object"
                                    attrs="{'invisible': ['|',('enable_carbonate_sync','=',False),('carbonate_token', '!=', False)]}" icon="fa-check-circle-o" class="oe_highlight"/>
                                <div class="content-group" attrs="{'invisible': [('enable_carbonate_sync','=',False)]}">
                                    <div class="row mt16">
                                        <label for="carbonate_token" string="Token" class="col-lg-3 o_light_label"/>
                                        <field name="carbonate_token" readonly="1"/>
                                    </div>
                                    <button name="action_auto_generate_token" string="Regenerate" type="object"
                                        attrs="{'invisible': ['|',('enable_carbonate_sync','=',False),('carbonate_token', '=', False)]}" icon="fa-check-circle-o" class="oe_highlight"/>
                                </div>
                                <!-- <br/>
                                <div class="content-group" attrs="{'invisible': [('enable_carbonate_sync','=',False)]}">
                                    <div class="row mt16">
                                        <label for="carbonate_token" string="Token" class="col-lg-3 o_light_label"/>
                                        <field name="carbonate_token" attrs="{'required': [('enable_carbonate_sync','=',True)]}"/>
                                    </div>
                                </div> -->
                            </div>
                        </div>
                    </div>
                </xpath>
            </field>
    </record>

</odoo>
