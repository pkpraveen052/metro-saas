        <record id="carbonate_log_logs_action_window" model="ir.actions.act_window">
            <field name="name">Carbonate Logs</field>
            <field name="res_model">carbonate.log</field>
            <field name="view_mode">tree,form,search</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                      Create new tags for your opportunities
                </p>
            </field>
        </record>
        

       <menuitem id="carbonate_logs_menu_root"
                  name="Carbonate Logs"
                  parent="base.menu_custom"
                  sequence="200"/>
        
        <menuitem id="carbonate_logs_menu"
                name="Carbonate Logs"
                parent="carbonate_logs_menu_root"
                action="carbonate_log_logs_action_window"
                groups="base.group_system"/>

       
</data>
</odoo>