<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        
        <record id="carbonate_log_logs_tree_view" model="ir.ui.view">
            <field name="name">carbonate.log.tree</field>
            <field name="model">carbonate.log</field>
            <field name="arch" type="xml">
                <tree create="false" delete="false" decoration-danger="status == 'fail'"
                decoration-success="status == 'success'">
                    <field name="company_id"/>
                    <field name="name"/>
                    <field name="create_date"/>
                    <field name="message"/>
                    <field name="status"/>
                    <field name="status_code"/>
                </tree>
            </field>
        </record>

        <record id="carbonate_log_logs_form_view" model="ir.ui.view">
            <field name="name">carbonate.log.form</field>
            <field name="model">carbonate.log</field>
            <field name="arch" type="xml">
                <form create="false" delete="false" edit="false">
                    <header>
                        <field name="status" widget="statusbar" statusbar_visible="success,fail" class="oe_highlight"/>
                    </header>
                    <sheet>
                       <group>
                            <group>
                                <field name="company_id"/>
                                <field name="name"/>
                                <field name="create_date"/>
                                <field name="status_code"/>
                            </group>
                            <group string="Description">
                                <field name="json_data"/>
                                 <field name="message"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

