<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="iras_coa_mapping_tree_view" model="ir.ui.view">
            <field name="name">iras.coa.mapping.tree</field>
            <field name="model">iras.coa.mapping</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="description"/>
                    <field name="account_ids" widget="many2many_tags"/>
                    <field name="direct_mapping" optional="hide"/>
                    <field name="date_as_of" optional="hide"/>
                    <field name="reverse_sign" optional="hide"/>
                </tree>
            </field>
        </record>

        <record id="iras_coa_mapping_form_view" model="ir.ui.view">
            <field name="name">iras.coa.mapping.from</field>
            <field name="model">iras.coa.mapping</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="description"/>
                            </group>
                            <group>
                                <field name='account_ids' widget="many2many_tags"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Technical">
                                <group>
                                    <group>
                                        <field name="direct_mapping"/>
                                    </group>
                                    <group>
                                        <field name="date_as_of" invisible="1"/>
                                    </group>
                                    <group>
                                        <field name="reverse_sign" invisible="1"/>
                                    </group>
                                    <group/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record model="ir.actions.act_window" id="action_iras_coa_mapping">
            <field name="name">COA Mapping</field>
            <field name="res_model">iras.coa.mapping</field>
            <field name="view_mode">tree,form</field>
        </record>
        
        <menuitem id="menu_iras_coa_mapping" name="COA Mapping"
              parent="menu_iras_config_technical"
              action="action_iras_coa_mapping"
              sequence="0"
              groups="base.group_system"/>

    </data>
</odoo>
