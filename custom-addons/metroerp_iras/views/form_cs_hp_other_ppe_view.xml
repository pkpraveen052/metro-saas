<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--    hp.other.ppe.form   -->
    <record id="hp_other_ppe_form" model="ir.ui.view">
        <field name="name">hp.other.ppe.form</field>
        <field name="model">hp.other.ppe</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group name="grp_main">
                        <div></div>
                        <field name="descriptionEachAsset"/>
                        <field name="yaOfPurchaseEachAsset"/>
                        <field name="costEachAsset"/>
                        <field name="salesProceedEachAsset"/>
                        <field name="yaOfDisposalEachAsset"/>
                        <field name="depositOrPrincipalExcluding"/>
                        <field name="depositOrPrincipalMinus1"/>
                        <field name="depositOrPrincipalMinus2"/>
                        <field name="totalPrincipalTillDateEachAsset"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="hp_other_ppe_tree" model="ir.ui.view">
        <field name="name">hp.other.ppe.tree</field>
        <field name="model">hp.other.ppe</field>
        <field name="arch" type="xml">
            <tree>
                <field name="descriptionEachAsset"/>
                <field name="yaOfPurchaseEachAsset"/>
                <field name="costEachAsset"/>
                <field name="salesProceedEachAsset"/>
                <field name="yaOfDisposalEachAsset"/>
                <field name="depositOrPrincipalExcluding"/>
                <field name="depositOrPrincipalMinus1"/>
                <field name="depositOrPrincipalMinus2"/>
                <field name="totalPrincipalTillDateEachAsset"/>
            </tree>
        </field>
    </record>

    <record id="hp_other_ppe_action" model="ir.actions.act_window">
        <field name="name">HP Other PPE</field>
        <field name="res_model">hp.other.ppe</field>
        <field name="view_mode">tree,form</field>
    </record>

