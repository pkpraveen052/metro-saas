                            <td style="padding:5px;font-weight: bold;vertical-align: text-top;">Box 1</td>
                            <td style="font-weight: bold;">Total value of standard-rated supplies</td>
                            <td style="vertical-align: text-top;"><field name="totStdSupply" attrs="{'readonly': [('state', 'in', ['ready_submit','submitted'])]}"/></td>
                        </tr>
                        <tr style="border-bottom: 1px solid #dddd;border-top: 1px solid #dddd;">
