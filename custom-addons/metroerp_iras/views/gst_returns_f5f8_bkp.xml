                            <separator string="Request JSON" attrs="{'invisible': [('state', 'not in', ['ready_submit','submitted'])]}" groups="metroerp_customizations.sub_admin_group,base.group_system"/> 
                            <button string="Generate JSON Request" type="object" name="generate_json_request" attrs="{'invisible': [('state', 'not in', ['ready_submit','submitted'])]}" groups="metroerp_customizations.sub_admin_group,base.group_system"/><br/>
                            <div attrs="{'invisible': [('json_iras', '=', False)]}" groups="metroerp_customizations.sub_admin_group,base.group_system">
                                <field name="json_iras" nolabel="1" readonly="1"/>                            
                            </div>
                        </page>
                        <page string="Declaration" attrs="{'invisible': [('state', 'not in', ['ready_submit','submitted'])]}">
                            <group>
                                <field name="signed_by" readonly="1"/>
                                <field name="manager_signature_done" invisible="1"/>
                                <field name="manager_signature" widget="signature" attrs="{'readonly': [('manager_signature_done', '=', True)]}"/>
                            </group>
                        </page>
                        <page string="Final JSON Response" attrs="{'invisible': [('state', '!=', 'submitted')]}">
                            <field name="json_response" nolabel="1"/>
                        </page>

                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="gst_returns_f5f8_tree" model="ir.ui.view">
        <field name="name">gst.returns.f5f8.tree</field>
        <field name="model">gst.returns.f5f8</field>
        <field name="arch" type="xml">
            <tree
                  decoration-info="state == 'ready_submit'" decoration-muted="state in ('submitted')" delete="false">
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="taxRefNo"/>
                <field name="formType"/>
                <field name="dtPeriodStart"/>
                <field name="dtPeriodEnd"/>
                <field name="create_date"/>
                <field name="state"/>            
            </tree>
        </field>
    </record>

    <record id="gst_returns_f5f8_kanban" model="ir.ui.view">
            <field name="name">gst.returns.f5f8.kanban</field>
            <field name="model">gst.returns.f5f8</field>
            <field name="arch" type="xml">
                <kanban class="o_kanban_mobile" delete="false">
                    <field name="company_id"/>
                    <field name="taxRefNo"/>
                    <field name="formType"/>
                    <field name="dtPeriodStart"/>
                    <field name="dtPeriodEnd"/>
                    <field name="state"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div t-attf-class="#{!selection_mode ? kanban_color(record.company_id) : ''} oe_kanban_global_click">
                                <div class="o_dropdown_kanban dropdown">

                                    <a class="dropdown-toggle o-no-caret btn" role="button" data-toggle="dropdown" data-display="static" href="#" aria-label="Dropdown menu" title="Dropdown menu">
                                        <span class="fa fa-ellipsis-v"/>
                                    </a>
                                    <div class="dropdown-menu" role="menu">
                                        <t t-if="widget.editable"><a role="menuitem" type="edit" class="dropdown-item">Edit</a></t>
                                        <t t-if="widget.deletable"><a role="menuitem" type="delete" class="dropdown-item">Delete</a></t>
                                    </div>
                                </div>
                                <div class="oe_kanban_content">
                                    <div class="o_kanban_record_title">
                                        <h3><field name="company_id"/></h3>
                                    </div>
                                    <div class="o_kanban_record_subtitle">
                                        <strong>Tax Reference(GST) No:</strong>
                                        <span><field name="taxRefNo"/></span><br/>
                                        <strong>Form Type:</strong>
                                        <span><field name="formType"/></span><br/>
                                        <strong>GST Start Period Date:</strong>
                                        <span><field name="dtPeriodStart"/></span><br/>
                                        <strong>GST End Period Date:</strong>
                                        <span><field name="dtPeriodEnd"/></span><br/>
                                        <strong>Status:</strong>
                                        <span><field name="state"/></span>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
    </record>

    <record id="gst_returns_f5f8_search_view" model="ir.ui.view">
        <field name="name">gst.returns.f5f8.search</field>
        <field name="model">gst.returns.f5f8</field>
        <field name="arch" type="xml">
            <search>
                <filter string="New" name="filter_state_new" domain="[('state', '=', 'new')]"/>
                <filter string="Draft" name="filter_state_draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Ready to Submit" name="filter_state_ready_submit" domain="[('state', '=', 'ready_submit')]"/>
                <filter string="Submitted" name="filter_state_submitted" domain="[('state', '=', 'submitted')]"/>
                <separator/>
                <filter string="Archived" name="filter_active_false" domain="[('active', '=',False)]"/>
                <group expand="1" string="Group By">
                    <filter string="Status" name="Status" context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="gst_returns_f5f8_action" model="ir.actions.act_window">
        <field name="name">GST Returns (F5 and F8)</field>
        <field name="res_model">gst.returns.f5f8</field>
        <field name="view_mode">kanban,tree,form</field>
    </record>

    <menuitem id="gst_returns_f5f8_menu"
        action="gst_returns_f5f8_action"
        parent="menu_iras_root"
        sequence="1" 
        groups="account.group_account_manager"/>

</odoo>
