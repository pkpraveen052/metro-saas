                        <field name="taxRefNo" attrs="{'readonly': [('state', 'in', ['ready_submit','submitted'])]}"/>
                        <field name="formType" attrs="{'readonly': [('state', 'in', ['ready_submit','submitted'])]}"/>
                        <field name="dtPeriodStart" attrs="{'readonly': [('state', 'in', ['ready_submit','submitted'])]}"/>
                        <field name="dtPeriodEnd" attrs="{'readonly': [('state', 'in', ['ready_submit','submitted'])]}"/>
                    </group>

