<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="gst_returns_signature_f5f8_form" model="ir.ui.view">
        <field name="name">gst.returns.f5f8.signature.form</field>
        <field name="model">gst.returns.f5f8</field>
        <field name="arch" type="xml">
            <form delete="false">
                <b>Place your signature and Submit</b>
                <group>
                    <field name="manager_signature" widget="signature" nolabel="1"/>
                </group>
                <footer>
                    <button string="Submit" name="action_submit" type="object" default_focus="1" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel" />
                </footer>
            </form>
        </field>
     </record>

    <record id="gst_returns_f5f8_form" model="ir.ui.view">
        <field name="name">gst.returns.f5f8.form</field>
        <field name="model">gst.returns.f5f8</field>
        <field name="priority" eval="1"/>
        <field name="arch" type="xml">
            <form delete="false">                
                <header>
                    <button name="fetch_details" string="Fetch" type="object" icon="fa-refresh" attrs="{'invisible': [('state','in',['ready_submit','submitted'])]}"/>
                    <button name="action_ready_submit" string="Ready to Submit" type="object"
                            attrs="{'invisible': [('state', '!=', 'draft')]}" icon="fa-thumbs-o-up" class="oe_highlight"/>
                    <button name="action_click_me_edit" string="Click Me to Edit" type="object"
                            attrs="{'invisible': [('state', '!=', 'ready_submit')]}" icon="fa-pencil-square-o"/>
                    <button name="action_submit" string="Submit" type="object"
                            attrs="{'invisible': [('state', '!=', 'ready_submit')]}" icon="fa-check-circle-o" class="oe_highlight"/>
                    <button name="autosubmit_gst_data" string="Force Submit" type="object"
                            attrs="{'invisible': [('state', '!=', 'ready_submit')]}" icon="fa-check-circle-o" class="oe_highlight" context="{'force_submit':1}"/>
                    <button name="action_claim_f7" string="Claim F7" type="object" icon="fa-file" class="oe_highlight"
                            attrs="{'invisible': ['|',('state', '!=', 'submitted'),('formType', '!=', 'F5')]}"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,ready_submit,submitted"/>
                </header>
                <sheet>
                    <div class="ribbon ribbon-top-right" style="margin-top:-53px;" attrs="{'invisible': [('online_gst_registered', '=', False)]}">
                        <span style="font-size: 12px;height:32px;width:278px;text-indent:-94px;padding:24px 44px;left: -15px;top: 30px;transform: rotate(360deg);padding: 0px !important" class="bg-info">GST Registered Online</span>
                    </div>
                    <div name="button_box" class="oe_button_box">
                        <button name="action_open_f7" class="oe_stat_button" icon="fa-file" type="object" attrs="{'invisible': [('gst_f7_id', '=', False)]}" string="Open GST F7" help="Open GST F7 forms">
                            </button>
                        <button name="check_gst_registered" class="oe_stat_button" icon="fa-check" type="object" attrs="{'invisible': [('online_gst_registered', '=', True)]}" string="Check GST Registered" help="Check GST Registered Online">
                        </button>
                    </div>                    
                    <group name="grp_main">
                        <field name="company_id"/>
