<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <data>
      <record id="inherit_account_chart_template_form" model="ir.ui.view">
            <field name="name">account.chart.template.form.inherit</field>
            <field name="model">account.chart.template</field>
            <field name="inherit_id" ref="account.view_account_chart_template_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form/group[2]" position="after">
                    <group>
                       <group string="IRAS Mapping" col="4">
                            <field name="iras_template_id"/>
                        </group>
                    </group>
                </xpath>
            </field>
        </record>
  </data>
</odoo>