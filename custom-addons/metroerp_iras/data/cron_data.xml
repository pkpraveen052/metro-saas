<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="form_cs_cron" model="ir.cron">
            <field name="name">Access Token Expired</field>
            <field name="model_id" ref="model_form_cs"/>
            <field name="state">code</field>
            <field name="code">model._cron_form_cs()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="active" eval="False"/>
        </record>

        <record id="form_gst_f5_reminder_cron" model="ir.cron">
            <field name="name">GST F5 Reminder</field>
            <field name="model_id" ref="model_gst_f5_auto_schedule"/>
            <field name="state">code</field>
            <field name="code">model._cron_gst_f5_reminder()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
        </record>
    </data>
</odoo>
