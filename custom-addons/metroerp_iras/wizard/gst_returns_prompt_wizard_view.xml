<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="gst_returns_prompt_wizard_view_sn7" model="ir.ui.view">
        <field name="name">GST Return Prompt</field>
        <field name="model">gst.returns.prompt.wizard</field>
        <field name="arch" type="xml">
            <form string="GST Return Prompt">
                <div>
                    <strong>
                        Standard-rated supplies is in positive value, output tax should not be in negative value. Please re-enter the value of output tax due.
                        Otherwise, please indicate reasons by clicking on the following:
                    </strong>
                </div><br/>
                <group>
                    <div>
                        <field name="gstOnBadDebtRecoveryChk"/>
                        <label for="gstOnBadDebtRecoveryChk"/>
                    </div><br/>
                    <div>
                        <field name="gstCollectedPriorToRegistrationChk"/>
                        <label for="gstCollectedPriorToRegistrationChk"/>
                    </div><br/>
                    <div>
                        <field name="otherReasonsChk" attrs="{'readonly': [('set_others_readonly','!=',False)]}" force_save="1"/>
                        <label for="otherReasonsChk"/>
                    </div><br/>
                    <field name="others_reason" attrs="{'required': [('otherReasonsChk', '=',True)],'invisible': [('otherReasonsChk', '!=', True)]}"/>
                    <field name="set_others_readonly" invisible="1"/>
                </group>
                <footer>
                    <button string="Proceed" name="action_proceed_sn7" type="object" default_focus="1" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel" />
                </footer>
            </form>
        </field>
    </record>

