<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_field_dynamic_tab_form" model="ir.ui.view">
        <field name="name">view_field_dynamic_tab_form</field>
        <field name="model">dynamic.field.tab</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name" string="Name"/>
                            <field name="tab_string" string="String"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_field_dynamic_tab_tree" model="ir.ui.view">
            <field name="name">view_field_dynamic_tab_tree</field>
            <field name="model">dynamic.field.tab</field>
            <field name="arch" type="xml">
                <tree string="Dynamic Tab">
                    <field name="name"/>
                </tree>
            </field>
        </record>

    <record id="action_field_dynamic_tab_button" model="ir.actions.act_window">
            <field name="name">Dynamic Tab</field>
            <field name="res_model">dynamic.field.tab</field>
            <field name="view_mode">tree,form</field>
            <field name="view_id" ref="view_field_dynamic_tab_tree"/>
        </record>

    <menuitem id="menu_dynamic_tab" parent="dynamic_fields_menu" name="Create Tab" action="action_field_dynamic_tab_button" sequence="3"/>

</odoo>