<?xml version="1.0"?>
<odoo>
	<data noupdate="0">

		<record id="email_template_customer_activity_statement" model="mail.template">
			<field name="name">Customer Activity Statement Email</field>
			<field name="email_from">${(user.email or '')|safe}</field>
			<field name="subject">${user.company_id.name} Activity Statement</field>
			<field name="partner_to">${object.id}</field>
			<field name="lang">${object.lang}</field>
			<field name="report_name">Activity Statement Report</field>
			<field name="model_id" ref="base.model_res_partner" />
			<field name="body_html" type="html">
				<div style="margin: 0px; padding: 0px;font-size: 13px;">
					<p>Dear ${object.name},</p>
					<p>
						Please find attached your activity statement.
						This document provides a detailed overview of your transactions and activities with us.
					</p>
					<p>Thank you for choosing ${user.company_id.name}.</p>
					<br/>
				</div>
        	</field>
        	<field name="lang">${object.lang}</field>
        	<field name="auto_delete" eval="True"/>
		</record>

		<record id="email_template_customer_outstanding_statement" model="mail.template">
				<field name="name">Customer Outstanding Statement Email</field>
			<field name="email_from">${(user.email or '')|safe}</field>
			<field name="subject">${user.company_id.name} Outstanding Statement</field>
			<field name="partner_to">${object.id}</field>
			<field name="lang">${object.lang}</field>
			<field name="report_name">Outstanding Statement Report</field>
			<field name="model_id" ref="base.model_res_partner" />
			<field name="body_html" type="html">
				<div style="margin: 0px; padding: 0px;font-size: 13px;">
					<p>Dear ${object.name},</p>
					<p>
						Please find attached your outstanding statement.
						This document provides a detailed overview of your unpaid invoices and outstanding balances with us.
					</p>
					<p>
						Thank you for choosing ${user.company_id.name}.
					</p>
					<br/>
				</div>
			</field>
            <field name="lang">${object.lang}</field>
        	<field name="auto_delete" eval="True"/>
		</record>
	</data>
</odoo>