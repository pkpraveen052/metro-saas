<odoo>
    <template id="partner_statement.outstanding_statement_document">
        <t t-call="partner_statement.custom_external_partner_layout">
            <t t-set="o" t-value="o.with_context({'lang': lang})"/>
            <!-- <t t-set="address">
                <address
                    t-esc="get_inv_addr(o)"
                    t-options='{"widget": "contact", "fields": ["address", "name"], "no_marker": True}'
                />
                <div t-if="o.vat" class="mt16"><t
                        t-esc="company.country_id.vat_label or 'Tax ID'"
                    />: <span t-field="o.vat" /></div>
            </t> -->
            <div class="page">
                <div class="oe_structure"/>
                <h2 style="margin-top:-42px;text-align:center;">Statement of Account</h2>
                <t t-if="account_type == 'receivable'">
                    <h6 style="text-align:center;">Outstanding invoices</h6>
                </t>
                <t t-if="account_type == 'payable'">
                    <h6 style="text-align:center;">Outstanding bills</h6>
                </t>
                <br/>
                <div class="row" style="margin-top: 0px !important;">
                    <div class="col-6">
                        <strong>Name:</strong>
                        <span t-esc="o.name"/>
                        <br/>
                        <div t-if="o.company_type == 'person' and o.parent_id">
                            Attn: <span t-field="o.parent_id.name"/>
                        </div>
                        <div>
                            <strong>Address:</strong>
                            <t t-if="o.street">
                                <span t-field="o.street"/>,
                            </t>
                            <t t-if="o.street2">
                                <span t-field="o.street2"/>,
                            </t>
                            <t t-if="o.street or o.street2">
                                <br/>
                            </t>
                            <t t-if="o.city">
                                <span t-field="o.city"/>,
                            </t>
                            <t t-if="o.state_id">
                                <span t-field="o.state_id.name"/>,
                            </t>
                            <t t-if="o.country_id">
                                <span t-field="o.country_id.name"/>,
                            </t>
                            <t t-if="o.zip">
                                <span t-field="o.zip"/>
                            </t>
                        </div>
                        <div t-if="o.phone">
                            <strong>Phone:</strong>
                            <span t-field="o.phone"/>
                        </div>
                        <div t-if="o.email">
                            <strong>Email:</strong>
                            <span t-field="o.email"/>
                        </div>
                    </div>
                    <div class="col-3"/>
                    <div class="col-3" style="margin-left:70px;">
                        <table style="width: 100%; border-collapse: collapse;">
                            <tr>
                                <td style="">
                                    <strong>As of</strong>
                                    <span t-esc="d['end']"/>
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>
                <br/>
                <!-- <div id="informations" class="row mt32 mb32">
                    <div class="col-3 bm-2">
                        <strong>Date:</strong>
                        <p t-esc="d['today']" class="m-0" />
                    </div>
                    <div class="col-3 bm-2">
                        <strong>Partner Name:</strong>
                        <p t-field="o.name" class="m-0" />
                    </div>
                    <div t-if="o.ref" class="col-3 bm-2">
                        <strong>Partner Code:</strong>
                        <p t-field="o.ref" class="m-0" />
                    </div>
                </div> -->
                <t t-if="d['currencies']">
                    <t t-foreach="d['currencies'].items()" t-as="currency">
                        <t t-set="display_currency" t-value="Currencies[currency[0]]"/>
                        <t t-set="currency" t-value="currency[1]"/>
                        <div class="row" style="margin-top: 0px !important;">
                            <!--                            <div class="col-6">-->
                            <!--                                <p>-->
                            <!--                                    <span-->
                            <!--                                            t-esc="'' if  account_type == 'receivable' else 'Supplier '"-->
                            <!--                                    />Statement up to-->
                            <!--                                    <span t-esc="d['end']"/>-->
                            <!--                                    in-->
                            <!--                                    <strong-->
                            <!--                                            t-esc="display_currency.name"-->
                            <!--                                    />-->
                            <!--                                </p>-->
                            <!--                            </div>-->
                            <div class="col-6">
                                <!--                                <t t-set="not_due_yet" t-value="0.0"/>-->
                                <t t-set="ending_bal" t-value="currency['amount_due']"/>
                                <!--                                <t t-foreach="currency['lines']" t-as="line_summary">-->
                                <!--                                    <t t-if="line_summary['date_maturity'] &gt; d['end']">-->
                                <!--                                        <t t-set="not_due_yet" t-value="not_due_yet + line_summary['amount']"/>-->
                                <!--                                    </t>-->
                                <!--                                </t>-->
                                <table style="width: 100%; border-collapse: collapse;">
                                    <tr>
                                        <td style="">
                                            <strong>Overdue</strong>
                                        </td>
                                        <td style="text-align: right; ">
                                            <t t-if="ending_bal">
                                                <span t-esc="round(ending_bal,2)"
                                                      t-options="{'widget': 'monetary', 'display_currency': display_currency}"/>
                                            </t>
                                            <t t-else="">
                                                <span t-esc="ending_bal"
                                                      t-options="{'widget': 'monetary', 'display_currency': display_currency}"/>
                                            </t>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="">
                                            <strong>Not yet due</strong>
                                        </td>
                                        <td style="text-align: right; ">
                                            <t t-if="not_due_yet">
                                                <span t-esc="round(not_yet_due_bal,2)"
                                                      t-options="{'widget': 'monetary', 'display_currency': display_currency}"/>
                                            </t>
                                            <t t-else="">
                                                <span t-esc="not_yet_due_bal"
                                                      t-options="{'widget': 'monetary', 'display_currency': display_currency}"/>
                                            </t>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="">
                                            <strong>Outstanding balance
                                                <span t-esc="display_currency.name"/>
                                            </strong>
                                        </td>
                                        <td style="text-align: right; ">
                                            <t t-if="ending_bal">
                                                <span t-esc="round(ending_bal,2)"
                                                      t-options="{'widget': 'monetary', 'display_currency': display_currency}"/>
                                            </t>
                                            <t t-else="">
                                                <span t-esc="ending_bal"
                                                      t-options="{'widget': 'monetary', 'display_currency': display_currency}"/>
                                            </t>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>
                        <br/>
                        <table class="table table-condensed table-statement">
                            <col width="12%"/>
                            <col width="12%"/>
                            <col width="34%"/>
                            <col width="15%"/>
                            <col width="15%"/>
                            <col width="15%"/>
                            <thead>
                                <tr>
                                    <!--                                    <th>Reference number</th>-->
                                    <th>Date</th>
                                    <th>Due Date</th>
                                    <th>Reference/Description</th>
                                    <th class="amount">Total</th>
                                    <th class="amount">Unpaid</th>
                                    <th class="amount">Balance</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr
                                        t-foreach="currency['lines']"
                                        t-as="line"
                                        t-att-class="'statement-blocked' if line['blocked'] else ''"
                                >
                                    <!--                                    <td>-->
                                    <!--                                        <span t-esc="line['move_id']"/>-->
                                    <!--                                    </td>-->
                                    <td>
                                        <span t-esc="line['date']"/>
                                    </td>
                                    <td>
                                        <span t-esc="line['date_maturity']"/>
                                    </td>
                                    <td>
                                        <t t-if="line['name'] != '/'">
                                            <t t-if="not line['ref']">
                                                <span t-esc="line['name']"/>
                                            </t>
                                            <t t-if="line['ref'] and not line['name']">
                                                <span t-esc="line['ref']"/>
                                            </t>
                                            <t t-if="line['ref'] and line['name']">
                                                <t t-if="line['name'] not in line['ref'] or line['name'] == line['ref']">
                                                    <span t-esc="line['name']"/>
                                                </t>
                                                <t t-if="line['ref'] not in line['name']">
                                                    <span t-esc="line['ref']"/>
                                                </t>
                                            </t>
                                        </t>
                                        <t t-if="line['name'] == '/'">
                                            <span t-esc="line['ref']"/>
                                        </t>
                                        <t t-if="not line['name'] and not line['ref']">
                                            <span t-esc="line['move_id']"/>
                                        </t>
                                    </td>
                                    <td class="amount">
                                        <span
                                                t-esc="line['amount']"
                                                t-options="{'widget': 'monetary', 'display_currency': display_currency}"
                                        />
                                    </td>
                                    <td class="amount">
                                        <span
                                                t-esc="line['open_amount']"
                                                t-options="{'widget': 'monetary', 'display_currency': display_currency}"
                                        />
                                    </td>
                                    <td class="amount">
                                        <span
                                                t-esc="line['balance']"
                                                t-options="{'widget': 'monetary', 'display_currency': display_currency}"
                                        />
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <span t-esc="d['end']"/>
                                    </td>
                                    <td/>
                                    <td>
                                        Ending Balance
                                    </td>
                                    <td/>
                                    <td/>
                                    <td class="amount">
                                        <span
                                                t-esc="currency['amount_due']"
                                                t-options="{'widget': 'monetary', 'display_currency': display_currency}"
                                        />
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                        <t
                                t-call="partner_statement.aging_buckets"
                                t-if="currency['buckets']"
                        />
                        <br/>
                    </t>
                </t>
                <p t-if="d.get('no_entries')">
                    <strong>The partner doesn't have due entries.</strong>
                </p><br/>
                <div class="col-12" t-if="o.company_id.show_tc_customer_statement">
                    <strong style="color: black;">TERMS AND CONDITIONS:</strong><br/>
                    <span t-field="o.company_id.customer_overdue_statement_tc"/>
                </div>
                <div t-if="o.company_id.show_paynow_qrcode_cs">
                    <t t-if="o.generate_paynow_qr_for_soa()">
                        <div class="col-5 float-right" style="padding-left:65px;padding-top: 10px;text-align: right;">
                            <img style="width: 150px; height: 150px; object-fit: cover;" 
                                t-attf-src="data:image/png;base64,{{ o.generate_paynow_qr_for_soa() }}" alt=""/>
                        </div>
                    </t>
                </div>
            </div>
<!--            <div class="footer"-->
<!--                 style="margin-top:10px;text-align: center; font-size: 14px;font-weight: bold;font-family: 'dinerosans,sans-serif;"-->
<!--                 t-if="o.company_id.show_poweredby_report_statements">-->
<!--                <span style="padding-left:2px;margin-top:10px;">Powered by</span>-->
<!--                <img t-att-src="'/partner_statement/static/src/img/metrologo.png'" style="width: 80px;"/>-->
<!--            </div>-->
            <!--            <div class="footer"-->
            <!--                 style="margin-top:30px;text-align: center; font-size: 14px;font-weight: bold;font-family: 'dinerosans,sans-serif;">-->
            <!--                <span style="padding-left:2px;">Powered by</span>-->
            <!--                <img t-att-src="'/partner_statement/static/src/img/metrologo.png'" style="width: 80px;"/>-->
            <!--            </div>-->
        </t>
    </template>
    <template id="outstanding_statement">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-set="d" t-value="data.get(o.id)"/>
                <t
                        t-call="partner_statement.outstanding_statement_document"
                        t-lang="o.lang"
                />
            </t>
        </t>
    </template>
    <record id="action_print_outstanding_statement" model="ir.actions.report">
        <field name="name">Outstanding Statement</field>
        <field name="model">res.partner</field>
        <field name="report_name">partner_statement.outstanding_statement</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_file">partner_statement.outstanding_statement</field>
        <field name="print_report_name">'%s_Outstanding_Statement' % (object.name)</field>
        <field name="paperformat_id" ref="partner_statement.paperformat_partner_statement"/>
    </record>
</odoo>
