<odoo>
	<data>
<!--        Multi-Company Record Rule For progressive billing Quotation  -->
        <record id="progressive_billing_quotations_multi_company_rule" model="ir.rule">
            <field name="name">Progressive Quotations Multi Company Rule - Non Super Admins</field>
            <field ref="metroerp_progressive_billing.model_progressive_billing_qt" name="model_id"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(6,0,[ref('base.group_user')])]"/>
         </record>

        <record id="progressive_billing_quotations_admin_rule" model="ir.rule">
            <field name="name">Progressive Quotations Multi Company Rule - Super Admin</field>
            <field ref="metroerp_progressive_billing.model_progressive_billing_qt" name="model_id"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(6,0,[ref('base.group_system')])]"/>
         </record>
	</data>
</odoo>

