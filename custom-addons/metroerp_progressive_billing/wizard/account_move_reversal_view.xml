<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="inherite_view_account_move_reversal" model="ir.ui.view">
            <field name="name">account.move.reversal.form.inherit</field>
            <field name="model">account.move.reversal</field>
            <field name="inherit_id" ref="account.view_account_move_reversal"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='refund_method']" position="after">
                    <field name="is_progressive_invoice" invisible="1"/>
                </xpath>
                <xpath expr="//field[@name='refund_method']" position="attributes">
                    <attribute name="attrs">{'readonly': ['|', ('is_progressive_invoice', '=', True), ('residual', '=', 0)]}</attribute>
                </xpath>
            </field>
    </record>
</odoo>