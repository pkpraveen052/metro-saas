<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sales_detail_listing_wizard_form_view" model="ir.ui.view">
        <field name="name">sales.detail.listing.wizard.form</field>
        <field name="model">sales.detail.listing.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="from_date"/>
                    <field name="to_date"/>
                </group>
                <group>
                    <field name="pos_config_ids" mode="tree" colspan="4" nolabel="1" />
                </group>
                <footer>
                    <button string="Print" name="print_report" type="object" class="oe_highlight"/>
                    <button string="Cancel" class="btn btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record model="ir.actions.act_window" id="action_sales_details_listing">
        <field name="name">Sales Detail Listing</field>
        <field name="res_model">sales.detail.listing.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="sale_details_listing_menu"
              name="Sales Detail Listing"
              parent="point_of_sale.menu_point_rep"
              action="action_sales_details_listing"
              sequence="1"/>

</odoo>