<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
         <record id="assistro_whatsapp_template_view_form" model="ir.ui.view">
            <field name="name">assistro.whatsapp.template.view.form</field>
            <field name="model">assistro.whatsapp.template</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                       <group>
                            <group>
                                <field name="name" required="1" attrs="{'readonly': [('is_default', '=', True)]}"/>
                                <field name="company_id" readonly="1"/>
                            </group>
                            <group>
                                <field name="model_id" required="1" options="{'no_create': True,'no_open': True}" domain="[('model', 'in', ['sale.order', 'account.move', 'purchase.order', 'stock.picking','account.payment','progressive.billing.qt'])]" 
                                attrs="{'readonly': [('is_default', '=', True)]}"/>
                                <field name="is_default" invisible="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page id="body" name="Body" string="Content">
                                <field name="body" placeholder="Hello {object.name}, here is your order with the reference {object.reference}..."
                                attrs="{'readonly': [('is_default', '=', True)]}"/>
                                <div style="color: red; font-weight: bold; margin-bottom: 10px;" attrs="{'invisible': [('is_default', '=', True)]}">
                                    Note: Placeholder always be added to the end of the content. Please perform required edits after the placeholder is inserted.
                                </div>
                                <group>
                                   <button string="Insert Placeholder (e.g.{object.name})" 
                                            type="object" 
                                            name="action_open_placeholder_wizard" 
                                            class="btn-primary"
                                            attrs="{'invisible': [('is_default', '=', True)]}"/>
                                </group>
                            </page>
                            <page id="variables" name="Variables" string="Variables">
                                <label for="available_placeholders" string="Available Placeholders"/>
                                <div>
                                    <field name="available_placeholders" readonly="1" nolabel="1"/>
                                </div>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
    
        <record id="assistro_whatsapp_template_view_tree" model="ir.ui.view">
            <field name="name">assistro.whatsapp.template.view.tree</field>
            <field name="model">assistro.whatsapp.template</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="model_id"/>
                    <field name="company_id" readonly="1"/>
                    <field name="create_date"/>
                    <field name="create_uid"/>
                </tree>
            </field>
        </record>

        
        <record id="assistro_whatsapp_template_action_window" model="ir.actions.act_window">
            <field name="name">WhatsApp Template</field>
            <field name="res_model">assistro.whatsapp.template</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                      Create a new template
                </p>
            </field>
        </record>

        <menuitem id="assistro_configuration_parent_menu"
                  sequence="50" groups="assistro_menu_invisible"/>

        <menuitem name="Assistro WhatsApp"
                  id="assistro_configuration_menu"
                  parent="assistro_configuration_parent_menu"
                  action="assistro_whatsapp_template_action_window"
                  groups="assistro_menu_invisible"/>
    </data>
</odoo>