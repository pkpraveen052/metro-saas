<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="portal_share_whatsapp_wizard" model="ir.ui.view">
        <field name="name">portal.share.whatsapp.wizard</field>
        <field name="model">portal.share.whatsapp</field>
        <field name="arch" type="xml">
            <form string="Share Document">
                <group name="share_link">
                    <field name="share_link" widget="CopyClipboardChar" options="{'string': 'Copy Link'}" readonly="1"/>
                </group>
                <group>
                    <field name="partner_id" placeholder="Add contact to share the document..."/>
                </group>
                <group>
                    <field name="note" placeholder="Add a note"/>
                </group>
                <footer>
                    <button string="Send" name="action_send_whatsapps" type="object" class="oe_highlight" icon="fa-whatsapp"/>
                    <button string="Cancel" class="btn-default" special="cancel" />
                </footer>
            </form>
        </field>
    </record>

    <record id="model_sale_order_action_share_whatsapp" model="ir.actions.server">
        <field name="name">Share via Whatsapp</field>
        <field name="model_id" ref="sale.model_sale_order"/>
        <field name="binding_model_id" ref="sale.model_sale_order"/>
        <field name="binding_view_types">form</field>
        <field name="state">code</field>
        <field name="code">action = {
            'type': 'ir.actions.act_window',
            'res_model': 'portal.share.whatsapp',
            'view_mode': 'form',
            'target': 'new',
            'context': {'active_id': record.id}
            }</field>
    </record>
</odoo>
