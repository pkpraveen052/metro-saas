<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="users_guide_tags_form_view" model="ir.ui.view">
            <field name="name">user.guide.tags.form.view</field>
            <field name="model">user.guide.tags</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name" required="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="users_guide_tags_list_view" model="ir.ui.view">
            <field name="name">user.guide.tags.list.view</field>
            <field name="model">user.guide.tags</field>
            <field name="arch" type="xml">
                <tree string="Tags">
                    <field name="name"/>
                </tree>
            </field>
        </record>

        <record id="action_user_guide_tags_form" model="ir.actions.act_window">
            <field name="name">Tags</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">user.guide.tags</field>
            <field name="view_mode">tree,form</field>
        </record>
    </data>
</odoo>