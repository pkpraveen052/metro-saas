<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_immediate_production_inherit" model="ir.ui.view">
        <field name="name">mrp.immediate.production.view.form</field>
        <field name="model">mrp.immediate.production</field>
        <field name="inherit_id" ref="mrp.view_immediate_production"/>
        <field name="arch" type="xml">
            <xpath expr="//group[1]" position="replace">
                <group>
                    <p>You have not recorded <i>produced</i> quantities yet, by clicking on <i>apply</i> ERP will produce all the finished products and consume all components.</p>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
