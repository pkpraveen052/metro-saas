<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">metro.res.config.settings.view.form.inherit.mrp</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="mrp.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='process_operations_setting_container']/div[1]" position="attributes">
                <attribute name='groups'>base.group_system</attribute>
            </xpath>
            <xpath expr="//div[@name='process_operations_setting_container']/div[2]" position="attributes">
                <attribute name='groups'>base.group_system</attribute>
            </xpath>
        </field>
    </record>
</odoo>
