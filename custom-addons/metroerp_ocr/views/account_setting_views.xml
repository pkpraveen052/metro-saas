<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_account_config_settings_inherit_ocr" model="ir.ui.view">
    <field name="name">res.config.settings.inherit.bill.ocr</field>
    <field name="model">res.config.settings</field>
    <field name="inherit_id" ref="account.res_config_settings_view_form"/>
    <field name="arch" type="xml">
        <xpath expr="//div[@id='analytic']" position="after">
            <h2>Bill OCR</h2>
            <div class="row mt16 o_settings_container" groups="base.group_system">
                <div class="row mt16 o_settings_container">
                    <div class="col-xs-12 col-md-12 o_setting_box">
                        <field name="gemini_api_key"/>
                    </div>
                </div>
            </div>
        </xpath>
    </field>
</record>
</odoo>