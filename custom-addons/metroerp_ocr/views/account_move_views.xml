<odoo>
    <record id="invoice_ocr_account_invoice_filter" model="ir.ui.view">
        <field name="name">invoice.ocr.filter</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_account_invoice_filter"/>
        <field name="arch" type="xml">
            <filter name="activities_upcoming_all" position="after">
                <separator/>
                <filter string="Created via OCR" name="filter_ocr_created"
                    domain="[('is_ocr_created', '=', True)]"/>
            </filter>
        </field>
    </record>

