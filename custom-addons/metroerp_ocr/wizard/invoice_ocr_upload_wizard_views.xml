<!-- views/invoice_upload_wizard_view.xml -->

<odoo>
    <record id="view_invoice_upload_wizard_form" model="ir.ui.view">
        <field name="name">invoice.upload.wizard.form</field>
        <field name="model">invoice.upload.wizard</field>
        <field name="arch" type="xml">
            <form string="Upload Vendor Bill">
                <group>
                    <field name="invoice_file" filename="filename"/>
                    <field name="filename" invisible="1"/>
                </group>
                <div>
                    <p class="o_form_label">
                        <strong>Note:</strong>
                        You can upload PDF or image(JPG, PNG) files.
                        Please upload one vendor bill at a time.
                    </p>
                </div>
                <footer>
                    <button name="action_create_vendor_bill" type="object" string="Send" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Optional menu item to open the wizard -->
    <record id="action_invoice_upload_wizard" model="ir.actions.act_window">
        <field name="name">Upload Invoice (Textract)</field>
        <field name="res_model">invoice.upload.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="action_upload_invoice_wizard" model="ir.actions.server">
        <field name="name">Upload Invoice (Textract)</field>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="state">code</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_view_types">list</field>
        <field name="code">
            action = {
            'type': 'ir.actions.act_window',
            'res_model': 'invoice.upload.wizard',
            'view_mode': 'form',
            'target': 'new',
            }
        </field>
    </record>

    <!--    <menuitem id="menu_invoice_upload_wizard"-->
    <!--              name="Upload Invoice (Textract)"-->
    <!--              parent="account.menu_finance"-->
    <!--              action="action_invoice_upload_wizard"/>-->

</odoo>
