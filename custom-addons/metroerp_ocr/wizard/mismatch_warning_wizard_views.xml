<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_mismatch_warning_wizard_form" model="ir.ui.view">
    <field name="name">mismatch.warning.wizard.form</field>
    <field name="model">mismatch.warning.wizard</field>
    <field name="arch" type="xml">
        <form string="Warning">
            <group>
                <field name="message" readonly="1"/>
            </group>
            <footer>
                <button string="Ok" type="object" name="action_close" class="btn-primary"/>
            </footer>
        </form>
    </field>
    </record>
</odoo>