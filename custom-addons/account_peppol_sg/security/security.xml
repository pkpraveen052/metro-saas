<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record model="ir.module.category" id="module_category_peppol">
            <field name="name">PEPPOL</field>
            <field name="description">PEPPOL</field>
            <field name="sequence">7</field>
        </record>

        <record id="group_peppol_admin" model="res.groups">
            <field name="name">Administrator</field>
            <field name="category_id" ref="module_category_peppol"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record model="ir.rule" id="peppol_invoice_report_comp_rule">
            <field name="name">Peppol Invoice Analysis multi-company</field>
            <field name="model_id" ref="model_peppol_invoice_report"/>
            <field name="domain_force">['|',('company_id','=',False),('company_id', 'in', company_ids)]</field>
        </record>

    </data>

    <data noupdate="1">

        <record id="group_peppol_admin" model="res.groups">
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        </record>

        <record id="outgoing_invoice_document_multicompany" model="ir.rule">
            <field name="name">Outgoing Invoice Documents - Multi Company</field>
            <field name="model_id" ref="model_peppol_queue_out"/>
            <field name="domain_force">['|',('company_id','=',False),('company_id', 'in', company_ids)]</field>
        </record>

        <record id="incoming_invoice_document_multicompany" model="ir.rule">
            <field name="name">Incoming Invoice Documents - Multi Company</field>
            <field name="model_id" ref="model_peppol_log_sg"/>
            <field name="domain_force">['|',('company_id','=',False),('company_id', 'in', company_ids)]</field>
        </record>
        
    </data>
</odoo>
