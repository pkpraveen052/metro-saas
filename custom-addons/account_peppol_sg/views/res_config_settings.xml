<?xml version="1.0" encoding="utf-8" ?>

<odoo>

    <record id="res_config_settings_view_peppol_form" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.peppol</field>
            <field name="model">res.config.settings</field>
            <field name="priority" eval="40"/>
            <field name="inherit_id" ref="base.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//div[hasclass('settings')]" position="inside">
                    <div class="app_settings_block" data-string="Peppol" string="Peppol" data-key="account_peppol_sg">
                        <h2>Storecove</h2>
                        <div class="row mt16 o_settings_container">
                            <div class="col-xs-12 col-md-12 o_setting_box">
                                <div class="o_setting_right_pane">
                                    <label for="endpoint"/>
                                    <div class="text-muted">
                                        Default End point applied on the Access Point
                                    </div>
                                </div>
                                <div class="o_setting_right_pane">
                                    <field name="endpoint"/>
                                </div>
                            </div>
<!--                            <div class="col-xs-12 col-md-12 o_setting_box">-->
<!--                                <div class="o_setting_right_pane">-->
<!--                                    <label for="apikey"/>-->
<!--                                    <div class="text-muted">-->
<!--                                        Default API Key applied on the Access Point-->
<!--                                    </div>-->
<!--                                </div>-->
<!--                                <div class="o_setting_right_pane">-->
<!--                                    <field name="apikey"/>-->
<!--                                </div>-->
<!--                            </div>-->
                        </div>
                        
                        <h2>Peppol Lookup Directory</h2>
                        <div class="row mt16 o_settings_container">
                            <div class="col-xs-12 col-md-12 o_setting_box">
                                <div class="o_setting_right_pane">
                                    <label for="peppol_endpoint"/>
                                    <div class="text-muted">
                                        Default End point applied on the Access Point
                                    </div>
                                </div>
                                <div class="o_setting_right_pane">
                                    <field name="peppol_endpoint"/>
                                </div>
                            </div>
                            <div class="col-xs-12 col-md-12 o_setting_box">
                                <div class="o_setting_right_pane">
                                    <label for="peppol_apikey"/>
                                    <div class="text-muted">
                                        Default Access Key applied
                                    </div>
                                </div>
                                <div class="o_setting_right_pane">
                                    <field name="peppol_apikey"/>
                                </div>
                            </div>
                        </div>
                        <h2>SG Electronic Address Scheme</h2>
                        <div class="row mt16 o_settings_container">
                            <div class="col-xs-6 col-md-6 o_setting_box">
                                <div class="o_setting_right_pane">
                                    <div class="text-muted">
                                        Scheme Numerical Code
                                    </div>
                                </div>
                                <div class="o_setting_right_pane">
                                    <field name="electronic_address_scheme"/>
                                </div>
                            </div>
                            <div class="col-xs-6 col-md-6 o_setting_box">
                                <div class="o_setting_right_pane">
                                    <div class="text-muted">
                                        Scheme Identifier
                                    </div>
                                </div>
                                <div class="o_setting_right_pane">
                                    <field name="electronic_address_scheme_identifier"/>
                                </div>
                            </div>
                        </div>
                        <h2>Invoice Notifications</h2>
                        <div class="row mt16 o_settings_container">
                            <div class="col-xs-12 col-md-12 o_setting_box">
                                <div class="o_setting_right_pane">
                                    <label for="grp_name_ids"/>
                                    <div class="text-muted">
                                        Default Groups for Incoming Invoice
                                    </div>
                                </div>
                                <div class="o_setting_right_pane">
                                    <field name="grp_name_ids" widget="many2many_tags"/>
                                </div>
                            </div>
                        </div>
                        <h2>Invoice Submission Type</h2>
                        <div class="row mt16 o_settings_container">
                            <div class="col-xs-12 col-md-12 o_setting_box">
                                <div class="o_setting_right_pane">
                                    <div class="text-muted">
                                        Default Invoice Type while submitting an Invoice
                                    </div>
                                </div>
                                <div class="o_setting_right_pane">
                                    <field name="invoice_type" widget="radio"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </xpath>
            </field>
    </record>

    <record id="action_peppol_config" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="context">{'module' : 'account_peppol_sg', 'bin_size': False}</field>
    </record>

    <menuitem id="menu_peppol_settings"
        action="action_peppol_config"
        name="Settings"
        parent="account_peppol_sg.menu_peppol_configuration"
        sequence="1"/>

</odoo>
