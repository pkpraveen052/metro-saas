<?xml version="1.0" encoding="utf-8"?>
<odoo>

<record id="peppol_manual_send_wizard_form_view" model="ir.ui.view">
    <field name="name">peppol.manual.send.wizard.form</field>
    <field name="model">peppol.manual.send.wizard</field>
    <field name="arch" type="xml">
        <form>
            <field name="mode" invisible="1"/>
<!--            <field name="document_model" invisible="1"/>-->
<!--            <field name="document_ids" invisible="1"/>-->
            <group>
                <field name="message" nolabel="1"/>
            </group>
            <footer>
                <button string="Send" name="button_send" type="object" class="oe_highlight"/>
                <button string="Cancel" class="btn btn-secondary" special="cancel"/>
            </footer>
        </form>
    </field>
</record>

<record id="action_peppol_manual_send_wizard" model="ir.actions.act_window">
    <field name="name">Send to PEPPOL</field>
    <field name="res_model">peppol.manual.send.wizard</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
</record>

<!--  This is for warning message  -->
<record id="peppol_warning_wizard_form_view" model="ir.ui.view">
    <field name="name">peppol.warning.wizard.form</field>
    <field name="model">peppol.warning.wizard</field>
    <field name="arch" type="xml">
        <form>
            <group>
                <field name="message" nolabel="1"/>
            </group>
            <footer>
                <button string="Cancel" class="btn btn-secondary" special="cancel"/>
            </footer>
        </form>
    </field>
</record>

<record id="action_peppol_warning_wizard" model="ir.actions.act_window">
    <field name="name">Warning</field>
    <field name="res_model">peppol.warning.wizard</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
</record>

</odoo>
