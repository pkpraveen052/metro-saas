<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <record id="view_pos_payment_change_wizard_form" model="ir.ui.view">
        <field name="model">pos.payment.change.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group col="4">
                    <field name="order_id" readonly="1"/>
                    <field name="amount_total" invisible="1" readonly="1"/>
                    <newline />
                    <field
                        name="payment_new_line_ids"
                        colspan="4"
                    >
                        <tree create="false" delete="false" editable="bottom">
                            <field name="old_payment_method_id" force_save="1"/>
                            <field
                                name="new_payment_method_id"
                                options="{'no_open': True, 'no_create_edit': True, 'no_create': True}"
                                force_save="1"
                            />
                            <field name="amount" sum="Total" readonly="1" force_save="1"/>
                        </tree>
                    </field>
                </group>
                <footer>
                    <button
                        name="button_change_payment"
                        string="Change Payments"
                        type="object"
                        class="oe_highlight"
                    />
                    <button string="Cancel" class="oe_link" special="cancel" />
                </footer>
            </form>
        </field>
    </record>

    <record id="action_pos_payment_change_wizard" model="ir.actions.act_window">
        <field name="name">Change Payments</field>
        <field name="res_model">pos.payment.change.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
