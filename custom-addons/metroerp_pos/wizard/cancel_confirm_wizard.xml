<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_pos_order_cancel_wizard_form" model="ir.ui.view">
        <field name="name">pos.order.cancel.wizard.form</field>
        <field name="model">pos.order.cancel.wizard</field>
        <field name="arch" type="xml">
            <form string="Cancel POS Order">
                <group>
                    <p>Are you sure you want to cancel this order?</p>
                </group>
                <footer>
                    <button string="OK" type="object" name="confirm_cancel" class="btn-primary"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
