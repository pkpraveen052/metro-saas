<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
<!--        Paper format defined for the POS > Reporting > Sales Details report. This is a printer size format-->
        <record id="paperformat_for_thermal_pos_sales_details" model="report.paperformat">
            <field name="name">POS Sales Details - Thermal Printer Size</field>
            <field name="default" eval="True"/>
            <field name="format">custom</field>
            <field name="page_height">350</field>
            <field name="page_width">75</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">6</field>
            <field name="margin_bottom">5</field>
            <field name="margin_left">1</field>
            <field name="margin_right">1</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">6</field>
            <field name="dpi">200</field>
        </record>

        <record id="paperformat_for_a4_pos_sales_details" model="report.paperformat">
            <field name="name">POS Sales Details - A4 Paper Size</field>
            <field name="default" eval="True" />
            <field name="format">A4</field>
            <field name="page_height">0</field>
            <field name="page_width">0</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">8</field>
            <field name="margin_bottom">10</field>
            <field name="margin_left">7</field>
            <field name="margin_right">7</field>
            <field name="header_line" eval="False" />
            <field name="header_spacing">8</field>
            <field name="dpi">90</field>
        </record>
    </data>
</odoo>