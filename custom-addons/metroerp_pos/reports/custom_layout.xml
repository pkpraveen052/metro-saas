<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
		<template id="custom_external_pos_sale_layout">
			<t t-if="not o and doc">
				<t t-set="o" t-value="doc"/>
			</t>
			<t t-if="o and 'company_id' in o">
				<t t-set="company" t-value="o.company_id"/>
			</t>
			<t t-if="not o or not 'company_id' in o">
				<t t-set="company" t-value="res_company"/>
			</t>
			<t t-call="metroerp_pos.custom_external_pos_sale_layout_standard">
			   <t t-raw="0"/>
			</t>
		</template>

		<template id="custom_external_pos_sale_layout_standard">
			<div class="header">
				<div class="o_boxed_header" style="font-family: sans-serif;color: #495057;font-size:10.0pt;">
					<div class="row">
						<div class="col-6 text-left" style="display: flex;justify-content: flex-start;align-items: center;" >
							<img t-att-src="image_data_uri(company.logo)" alt="Logo"/>
						</div>
						<div class="col-1"/>
						<div class="col-5 text-left">
							<table>
								<tr>
									<div>
										<b>
											<span style="font-size: 125%;color:black;" t-field="company.name"/>
										</b>
										<br/>
									</div>
									<div>
										<t t-if="company.street">
											<span t-field="company.street"/>,
										</t>
										<t t-if="company.street2">
											<span t-field="company.street2"/>,
										</t>
									</div>
									<div>
										<t t-if="company.city">
											<span t-field="company.city"/>,
										</t>
										<t t-if="company.state_id">
											<span t-field="company.state_id.name"/>,
										</t>
										<t t-if="company.zip">
											<span t-field="company.zip"/>,
										</t>
										<t t-if="company.country_id">
											<span>
												<t t-esc="company.country_id.name"/>
												<br/>
											</span>
										</t>
									</div>
								</tr>
								<tr>
									<t t-if="company.l10n_sg_unique_entity_number">
										<td>UEN: <span t-field="company.l10n_sg_unique_entity_number"/>, <span t-if="company.vat" style="display: inline-block;">GST Reg No: </span><span t-field="company.vat"/>
										</td>
									</t>
									<t t-if="not company.l10n_sg_unique_entity_number and company.company_registry">
										<td>UEN: <span t-field="company.company_registry"/>, <span t-if="company.vat" style="display: inline-block;">GST Reg No: </span><span t-field="company.vat"/>
										</td>
									</t>
								</tr>
								<tr>
									<t t-if="company.phone or company.email">
										<td>
											<span t-if="company.phone">Phone: <span t-field="company.phone"/>, </span>
											<span t-if="company.email" style="display: inline-block;">Email: <span t-field="company.email"/></span>
										</td>
									</t>
								</tr>
							</table>
							<br/>
						</div>
					</div>
				</div>
			</div>
			<div class="article o_report_layout_boxed" t-att-data-oe-model="o and o._name" t-att-data-oe-id="o and o.id" t-att-data-oe-lang="o and o.env.context.get('lang')">
				<t t-call="web.address_layout"/>
				<t t-raw="0"/>
			</div>
			<div t-attf-class="footer" style="page-break-inside:avoid; border-top: 1px solid black; font-size:16px;">
				<div class="row" style="display: flex; justify-content: space-between; align-items: center; margin-top:10px;">
					<!-- Copyright and Company Name (Left-aligned) -->
					<div class="col-4 text-nowrap" style="text-align: left;">
						Copyright ©
						<t t-esc="obj.company_id.name if obj and obj.company_id else (env.company.name if env and env.company else 'Your Company Name')"/>
					</div>
					<!-- Pagination (Center-aligned) -->
					<div class="col-4" style="text-align: center;">
						Page: <span class="page"/> / <span class="topage"/>
					</div>
					<!-- Metro Branding (Right-aligned) -->
					<div class="col-4" style="text-align:right;">
						<span style="margin-right:5px;margin-top:2px;">Powered by </span>
						<a target="_blank" href="https://www.metrogroup.solutions/solutions/accounting-system" style="color: #007bff; text-decoration: none; font-weight: bold;">
							<img src="/metroerp_pos/static/src/img/metro_logo.png" alt="Metro Logo" style="height:12px;"/>
						</a>
					</div>
				</div>
			</div>
		</template>
    </data>
</odoo>
