<odoo>

	<record id="view_res_config_settings_account_custom" model="ir.ui.view">
	    <field name="name">res.config.settings.account.custom</field>
	    <field name="model">res.config.settings</field>
	    <field name="inherit_id" ref="account.res_config_settings_view_form"/>
	    <field name="arch" type="xml">
		<xpath expr="//div[@id='invoicing_settings']" position="inside">
		    <div class="col-12 col-lg-6 o_setting_box">
		        <div class="o_setting_left_pane"/>
		        <div class="o_setting_right_pane">
		            <span class="o_form_label">BCRS Deposit Amount</span>
		            <div class="text-muted">
		                Default BCRS Deposit Amount set on your product
		            </div>
		            <div class="text-muted">
		                <field name="brs_deposit_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
		            </div>
		        </div>
		    </div>
		    <div class="col-12 col-lg-6 o_setting_box">
		        <div class="o_setting_left_pane"/>
		        <div class="o_setting_right_pane">
		            <span class="o_form_label">BCRS Deposit Product</span>
		            <div class="text-muted">
		                BCRS Deposit Product of your company
		            </div>
		            <div class="text-muted">
		                <field name="brs_deposit_product_id"/>
		            </div>
		        </div>
		    </div>
		</xpath>
	    </field>
	</record>

    <record id="new_res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.base.saas</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="0"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='languages']" position="attributes">
                <attribute name="groups">!metroerp_customizations.sub_admin_group</attribute>
            </xpath>
            <xpath expr="//div[@id='emails']" position="attributes">
                <attribute name="groups">!metroerp_customizations.sub_admin_group</attribute>
            </xpath>
        </field>
    </record>

    <record id="new_base_saas_res_config_settings_view_form" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.base.setup.saas</field>
            <field name="model">res.config.settings</field>
            <field name="priority" eval="0"/>
            <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//div[hasclass('app_settings_block')]/h2[1]" position="attributes">
                    <attribute name="groups">!metroerp_customizations.sub_admin_group</attribute>
                </xpath>
                <xpath expr="//div[@id='user_default_rights']" position="attributes">
                    <attribute name="groups">!metroerp_customizations.sub_admin_group</attribute>
                </xpath>
            </field>
    </record>

    <record id="hide_favicon_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='web_theme']/div[@class='col-12 col-lg-6 o_setting_box'][2]" position="attributes">
                <attribute name="groups">!metroerp_customizations.sub_admin_group</attribute>
            </xpath>
        </field>
    </record>

    <record id="hide_debranding_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.debranding</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='debranding_config1']" position="attributes">
                <attribute name="groups">!metroerp_customizations.sub_admin_group</attribute>
            </xpath>
        </field>
    </record>

    <record id="hide_companies_count_setting" model="ir.ui.view">
        <field name="name">res.config.settings.hide.companycount</field>
        <field name="model">res.config.settings</field> 
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='companies_setting']//field[@name='company_count']" position="attributes">
                <attribute name="groups">!metroerp_customizations.sub_admin_group</attribute>
            </xpath>
        </field>
    </record>

    <record id="hide_active_user_count_setting" model="ir.ui.view">
        <field name="name">res.config.settings.hide.usercount</field>
        <field name="model">res.config.settings</field> 
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='active_user_setting']//field[@name='active_user_count']" position="attributes">
                <attribute name="groups">!metroerp_customizations.sub_admin_group</attribute>
            </xpath>
        </field>
    </record>

    <!--<record model="res.config.settings" id="res_config_settings_discount">
        <field name="group_discount_per_so_line" eval="True"/>
    </record>

    <function model="res.config.settings" name="execute">
        <value model="res.config.settings"
               search="[('id', '=', ref('res_config_settings_discount'))]"/>
    </function>-->
</odoo>
