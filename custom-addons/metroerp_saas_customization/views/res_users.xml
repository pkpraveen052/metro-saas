<odoo>


    <record id="view_users_form_inherit_ap" model="ir.ui.view">
        <field name="name">res.users.inherited.ap</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='signature']" position="after">
                <field name="enable_ap" invisible="1"/>
                <field name="restrict_ap" invisible="1"/>
            </xpath>
        </field>
    </record>

</odoo>
