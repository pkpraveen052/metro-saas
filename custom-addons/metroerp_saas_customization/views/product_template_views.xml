<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_product_form_uom_inherit" model="ir.ui.view">
        <field name="name">product.template.uom.form</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='general_information']//field[@name='uom_id']" position="replace">
                <label for="uom_id"/>
                <div name="uom">
                    <field name="uom_id" class="oe_inline"
                           groups="uom.group_uom" options="{'no_quick_create':True,'no_create_edit':True,'no_open': True}"/>
                    <button name="open_uom_wizard" icon="fa-arrow-right" type="object"
                            groups="uom.group_uom" class="oe_inline">
                        <span>
                            Update Uom
                        </span>
                    </button>
                </div>
            </xpath>
        </field>
    </record>

        <!-- Product Template Inherited Form View -->
		<record id="view_product_template_brs_inherit" model="ir.ui.view">
            <field name="name">product.template.brs</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_only_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='categ_id']" position="after">
                    	<field name="is_brs_deposit"/>
                        <field name="brs_deposit_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                </xpath>
            </field>
        </record>

        <!-- Product Product Inherited Form View -->
		<record id="view_product_product_brs_inherit" model="ir.ui.view">
            <field name="name">product.product.brs</field>
            <field name="model">product.product</field>
            <field name="inherit_id" ref="product.product_normal_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='categ_id']" position="after">
                    	<field name="is_brs_deposit"/>
                        <field name="brs_deposit_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                </xpath>
            </field>
        </record>
</odoo>
