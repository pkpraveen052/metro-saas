<odoo>
    <data>
        
        <record id="access_crm_lead_scoring_frequency_field_custom_group" model="ir.model.access">
            <field name="name">access_crm_lead_scoring_frequency_field_custom_group</field>
            <field name="model_id" ref="crm.model_crm_lead_scoring_frequency_field"/>
            <field name="group_id" ref="base.group_user"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="access_mail_alias_user_custom_group" model="ir.model.access">
            <field name="name">access_mail_alias_user_custom_group</field>
            <field name="model_id" ref="mail.model_mail_alias"/>
            <field name="group_id" ref="base.group_user"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>



        <record id="base.module_category_sales_crm" model="ir.module.category">
            <field name="description">Helps you handle your crm, sales and leads.</field>
            <field name="sequence">22</field>
        </record>

        <record id="group_crm_salesman" model="res.groups">
            <field name="name">User: Own Documents Only</field>
            <field name="category_id" ref="base.module_category_sales_crm"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">the user will have access to his own data in the sales application.</field>
        </record>

        <record id="group_crm_salesman_all_leads" model="res.groups">
            <field name="name">User: All Documents</field>
            <field name="category_id" ref="base.module_category_sales_crm"/>
            <field name="implied_ids" eval="[(4, ref('group_crm_salesman'))]"/>
            <field name="comment">the user will have access to all records of everyone in the sales application.</field>
        </record>

        <record id="group_crm_manager" model="res.groups">
            <field name="name">Administrator</field>
            <field name="comment">the user will have an access to the sales configuration as well as statistic reports.</field>
            <field name="category_id" ref="base.module_category_sales_crm"/>
            <field name="implied_ids" eval="[(4, ref('group_crm_salesman_all_leads'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>
    
        <record id="crm.crm_menu_root" model="ir.ui.menu">
            <field name="name">CRM</field>
            <field name="groups_id" eval="[(3, ref('sales_team.group_sale_salesman')), (3, ref('sales_team.group_sale_manager')),
             (4, ref('metroerp_crm_enhancement.group_crm_salesman')),(4, ref('metroerp_crm_enhancement.group_crm_salesman_all_leads')),(4, ref('metroerp_crm_enhancement.group_crm_manager'))]"/>
        </record>

        <record id="crm.crm_lead_menu_my_activities" model="ir.ui.menu">
            <field name="name">My Activities</field>
            <field name="groups_id" eval="[(3, ref('sales_team.group_sale_manager')),(4, ref('metroerp_crm_enhancement.group_crm_manager'))]"/>
        </record>

        <record id="crm.sales_team_menu_team_pipeline" model="ir.ui.menu">
            <field name="name">Teams</field>
            <field name="groups_id" eval="[(3, ref('sales_team.group_sale_manager')),(4, ref('metroerp_crm_enhancement.group_crm_manager'))]"/>
        </record>

        <record id="crm.crm_menu_report" model="ir.ui.menu">
            <field name="name">Reporting</field>
            <field name="groups_id" eval="[(3, ref('sales_team.group_sale_manager')),(4, ref('metroerp_crm_enhancement.group_crm_manager'))]"/>
        </record>

        <record id="crm.crm_menu_config" model="ir.ui.menu">
            <field name="name">Configuration</field>
            <field name="groups_id" eval="[(3, ref('sales_team.group_sale_manager')),(4, ref('metroerp_crm_enhancement.group_crm_manager'))]"/>
        </record>

        <record id="crm.menu_crm_config_opportunity" model="ir.ui.menu">
            <field name="name">Opportunities</field>
            <field name="groups_id" eval="[(3, ref('sales_team.group_sale_manager')),(4, ref('metroerp_crm_enhancement.group_crm_manager'))]"/>
        </record>

        <record id="crm.menu_crm_config_lead" model="ir.ui.menu">
            <field name="name">Pipeline</field>
            <field name="groups_id" eval="[(3, ref('sales_team.group_sale_manager')),(4, ref('metroerp_crm_enhancement.group_crm_manager'))]"/>
        </record>

        <record id="crm_iap_lead.crm_menu_lead_generation" model="ir.ui.menu">
            <field name="name">Lead Generation</field>
            <field name="groups_id" eval="[(4, ref('base.group_system'))]"/>
        </record>

        <record id="crm.menu_crm_lead_stage_act" model="ir.ui.menu">
            <field name="name">Stages</field>
            <field name="groups_id" eval="[(3,ref('base.group_no_one')),(4, ref('metroerp_crm_enhancement.group_crm_manager'))]"/>
        </record>


        <record id="crm.crm_team_menu_config_activity_types" model="ir.ui.menu">
            <field name="name">Activity Types</field>
            <field name="groups_id" eval="[(4, ref('base.group_system'))]"/>
        </record>

    
    </data>
</odoo>
